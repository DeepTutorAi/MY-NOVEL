<div class="ambient-player" data-enabled="false" data-soundscape="false">
  <button class="ambient-main" type="button" aria-label="เปิดแผงเสียง" aria-expanded="false">
    <svg class="ambient-icon ambient-icon-off" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M16 9a5 5 0 0 1 0 6" />
      <path d="M3 9v6h4l5 4V5L7 9H3Z" />
      <path d="M22 2 2 22" />
    </svg>
    <svg class="ambient-icon ambient-icon-on" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M11 5 6 9H2v6h4l5 4V5Z" />
      <path d="M15.5 8.5a5 5 0 0 1 0 7" />
      <path d="M19 5a10 10 0 0 1 0 14" />
    </svg>
  </button>

  <div class="ambient-panel" role="dialog" aria-label="แผงเสียงอ่านนิยาย">
    <div class="ambient-panel-head">
      <strong>เสียงประกอบ</strong>
      <span data-ambient-cue>เพลงช่วงที่ 1: ต้อนรับ</span>
    </div>

    <div class="ambient-control-row" aria-label="ควบคุมเพลง">
      <button class="ambient-icon-button" type="button" data-ambient-prev aria-label="เพลงก่อนหน้า">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="m11 17-5-5 5-5" />
          <path d="m18 17-5-5 5-5" />
        </svg>
      </button>
      <button class="ambient-icon-button ambient-play" type="button" data-ambient-play aria-label="เปิดเพลง">
        <svg class="ambient-play-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M8 5v14l11-7Z" />
        </svg>
        <svg class="ambient-pause-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M8 5v14" />
          <path d="M16 5v14" />
        </svg>
      </button>
      <button class="ambient-icon-button" type="button" data-ambient-next aria-label="เพลงถัดไป">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="m6 17 5-5-5-5" />
          <path d="m13 17 5-5-5-5" />
        </svg>
      </button>
    </div>

    <label class="ambient-field">
      <span>ระดับเพลง</span>
      <input data-ambient-volume aria-label="ระดับเพลง" type="range" min="0" max="1" step="0.05" />
    </label>

    <label class="ambient-switch">
      <input data-soundscape-toggle type="checkbox" />
      <span>เสียงไฟไม้และลม</span>
    </label>

    <label class="ambient-switch">
      <input data-snow-toggle type="checkbox" />
      <span>หิมะพื้นหลัง</span>
    </label>

    <label class="ambient-field">
      <span>ระดับเสียงไฟ</span>
      <input data-soundscape-volume aria-label="ระดับเสียงไฟ" type="range" min="0" max="0.7" step="0.05" />
    </label>
  </div>
</div>

<script>
  import { getMusicCue, musicCueForChapter } from "../../../data/lodge/audio-cues";
  import { ambientAudio } from "../../../scripts/lodge/audio-state";
  import { soundscapeAudio } from "../../../scripts/lodge/soundscape-state";

  const SNOW_MOTION_KEY = "hvitveldt:motion:snow";
  const SNOW_MOTION_EVENT = "hvitveldt:motion-change";

  type AmbientWindow = Window & {
    __hvitveldtAmbientPlayerGlobalBound?: boolean;
    __hvitveldtAmbientDismissBound?: boolean;
    __hvitveldtAmbientCueBound?: boolean;
  };

  const ambientWindow = window as AmbientWindow;

  const getElements = () => {
    const root = document.querySelector(".ambient-player");

    return {
      root,
      main: root?.querySelector(".ambient-main"),
      play: root?.querySelector("[data-ambient-play]"),
      previous: root?.querySelector("[data-ambient-prev]"),
      next: root?.querySelector("[data-ambient-next]"),
      musicSlider: root?.querySelector("[data-ambient-volume]"),
      soundscapeToggle: root?.querySelector("[data-soundscape-toggle]"),
      snowToggle: root?.querySelector("[data-snow-toggle]"),
      soundscapeSlider: root?.querySelector("[data-soundscape-volume]"),
      cue: root?.querySelector("[data-ambient-cue]"),
    };
  };

  const getChapterProgress = (article: HTMLElement) => {
    const rect = article.getBoundingClientRect();
    const scrollable = Math.max(1, rect.height - window.innerHeight);
    const read = Math.min(Math.max(-rect.top, 0), scrollable);
    return read / scrollable;
  };

  const applyCueFromPage = () => {
    const article = document.querySelector("article.chapter");

    if (!(article instanceof HTMLElement)) {
      ambientAudio.setCue("snow-forest");
      return;
    }

    const chapter = Number(article.dataset.chapter ?? "1");
    const cue = musicCueForChapter(chapter, getChapterProgress(article));
    ambientAudio.setCue(cue.id);
  };

  const readSnowMotionEnabled = () => {
    try {
      return localStorage.getItem(SNOW_MOTION_KEY) !== "false";
    } catch {
      return true;
    }
  };

  const setSnowMotionEnabled = (enabled: boolean) => {
    try {
      localStorage.setItem(SNOW_MOTION_KEY, String(enabled));
    } catch {
      // localStorage can be unavailable in private or restricted browser modes.
    }

    window.dispatchEvent(new CustomEvent(SNOW_MOTION_EVENT));
  };

  const cueText = () => {
    const cue = getMusicCue(ambientAudio.getCurrentCue());
    return `เพลง ${cue.number}: ${cue.label}`;
  };

  const setPanelOpen = (open: boolean) => {
    const { root, main } = getElements();

    root?.setAttribute("data-open", String(open));

    if (main instanceof HTMLButtonElement) {
      main.setAttribute("aria-expanded", String(open));
      main.setAttribute("aria-label", open ? "ปิดแผงเสียง" : "เปิดแผงเสียง");
    }
  };

  const syncState = () => {
    const { root, play, cue, soundscapeToggle, snowToggle, musicSlider, soundscapeSlider } = getElements();
    const enabled = ambientAudio.isEnabled();
    const soundscapeEnabled = soundscapeAudio.isEnabled();
    const snowMotionEnabled = readSnowMotionEnabled();

    root?.setAttribute("data-enabled", String(enabled));
    root?.setAttribute("data-soundscape", String(soundscapeEnabled));
    root?.setAttribute("data-snow-motion", String(snowMotionEnabled));

    if (play instanceof HTMLButtonElement) {
      play.setAttribute("aria-label", enabled ? "หยุดเพลง" : "เปิดเพลง");
      play.setAttribute("aria-pressed", String(enabled));
    }

    if (cue instanceof HTMLElement) {
      cue.textContent = cueText();
    }

    if (soundscapeToggle instanceof HTMLInputElement) {
      soundscapeToggle.checked = soundscapeEnabled;
    }

    if (snowToggle instanceof HTMLInputElement) {
      snowToggle.checked = snowMotionEnabled;
    }

    if (musicSlider instanceof HTMLInputElement) {
      musicSlider.value = String(ambientAudio.getVolume());
    }

    if (soundscapeSlider instanceof HTMLInputElement) {
      soundscapeSlider.value = String(soundscapeAudio.getVolume());
    }
  };

  const bindPlayer = () => {
    const { root, main, play, previous, next, musicSlider, soundscapeToggle, snowToggle, soundscapeSlider } = getElements();

    if (
      !(root instanceof HTMLElement) ||
      !(main instanceof HTMLButtonElement) ||
      !(play instanceof HTMLButtonElement) ||
      !(previous instanceof HTMLButtonElement) ||
      !(next instanceof HTMLButtonElement) ||
      !(musicSlider instanceof HTMLInputElement) ||
      !(soundscapeToggle instanceof HTMLInputElement) ||
      !(snowToggle instanceof HTMLInputElement) ||
      !(soundscapeSlider instanceof HTMLInputElement)
    ) {
      return;
    }

    ambientAudio.init();
    soundscapeAudio.init();
    applyCueFromPage();
    syncState();

    if (root.dataset.ambientBound === "true") {
      return;
    }

    root.dataset.ambientBound = "true";

    main.addEventListener("click", () => {
      setPanelOpen(root.getAttribute("data-open") !== "true");
    });

    play.addEventListener("click", async () => {
      if (ambientAudio.isEnabled()) {
        ambientAudio.disable();
        syncState();
        return;
      }

      applyCueFromPage();
      const enabled = await ambientAudio.enable();
      root.setAttribute("data-enabled", String(enabled));
      syncState();
    });

    previous.addEventListener("click", () => {
      ambientAudio.previousCue();
      syncState();
    });

    next.addEventListener("click", () => {
      ambientAudio.nextCue();
      syncState();
    });

    musicSlider.addEventListener("input", () => {
      ambientAudio.setVolume(Number(musicSlider.value));
      syncState();
    });

    soundscapeToggle.addEventListener("change", async () => {
      if (soundscapeToggle.checked) {
        await soundscapeAudio.enable();
      } else {
        soundscapeAudio.disable();
      }

      syncState();
    });

    snowToggle.addEventListener("change", () => {
      setSnowMotionEnabled(snowToggle.checked);
      syncState();
    });

    soundscapeSlider.addEventListener("input", () => {
      soundscapeAudio.setVolume(Number(soundscapeSlider.value));
      syncState();
    });

    if (!ambientWindow.__hvitveldtAmbientDismissBound) {
      ambientWindow.__hvitveldtAmbientDismissBound = true;

      document.addEventListener("click", (event) => {
        const { root: currentRoot } = getElements();
        const target = event.target;

        if (currentRoot instanceof HTMLElement && target instanceof Node && !currentRoot.contains(target)) {
          setPanelOpen(false);
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          setPanelOpen(false);
        }
      });
    }

    if (!ambientWindow.__hvitveldtAmbientCueBound) {
      ambientWindow.__hvitveldtAmbientCueBound = true;
      let queued = false;

      const requestCueSync = () => {
        if (queued) {
          return;
        }

        queued = true;
        window.requestAnimationFrame(() => {
          queued = false;
          applyCueFromPage();
          syncState();
        });
      };

      window.addEventListener("scroll", requestCueSync, { passive: true });
      window.addEventListener("resize", requestCueSync);
      document.addEventListener("astro:page-load", requestCueSync);
    }
  };

  if (!ambientWindow.__hvitveldtAmbientPlayerGlobalBound) {
    ambientWindow.__hvitveldtAmbientPlayerGlobalBound = true;

    document.addEventListener("astro:page-load", bindPlayer);
    window.addEventListener("hvitveldt:audio-error", () => {
      syncState();
    });
  }

  bindPlayer();
</script>

<style>
  .ambient-player {
    position: relative;
    z-index: 3;
    color: var(--ink-dim);
  }

  .ambient-main,
  .ambient-icon-button {
    display: grid;
    place-items: center;
    padding: 0;
    color: inherit;
    border: 1px solid color-mix(in oklab, var(--ink) 10%, transparent);
    border-radius: 999px;
    background: color-mix(in oklab, var(--paper) 72%, transparent);
  }

  .ambient-main {
    inline-size: 2.4rem;
    block-size: 2.4rem;
  }

  .ambient-icon-button {
    inline-size: 2.45rem;
    block-size: 2.45rem;
  }

  .ambient-main:hover,
  .ambient-icon-button:hover {
    color: var(--ink);
    border-color: color-mix(in oklab, var(--ink) 22%, transparent);
  }

  .ambient-main:focus-visible,
  .ambient-icon-button:focus-visible,
  .ambient-field input:focus-visible,
  .ambient-switch input:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .ambient-icon,
  .ambient-icon-button svg {
    inline-size: 1.18rem;
    block-size: 1.18rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.75;
  }

  .ambient-icon-on,
  .ambient-pause-icon {
    display: none;
  }

  .ambient-player[data-enabled="true"] {
    color: var(--ink);
  }

  .ambient-player[data-enabled="true"] .ambient-icon-on,
  .ambient-player[data-enabled="true"] .ambient-pause-icon {
    display: block;
  }

  .ambient-player[data-enabled="true"] .ambient-icon-off,
  .ambient-player[data-enabled="true"] .ambient-play-icon {
    display: none;
  }

  .ambient-panel {
    position: absolute;
    inset-block-start: calc(100% + 0.55rem);
    inset-inline-end: 0;
    width: min(18.5rem, calc(100vw - 1rem));
    padding: 1rem;
    border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);
    background: color-mix(in oklab, var(--paper) 93%, black);
    box-shadow: 0 1.5rem 4rem rgb(0 0 0 / 0.42);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-0.35rem);
    transition: opacity 150ms ease-out, transform 150ms ease-out;
  }

  .ambient-player[data-open="true"] .ambient-panel {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .ambient-panel-head {
    display: grid;
    gap: 0.15rem;
    padding-block-end: 0.8rem;
    border-block-end: 1px solid color-mix(in oklab, var(--ink) 10%, transparent);
  }

  .ambient-panel-head strong {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
  }

  .ambient-panel-head span,
  .ambient-field span,
  .ambient-switch span {
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .ambient-control-row {
    display: flex;
    justify-content: center;
    gap: 0.6rem;
    padding-block: 1rem;
  }

  .ambient-field {
    display: grid;
    gap: 0.4rem;
    margin-block-start: 0.65rem;
  }

  .ambient-field input {
    inline-size: 100%;
    accent-color: var(--rune);
    cursor: pointer;
  }

  .ambient-switch {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-block-start: 1rem;
    padding-block-start: 0.85rem;
    border-block-start: 1px solid color-mix(in oklab, var(--ink) 10%, transparent);
  }

  .ambient-switch input {
    inline-size: 1rem;
    block-size: 1rem;
    accent-color: var(--accent);
  }

  @media (max-width: 700px) {
    .ambient-panel {
      position: fixed;
      inset-block-start: calc(var(--topbar-height) + 0.45rem);
      inset-inline: 0.5rem;
      width: auto;
    }
  }
</style>
