---
import BaseLayout from "../layouts/BaseLayout.astro";
import Rune from "../components/marks/Rune.astro";
import puzzleRaw from "../content/extras/puzzle-map.md?raw";

const body = puzzleRaw.replace(/^---[\s\S]*?---\s*/, "").trim();
const [itemsPart, summaryPart = ""] = body.split(/\n\nสรุป:/);
const [introLine, ...itemBlocks] = itemsPart.split(/\n(?=★ )/);
const items = itemBlocks.map((block) => {
  const [titleLine = "", ...lines] = block.trim().split("\n");
  const detailLines = lines.map((line) => line.trim()).filter(Boolean);
  const bullets: string[] = [];
  const paragraphs: string[] = [];

  for (const line of detailLines) {
    if (line.startsWith("-")) {
      bullets.push(line.replace(/^-\s*/, ""));
    } else {
      paragraphs.push(line);
    }
  }

  return {
    title: titleLine.replace(/^★\s*/, ""),
    bullets,
    paragraphs,
  };
});
---

<BaseLayout
  title="Puzzle Map — Hvitveldt Lodge"
  description="แผนที่ปริศนาและคำใบ้ของ Hvitveldt Lodge"
  bodyClass="puzzle-page"
>
  <main class="puzzle-shell">
    <section class="puzzle-gate" data-puzzle-gate>
      <div class="puzzle-gate-panel">
        <p>หน้านี้เปิดเผยปริศนาทั้งหมดของเรื่อง อ่านหลังจบเรื่องเท่านั้น</p>
        <label class="puzzle-confirm">
          <input type="checkbox" data-puzzle-confirm />
          <span>ฉันอ่านจบแล้ว</span>
        </label>
        <button class="puzzle-open" type="button" disabled data-puzzle-open>เปิด</button>
      </div>
    </section>

    <article class="puzzle-article" data-puzzle-content hidden>
      <h1>Puzzle Map</h1>
      <p class="puzzle-intro">{introLine}</p>
      <div class="puzzle-list">
        {
          items.map((item, index) => (
            <section class="puzzle-item">
              <h2>{item.title}</h2>
              {item.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
              {item.bullets.length > 0 && (
                <ul>
                  {item.bullets.map((bullet) => <li>{bullet}</li>)}
                </ul>
              )}
              <div class="puzzle-rune">
                <Rune seed={index + 21} />
              </div>
            </section>
          ))
        }
      </div>
      {
        summaryPart && (
          <div class="puzzle-summary">
            <p>สรุป:{summaryPart}</p>
          </div>
        )
      }
    </article>
  </main>

  <script>
    const gate = document.querySelector("[data-puzzle-gate]");
    const content = document.querySelector("[data-puzzle-content]");
    const confirm = document.querySelector("[data-puzzle-confirm]");
    const open = document.querySelector("[data-puzzle-open]");
    const key = "hvitveldt:puzzle-unlocked";

    const reveal = () => {
      gate?.setAttribute("hidden", "");
      content?.removeAttribute("hidden");
      localStorage.setItem(key, "true");
    };

    if (localStorage.getItem(key) === "true") {
      reveal();
    }

    if (confirm instanceof HTMLInputElement && open instanceof HTMLButtonElement) {
      confirm.addEventListener("change", () => {
        open.disabled = !confirm.checked;
      });

      open.addEventListener("click", () => {
        if (confirm.checked) {
          reveal();
        }
      });
    }
  </script>
</BaseLayout>
