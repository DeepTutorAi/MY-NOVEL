---
import type { NovelMeta } from "../../data/_novels";
import { withBase } from "../../utils/base-path";

interface Props {
  novel: NovelMeta;
}

const { novel } = Astro.props;
const isAvailable = novel.status === "เผยแพร่";
const heroImage = withBase(novel.heroImage);
const accentStyle = `--novel-accent: ${novel.accent}`;
const useImage = novel.heroState !== "placeholder";
---

<div class="novel-card-wrapper" data-novel-slug={novel.slug} data-status={novel.status}>
  <!-- Clickable / Published Card -->
  <a
    class="novel-card"
    style={accentStyle + (isAvailable ? "" : "; display: none")}
    href={withBase(novel.href)}
    aria-label={`เปิดอ่าน ${novel.titleTh}`}
    data-active-card
  >
    <span class="novel-card-media" aria-hidden="true">
      {
        useImage ? (
          <img src={heroImage} alt="" loading="eager" decoding="async" />
        ) : (
          <span class="novel-card-placeholder">
            <span class="station-line"></span>
            <span class="station-moon"></span>
            <span class="station-platform"></span>
          </span>
        )
      }
    </span>
    <span class="novel-card-body">
      <span class="novel-card-kicker">{novel.titleEn}</span>
      <strong class="novel-card-title">{novel.titleTh}</strong>
      <span class="novel-card-subtitle">{novel.subtitle}</span>
      <span class="novel-card-meta">{novel.mood} · {novel.length}</span>
      <span class="novel-card-footer">
        <span>เผยแพร่</span>
        <span class="novel-card-action">เริ่มอ่าน</span>
      </span>
    </span>
  </a>

  <!-- Locked / Coming Soon Card -->
  <article
    class="novel-card is-disabled"
    style={accentStyle + (isAvailable ? "; display: none" : "")}
    aria-disabled="true"
    data-locked-card
  >
    <span class="novel-card-media" aria-hidden="true">
      <span class="novel-card-placeholder">
        <span class="station-line"></span>
        <span class="station-moon"></span>
        <span class="station-platform"></span>
      </span>
    </span>
    <span class="novel-card-body">
      <span class="novel-card-kicker">{novel.titleEn}</span>
      <strong class="novel-card-title">{novel.titleTh}</strong>
      <span class="novel-card-subtitle">
        {novel.slug === "tsukinomi" ? "นิยายจะมาเร็วๆ นี้ (เนื้อเรื่องยังไม่เสร็จ)" : novel.subtitle}
      </span>
      <span class="novel-card-meta">{novel.mood} · {novel.length}</span>
      <span class="novel-card-footer">
        <span>{novel.status}</span>
        <span class="novel-card-action">รอเปิดสถานี</span>
      </span>
    </span>
  </article>
</div>

{
  novel.slug === "tsukinomi" && (
    <script is:inline>
      (() => {
        const wrapper = document.querySelector('[data-novel-slug="tsukinomi"]');
        if (!wrapper) return;

        const activeCard = wrapper.querySelector('[data-active-card]');
        const lockedCard = wrapper.querySelector('[data-locked-card]');
        
        const BYPASS_KEY = "tsukinomi:extra-bypassed";
        // Double hash verification: H2 = sha256(H1)
        const EXPECTED_H2 = "ef8fa25c0397c32aa53ef84fd328412eb170e33ad8b0a6c62cd0f67f4f604f18";
        
        // SHA-256 helper
        async function sha256(message) {
          const msgBuffer = new TextEncoder().encode(message);
          const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);
          const hashArray = Array.from(new Uint8Array(hashBuffer));
          return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
        }

        const getSecretReadsCount = () => {
          try {
            const raw = localStorage.getItem("tsukinomi:reading:secret:reads");
            const arr = raw ? JSON.parse(raw) : [];
            if (Array.isArray(arr)) {
              return arr.filter(id => id !== "00-introduction").length;
            }
            return 0;
          } catch {
            return 0;
          }
        };

        const getLodgeReadsCount = () => {
          try {
            const raw = localStorage.getItem("hvitveldt:secret:reads");
            const arr = raw ? JSON.parse(raw) : [];
            if (Array.isArray(arr)) {
              return arr.filter(id => id !== "00-introduction").length;
            }
            return 0;
          } catch {
            return 0;
          }
        };

        const checkUnlocked = async () => {
          const storedH1 = localStorage.getItem(BYPASS_KEY);
          if (storedH1) {
            const calculatedH2 = await sha256(storedH1);
            if (calculatedH2 === EXPECTED_H2) {
              return true;
            }
          }
          
          // Or unlock via reading progress
          if (getSecretReadsCount() >= 4) {
            return true;
          }

          // Or unlock via Lodge extra page unlock (Bypass check)
          const lodgeBypassH1 = localStorage.getItem("hvitveldt:extra-bypassed");
          if (lodgeBypassH1) {
            const calculatedLodgeH2 = await sha256(lodgeBypassH1);
            if (calculatedLodgeH2 === "6d4829eebb416434779797994fa3b4324fcf1b3eb2392c99b0c6599313b8dad7") {
              return true;
            }
          }

          // Or unlock via Lodge reading progress (>= 15 chapters read)
          if (getLodgeReadsCount() >= 15) {
            return true;
          }

          return false;
        };

        const updateCardUI = async () => {
          const unlocked = await checkUnlocked();
          if (unlocked && activeCard && lockedCard) {
            activeCard.style.display = '';
            lockedCard.style.display = 'none';
          } else if (activeCard && lockedCard) {
            activeCard.style.display = 'none';
            lockedCard.style.display = '';
          }
        };

        // Initialize
        updateCardUI();
        document.addEventListener("astro:page-load", updateCardUI);

        // Developer shortcut trigger: 5 clicks on the locked card
        let clickCount = 0;
        let lastClickTime = 0;
        if (lockedCard) {
          lockedCard.addEventListener('click', async () => {
            const now = Date.now();
            if (now - lastClickTime > 2000) {
              clickCount = 0; // reset if clicks are too slow
            }
            clickCount++;
            lastClickTime = now;

            if (clickCount >= 5) {
              clickCount = 0;
              const password = prompt('กรอกรหัสผ่านผู้พัฒนาสำหรับปลดล็อคเรื่อง "สถานีทะเลพระจันทร์":');
              if (password) {
                const h1 = await sha256(password.trim());
                const h2 = await sha256(h1);
                if (h2 === EXPECTED_H2) {
                  localStorage.setItem(BYPASS_KEY, h1);
                  alert('ปลดล็อคผู้พัฒนาสำเร็จแล้ว!');
                  updateCardUI();
                  // Also refresh page to trigger ResumeCard updates
                  window.location.reload();
                } else {
                  alert('รหัสผ่านไม่ถูกต้อง');
                }
              }
            }
          });
        }
      })();
    </script>
  )
}

