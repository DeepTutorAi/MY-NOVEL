---
import BaseLayout from "../layouts/BaseLayout.astro";
import Rune from "../components/marks/Rune.astro";
import puzzleRaw from "../content/extras/puzzle-map.md?raw";

const body = puzzleRaw.replace(/^\uFEFF/, "").replace(/^---[\s\S]*?---\s*/, "").trim();
const [itemsPart, summaryPart = ""] = body.split(/\n\nสรุป:/);
const [introLine, ...itemBlocks] = itemsPart.split(/\n(?=★ )/);
const items = itemBlocks.map((block) => {
  const [titleLine = "", ...lines] = block.trim().split("\n");
  const detailLines = lines.map((line) => line.trim()).filter(Boolean);
  const bullets: string[] = [];
  const paragraphs: string[] = [];

  for (const line of detailLines) {
    if (line.startsWith("-")) {
      bullets.push(line.replace(/^-\s*/, ""));
    } else {
      paragraphs.push(line);
    }
  }

  return {
    title: titleLine.replace(/^★\s*/, ""),
    bullets,
    paragraphs,
  };
});
---

<BaseLayout
  title="แผนที่ปริศนา — ฮวิตเวลต์ ลอดจ์"
  description="แผนที่ปริศนาและคำใบ้ของฮวิตเวลต์ ลอดจ์"
  bodyClass="puzzle-page"
>
  <main class="puzzle-shell">
    <section class="puzzle-gate" data-puzzle-gate>
      <div class="puzzle-gate-panel" data-puzzle-panel>
        <p>หน้านี้เปิดเผยปริศนาทั้งหมดของเรื่อง อ่านหลังจบเรื่องเท่านั้น</p>
        <label class="puzzle-confirm">
          <input type="checkbox" data-puzzle-confirm />
          <span>ฉันอ่านจบแล้ว และยอมเห็นสปอยล์</span>
        </label>
        <button class="puzzle-open puzzle-tease" type="button" hidden data-puzzle-tease>
          เปิดแผนที่ปริศนา
        </button>
        <div class="puzzle-challenge" data-puzzle-challenge hidden>
          <p class="puzzle-gotcha">อะฮ่า... ก่อนจะเปิดได้ ตอบนี่ให้ได้ก่อน</p>
          <label class="puzzle-passphrase">
            <span>เมืองสุดท้ายที่ Elena ไปถึงก่อนโลกปกติเริ่มกลับมา</span>
            <input
              type="text"
              inputmode="text"
              autocomplete="off"
              spellcheck="false"
              placeholder="answer in English"
              data-puzzle-passphrase
            />
          </label>
          <p class="puzzle-error" data-puzzle-error hidden>รหัสยังไม่ถูก กลับไปอ่านช่วงทางรอดอีกครั้ง</p>
          <button class="puzzle-open" type="button" disabled data-puzzle-open>ยืนยันคำตอบ</button>
        </div>
      </div>
    </section>

    <article class="puzzle-article" data-puzzle-content hidden>
      <h1>แผนที่ปริศนา</h1>
      <p class="puzzle-intro">{introLine}</p>
      <div class="puzzle-list">
        {
          items.map((item, index) => (
            <section class="puzzle-item">
              <h2>{item.title}</h2>
              {item.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
              {item.bullets.length > 0 && (
                <ul>
                  {item.bullets.map((bullet) => <li>{bullet}</li>)}
                </ul>
              )}
              <div class="puzzle-rune">
                <Rune seed={index + 21} />
              </div>
            </section>
          ))
        }
      </div>
      {
        summaryPart && (
          <div class="puzzle-summary">
            <p>สรุป:{summaryPart}</p>
          </div>
        )
      }
    </article>
  </main>

  <script>
    const gate = document.querySelector("[data-puzzle-gate]");
    const content = document.querySelector("[data-puzzle-content]");
    const panel = document.querySelector("[data-puzzle-panel]");
    const confirm = document.querySelector("[data-puzzle-confirm]");
    const tease = document.querySelector("[data-puzzle-tease]");
    const challenge = document.querySelector("[data-puzzle-challenge]");
    const passphrase = document.querySelector("[data-puzzle-passphrase]");
    const error = document.querySelector("[data-puzzle-error]");
    const open = document.querySelector("[data-puzzle-open]");
    const key = "hvitveldt:puzzle-unlocked";
    const accepted = new Set(["karasjok"]);

    const reveal = () => {
      gate?.setAttribute("hidden", "");
      content?.removeAttribute("hidden");
      localStorage.setItem(key, "karasjok");
    };

    const normalize = (value: string) => value.trim().toLowerCase().replace(/[^a-z]/g, "");
    const isUnlocked = () => {
      const value = localStorage.getItem(key);
      return value === "true" || value === "karasjok";
    };

    if (isUnlocked()) {
      reveal();
    }

    if (
      confirm instanceof HTMLInputElement &&
      tease instanceof HTMLButtonElement &&
      challenge instanceof HTMLElement &&
      passphrase instanceof HTMLInputElement &&
      open instanceof HTMLButtonElement
    ) {
      const hideChallenge = () => {
        challenge.hidden = true;
        passphrase.value = "";
        open.disabled = true;
        error?.setAttribute("hidden", "");
        panel?.removeAttribute("data-stage");
      };

      const updateButton = () => {
        tease.hidden = !confirm.checked || !challenge.hidden;
        open.disabled = !confirm.checked || passphrase.value.trim().length === 0;
        error?.setAttribute("hidden", "");
      };

      confirm.addEventListener("change", () => {
        if (!confirm.checked) {
          hideChallenge();
        }

        updateButton();
      });

      tease.addEventListener("click", () => {
        if (!confirm.checked) {
          return;
        }

        challenge.hidden = false;
        tease.hidden = true;
        panel?.setAttribute("data-stage", "challenge");
        updateButton();
        passphrase.focus();
      });

      passphrase.addEventListener("input", updateButton);
      passphrase.addEventListener("keydown", (event) => {
        if (event.key === "Enter" && !open.disabled) {
          open.click();
        }
      });

      open.addEventListener("click", () => {
        if (confirm.checked && accepted.has(normalize(passphrase.value))) {
          reveal();
          return;
        }

        error?.removeAttribute("hidden");
        passphrase.focus();
      });
    }
  </script>
</BaseLayout>
