<div class="sea-abyssal-mist" aria-hidden="true"></div>
<canvas class="sea-rain-canvas" aria-hidden="true"></canvas>

<style>
  .sea-abyssal-mist {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: 
      radial-gradient(ellipse at 50% 30%, var(--bg-mist-radial-1) 0%, transparent 70%),
      radial-gradient(circle at 20% 80%, var(--bg-mist-radial-2) 0%, transparent 60%),
      linear-gradient(180deg, var(--bg-mist-linear-start) 0%, var(--bg-mist-linear-end) 100%);
    opacity: 0.85;
    transition: opacity 1s ease, background 1s ease;
  }
  
  .sea-rain-canvas {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    width: 100%;
    height: 100%;
    opacity: 0.35;
  }
</style>

<script>
  let canvas: HTMLCanvasElement | null = null;
  let context: CanvasRenderingContext2D | null = null;
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  const mobile = window.matchMedia("(max-width: 640px)");

  let width = 0;
  let height = 0;
  let frame = 0;
  let particles: RainBubbleParticle[] = [];
  let motionEnabled = !reduceMotion.matches;

  type RainBubbleParticle = {
    x: number;
    y: number;
    size: number;
    speedY: number;
    speedX: number;
    opacity: number;
    type: 'rain' | 'bubble';
    wobble: number;
    wobbleSpeed: number;
  };

  const bindCanvas = () => {
    canvas = document.querySelector(".sea-rain-canvas") as HTMLCanvasElement | null;
    context = canvas ? canvas.getContext("2d") : null;
  };

  const clearCanvas = () => {
    context?.clearRect(0, 0, width, height);
  };

  const isHome = () => document.body.classList.contains("sea-page") && !document.body.classList.contains("sea-reader");

  const particleCap = () => {
    if (mobile.matches) {
      return 35;
    }
    return isHome() ? 90 : 65;
  };

  const getCurrentLayer = () => {
    if (typeof document === "undefined") return 1;
    return parseInt(document.body.getAttribute("data-depth-layer") || "1");
  };

  const getParticleColor = (opacity: number) => {
    if (typeof document === "undefined") return `rgba(0, 229, 255, ${opacity})`;
    const bodyStyles = getComputedStyle(document.body);
    const color = bodyStyles.getPropertyValue("--accent-cyan").trim();
    if (color.startsWith("#")) {
      const r = parseInt(color.slice(1, 3), 16);
      const g = parseInt(color.slice(3, 5), 16);
      const b = parseInt(color.slice(5, 7), 16);
      return `rgba(${r}, ${g}, ${b}, ${opacity})`;
    }
    return `rgba(0, 229, 255, ${opacity})`;
  };

  const createParticle = (initial = false): RainBubbleParticle => {
    const layer = getCurrentLayer();
    
    // Determine rain probability based on the current pressure layer.
    // Layer 1 (Ground): 100% rain, 0% bubbles
    // Layer 2 (Cloud): 50% rain, 50% bubbles/mist
    // Layer 3-5 (Ocean): 0% rain, 100% bubbles/spores
    let rainProb = 0.6;
    if (layer === 1) {
      rainProb = 1.0;
    } else if (layer === 2) {
      // Get current scroll morph factor to dynamically skew the probability
      const scrollTop = typeof window !== "undefined" ? (window.scrollY || document.documentElement.scrollTop) : 0;
      const scrollPercent = Math.min(1, scrollTop / 1200);
      rainProb = 1.0 - (scrollPercent * 0.5); // ranges from 1.0 (pure rain at top) to 0.5 (mixed at bottom)
    } else if (layer >= 3) {
      rainProb = 0.0;
    }

    const isRain = Math.random() < rainProb;
    return {
      x: Math.random() * width,
      y: initial ? Math.random() * height : (isRain ? -20 : height + 20),
      size: Math.random() * 1.5 + 0.5,
      speedY: isRain ? (Math.random() * 4 + 3) : -(Math.random() * 0.8 + 0.4),
      speedX: (Math.random() * 0.4 - 0.2),
      opacity: Math.random() * 0.4 + 0.15,
      type: isRain ? 'rain' : 'bubble',
      wobble: Math.random() * Math.PI * 2,
      wobbleSpeed: Math.random() * 0.05 + 0.01,
    };
  };

  let prevWidth = 0;
  const resize = () => {
    if (!canvas) return;
    const newWidth = window.innerWidth;
    const newHeight = window.innerHeight;
    
    // Ignore small height variations (often caused by mobile address bars hiding/showing)
    if (newWidth === prevWidth && Math.abs(newHeight - height) < 100) {
      canvas.width = newWidth;
      canvas.height = newHeight;
      width = newWidth;
      height = newHeight;
      return;
    }
    
    prevWidth = newWidth;
    width = canvas.width = newWidth;
    height = canvas.height = newHeight;
    particles = Array.from({ length: particleCap() }, () => createParticle(true));
  };

  const draw = () => {
    const ctx = context;
    if (!canvas || !ctx) return;
    ctx.clearRect(0, 0, width, height);

    // Get scroll position
    const scrollTop = window.scrollY || document.documentElement.scrollTop;
    const scrollPercent = Math.min(1, scrollTop / 1200); // Max morphing at 1200px scroll

    // Cull active columns to protect reading readability
    const readerElement = document.querySelector(".sea-prose");
    let cullRect: DOMRect | null = null;
    if (readerElement) {
      cullRect = readerElement.getBoundingClientRect();
    }

    const layer = getCurrentLayer();
    
    // Determine morphFactor based on the active pressure layer.
    let morphFactor = scrollPercent;
    if (layer === 1) {
      morphFactor = 0; // Pure rain, no morphing
    } else if (layer === 2) {
      morphFactor = scrollPercent * 0.5; // Max 50% morphing (mixture of rain and mist)
    } else if (layer >= 3) {
      morphFactor = 1; // Pure bubbles/spores, fully submerged
    }

    particles.forEach((p, index) => {
      // If particle coordinates are inside the reading column, draw with very low opacity
      let opacity = p.opacity;
      if (cullRect && p.x >= cullRect.left - 20 && p.x <= cullRect.right + 20) {
        opacity *= 0.12;
      }

      let currentSpeedY = p.speedY;
      let size = p.size;
      
      if (p.type === 'rain') {
        // Morph speed from falling down to slowly rising up
        currentSpeedY = p.speedY * (1 - morphFactor) - 0.6 * morphFactor;
        // Morph visual shape
        ctx.strokeStyle = getParticleColor(opacity);
        ctx.lineWidth = size * 0.8;
        
        ctx.beginPath();
        // Rain is drawn as vertical line, bubble is drawn as circle
        const length = Math.max(1, 15 * (1 - morphFactor));
        ctx.moveTo(p.x, p.y);
        ctx.lineTo(p.x + p.speedX, p.y + length);
        ctx.stroke();
      } else {
        // Bubble type: always rises, rises slightly faster as we scroll deeper (pressure)
        currentSpeedY = p.speedY * (1 + morphFactor * 0.5);
        p.wobble += p.wobbleSpeed;
        const driftX = Math.sin(p.wobble) * 0.4;
        
        ctx.fillStyle = getParticleColor(opacity);
        ctx.beginPath();
        ctx.arc(p.x + driftX, p.y, size * (1.2 + morphFactor * 0.5), 0, Math.PI * 2);
        ctx.fill();
      }

      // Update position
      p.y += currentSpeedY;
      p.x += p.speedX;

      // Boundaries recycling using dynamic type assignment based on the new particle's characteristics
      const isOutOfBounds = p.type === 'rain'
        ? (p.y > height + 20 || p.x < -20 || p.x > width + 20)
        : (p.y < -20 || p.x < -20 || p.x > width + 20);

      if (isOutOfBounds) {
        particles[index] = createParticle(false);
      }
    });
  };

  const loop = () => {
    if (!motionEnabled) return;
    draw();
    frame = requestAnimationFrame(loop);
  };

  const handleMotionChange = (e: CustomEvent) => {
    motionEnabled = e.detail !== false;
    if (motionEnabled) {
      loop();
    } else {
      cancelAnimationFrame(frame);
      clearCanvas();
    }
  };

  // Lifecycle
  document.addEventListener("astro:page-load", () => {
    bindCanvas();
    if (canvas) {
      resize();
      window.addEventListener("resize", resize);
      window.addEventListener("sea:motion-change" as any, handleMotionChange);
      
      if (motionEnabled) {
        loop();
      }
    }
  });

  document.addEventListener("astro:before-swap", () => {
    cancelAnimationFrame(frame);
    window.removeEventListener("resize", resize);
    window.removeEventListener("sea:motion-change" as any, handleMotionChange);
  });
</script>
