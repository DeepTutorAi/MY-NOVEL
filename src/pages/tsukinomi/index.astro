---
import { getCollection } from "astro:content";
import TsukinomiBaseLayout from "../../layouts/tsukinomi/TsukinomiBaseLayout.astro";
import { withBase } from "../../utils/base-path";

const sections = (await getCollection("tsukinomiSections")).sort(
  (a, b) => a.data.number - b.data.number,
);
const firstSection = sections[0];
// Never dereference firstSection.id directly: the Astro dev content store can
// be momentarily empty on the first request after boot or a content edit, and
// an unguarded `.id` turns that race into a hard 500. Fall back to the table of
// contents so the page always renders.
const sectionsHref = withBase("/tsukinomi/sections/");
const startHref = firstSection
  ? withBase(`/tsukinomi/sections/${firstSection.id}/`)
  : sectionsHref;
const sectionUnits = sections.map((section) => ({
  id: section.id,
  number: section.data.number,
  title: section.data.title,
}));
---

<TsukinomiBaseLayout
  title="สถานีทะเลพระจันทร์ — Tsukinomi no Eki"
  description="นิยายเงียบเรื่องเด็กชายกับสถานีร้าง"
  bodyClass="tsukinomi-home-page section-home palette-autumn"
  sectionPalette="autumn"
  musicCueId="discovery"
  backgroundSlotId="hero-station"
>
  <main id="tsukinomi-main" class="tsukinomi-home">
    <section class="tsukinomi-home-hero" aria-labelledby="tsukinomi-title">
      <div class="tsukinomi-home-copy">
        <p class="tsukinomi-kicker">Tsukinomi no Eki</p>
        <h1 id="tsukinomi-title">สถานีทะเลพระจันทร์</h1>
        <p>ฝนบนทางขึ้นเขาทำให้ Haruto เลี้ยวเข้าไปในสถานีร้างที่ไม่มีรถไฟวิ่งมานาน และพบเด็กผู้หญิงคนหนึ่งที่ยังนั่งรออยู่ตรงชานชาลาเดิม</p>
        <p>เรื่องนี้เดินช้ากว่าเสียงฝนเล็กน้อย อุ่นกว่าความทรงจำเล็กน้อย และปล่อยให้ช่องว่างบางอย่างพูดแทนคำตอบ</p>
        <div class="tsukinomi-home-actions">
          <a class="tsukinomi-primary-link" href={startHref}>
            เริ่ม → ภาค 1
          </a>
          <a class="tsukinomi-secondary-link" href={withBase("/tsukinomi/sections/")}>สารบัญ</a>
          <a class="tsukinomi-secondary-link" href={withBase("/tsukinomi/characters/")}>ตัวละคร</a>
          <a class="tsukinomi-secondary-link" href={withBase("/tsukinomi/extra/")}>Extra</a>
        </div>

        <div class="tsukinomi-home-resume" data-tsuki-resume hidden>
          <span class="tsukinomi-home-resume-label" data-tsuki-resume-label>อ่านค้างไว้</span>
          <strong data-tsuki-resume-title></strong>
          <small data-tsuki-resume-detail></small>
          <div class="tsukinomi-home-resume-actions">
            <a class="tsukinomi-primary-link" data-tsuki-resume-link href={withBase("/tsukinomi/sections/")}>อ่านต่อ</a>
            <button type="button" data-tsuki-resume-clear>ล้างตำแหน่ง</button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script is:inline define:vars={{ resumeBase: withBase("/tsukinomi/sections/"), tocHref: withBase("/tsukinomi/sections/"), units: sectionUnits }}>
    const card = document.querySelector("[data-tsuki-resume]");
    const label = document.querySelector("[data-tsuki-resume-label]");
    const title = document.querySelector("[data-tsuki-resume-title]");
    const detail = document.querySelector("[data-tsuki-resume-detail]");
    const link = document.querySelector("[data-tsuki-resume-link]");
    const clearBtn = document.querySelector("[data-tsuki-resume-clear]");
    const KEY = "tsukinomi:reading:last";
    const COMPLETED_PROGRESS = 0.995;

    if (card && title && detail && link instanceof HTMLAnchorElement) {
      try {
        const raw = localStorage.getItem(KEY);
        const saved = raw ? JSON.parse(raw) : null;
        const progress = Number(saved?.progress);

        if (
          saved &&
          typeof saved.sectionId === "string" &&
          Number.isFinite(progress) &&
          progress >= 0.005
        ) {
          title.textContent = `ภาค ${saved.sectionNumber}: ${saved.sectionTitle}`;

          if (progress >= COMPLETED_PROGRESS) {
            // Finished this section: hold at "done" and hand the reader the
            // next section, rather than dropping the marker entirely.
            const index = units.findIndex((unit) => unit.id === saved.sectionId);
            const next = index >= 0 ? units[index + 1] : null;
            if (label) label.textContent = "อ่านจบแล้ว";
            if (next) {
              detail.textContent = `อ่านจบ 100% · ไปต่อภาค ${next.number}: ${next.title}`;
              link.href = `${resumeBase}${next.id}/`;
              link.textContent = "อ่านภาคต่อไป →";
            } else {
              detail.textContent = "อ่านจบเรื่องแล้ว · ครบทุกภาค";
              link.href = tocHref;
              link.textContent = "กลับสารบัญ";
            }
          } else {
            const percent = Math.max(1, Math.min(99, Math.round(progress * 100)));
            if (label) label.textContent = "อ่านค้างไว้";
            detail.textContent = `ค้างไว้ประมาณ ${percent}%`;
            link.href = `${resumeBase}${saved.sectionId}/?resume=1`;
            link.textContent = "อ่านต่อ";
          }
          card.hidden = false;
        }
      } catch (error) {
        card.hidden = true;
      }

      clearBtn?.addEventListener("click", () => {
        try {
          const raw = localStorage.getItem(KEY);
          const saved = raw ? JSON.parse(raw) : null;
          if (saved && typeof saved.sectionId === "string") {
            localStorage.removeItem(`tsukinomi:reading:section:${saved.sectionId}`);
          }
          localStorage.removeItem(KEY);
        } finally {
          card.hidden = true;
        }
      });
    }
  </script>

  <style>
    .tsukinomi-home-resume {
      display: grid;
      gap: 0.3rem;
      max-width: 30rem;
      margin-top: 1.6rem;
      padding: 1rem 1.1rem;
      border: 1px solid var(--tsuki-line);
      background: color-mix(in srgb, var(--surface) 72%, transparent);
    }

    .tsukinomi-home-resume-label {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--sunset);
    }

    .tsukinomi-home-resume strong {
      font-family: var(--font-display-tsukinomi);
      font-weight: 500;
      color: var(--tsuki-ink);
    }

    .tsukinomi-home-resume small {
      color: var(--tsuki-ink-dim);
    }

    .tsukinomi-home-resume-actions {
      display: flex;
      align-items: center;
      gap: 0.9rem;
      margin-top: 0.5rem;
    }

    .tsukinomi-home-resume-actions button {
      background: none;
      border: none;
      color: var(--tsuki-ink-dim);
      font-size: 0.82rem;
      cursor: pointer;
      text-decoration: underline;
    }
  </style>
</TsukinomiBaseLayout>
