---
import { withBase } from "../../../utils/base-path";
---

<nav class="tsukinomi-topbar" aria-label="นำทางสถานีทะเลพระจันทร์">
  <a class="tsukinomi-topbar-mark" href={withBase("/tsukinomi/")}>สถานีทะเลพระจันทร์</a>
  <div class="tsukinomi-topbar-actions">
    <button
      class="tsukinomi-topbar-audio"
      type="button"
      data-walkman-mobile-trigger
      data-playing="false"
      aria-label="เปิดการตั้งค่า Walkman"
      aria-controls="tsukinomi-walkman-panel"
      aria-expanded="false"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.1a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" />
        <circle cx="12" cy="12" r="3" />
      </svg>
    </button>
    <a class="tsukinomi-topbar-link" href={withBase("/")}>ฮับนิยาย</a>
    <a class="tsukinomi-topbar-link" href={withBase("/tsukinomi/sections/")}>สารบัญ</a>
    <a class="tsukinomi-topbar-link" href={withBase("/tsukinomi/characters/")}>ตัวละคร</a>
    <a class="tsukinomi-topbar-link" href={withBase("/tsukinomi/extra/")}>Extra</a>
  </div>
</nav>

<style>
  .tsukinomi-topbar-actions {
    display: flex;
    align-items: center;
    gap: 0.72rem;
  }

  .tsukinomi-topbar-audio {
    display: none;
    place-items: center;
    width: 2.1rem;
    min-width: 2.1rem;
    height: 2.1rem;
    padding: 0;
    border: 1px solid rgba(232, 220, 196, 0.14);
    border-radius: 999px;
    background: rgba(232, 220, 196, 0.06);
    color: var(--tsuki-ink-dim);
    cursor: pointer;
  }

  .tsukinomi-topbar-audio[data-playing="true"] {
    color: var(--tsuki-ink);
    border-color: rgba(224, 163, 106, 0.48);
  }

  .tsukinomi-topbar-audio:hover,
  .tsukinomi-topbar-audio:focus-visible {
    color: var(--tsuki-ink);
    border-color: rgba(224, 163, 106, 0.62);
  }

  .tsukinomi-topbar-audio:focus-visible {
    outline: 2px solid var(--tsuki-accent);
    outline-offset: 3px;
  }

  .tsukinomi-topbar-audio svg {
    width: 1.05rem;
    height: 1.05rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tsukinomi-topbar-audio[data-open="true"] svg {
    transform: rotate(45deg);
  }

  @media (max-width: 760px) {
    .tsukinomi-topbar-audio {
      display: grid;
    }
  }
</style>
