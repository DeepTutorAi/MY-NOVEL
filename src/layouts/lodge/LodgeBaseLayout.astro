---
import "../../styles/lodge/global.css";
import "../../styles/lodge/polish.css";
import { ClientRouter } from "astro:transitions";
import GrainOverlay from "../../components/_shared/GrainOverlay.astro";
import BackgroundFog from "../../components/lodge/atmosphere/BackgroundFog.astro";
import SnowCanvas from "../../components/lodge/atmosphere/SnowCanvas.astro";
import TopBar from "../../components/lodge/navigation/TopBar.astro";
import { withBase } from "../../utils/base-path";

interface Props {
  title: string;
  description: string;
  bodyClass?: string;
  showTopBar?: boolean;
  ogImage?: string;
}

const { title, description, bodyClass, showTopBar = true, ogImage = "/og.jpg" } = Astro.props;
const canonical = Astro.url.href;
const resolvedOgImage = new URL(withBase(ogImage), Astro.site ?? Astro.url).href;
const faviconLit = withBase("/favicon.svg");
const faviconOut = withBase("/favicon-out.svg");
const faviconPng = withBase("/favicon.png");
const bodyClasses = [bodyClass, showTopBar ? "has-topbar" : "no-topbar"]
  .filter(Boolean)
  .join(" ");
---

<!doctype html>
<html lang="th">
  <head>
    <script is:inline>
      (function() {
        if (window.__localStorageIntercepted) return;
        window.__localStorageIntercepted = true;

        const originalGet = localStorage.getItem;
        const originalSet = localStorage.setItem;
        const originalRemove = localStorage.removeItem;

        function getActiveProfileId() {
          try {
            return originalGet.call(localStorage, "piichan-novels:active-profile-id") || "guest";
          } catch(e) {
            return "guest";
          }
        }

        function getProfileKey(key) {
          const prefixes = [
            "hvitveldt:reading:",
            "tsukinomi:reading:",
            "hvitveldt:secret:",
            "tsukinomi:reading:secret:",
            "hvitveldt:extra-bypassed",
            "tsukinomi:extra-bypassed"
          ];
          if (prefixes.some(p => key.startsWith(p))) {
            const activeProfile = getActiveProfileId();
            return `${key}:${activeProfile}`;
          }
          return key;
        }

        localStorage.getItem = function(key) {
          return originalGet.call(localStorage, getProfileKey(key));
        };
        localStorage.setItem = function(key, value) {
          originalSet.call(localStorage, getProfileKey(key), value);
        };
        localStorage.removeItem = function(key) {
          originalRemove.call(localStorage, getProfileKey(key));
        };
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0E0D0C" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={faviconLit} type="image/svg+xml" />
    <link rel="icon" href={faviconPng} type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href={faviconPng} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <ClientRouter />
  <body class={bodyClasses}>
    <script is:inline>
      (function() {
        function setTimeOfDay(hour) {
          let tod = 'evening';
          if (hour >= 6 && hour < 13) {
            tod = 'morning';
          } else if (hour >= 13 && hour < 19) {
            tod = 'afternoon';
          } else if (hour >= 19 || hour < 1) {
            tod = 'evening';
          } else {
            tod = 'night';
          }
          document.body.setAttribute('data-time-of-day', tod);
          window.__currentTimeOfDay = tod;
        }

        const localHour = new Date().getHours();
        setTimeOfDay(localHour);

        fetch('https://worldtimeapi.org/api/ip')
          .then(res => res.json())
          .then(data => {
            if (data && typeof data.datetime === 'string') {
              const tIndex = data.datetime.indexOf('T');
              if (tIndex !== -1) {
                const hourStr = data.datetime.substring(tIndex + 1, tIndex + 3);
                const hour = parseInt(hourStr, 10);
                if (!isNaN(hour)) {
                  setTimeOfDay(hour);
                }
              }
            }
          })
          .catch(err => {
            console.warn('IP-based time fetch failed, using local device time.', err);
          });

        if (!window.__timeOfDayBound) {
          window.__timeOfDayBound = true;
          document.addEventListener('astro:after-swap', () => {
            const currentTod = window.__currentTimeOfDay || 'evening';
            document.body.setAttribute('data-time-of-day', currentTod);
          });
        }
      })();
    </script>
    <BackgroundFog />
    <GrainOverlay />
    <SnowCanvas />
    {showTopBar && <TopBar />}
    <slot />
    <script is:inline define:vars={{ faviconLit, faviconOut }}>
      (() => {
        const media = window.matchMedia("(prefers-reduced-motion: no-preference)");
        const icon = document.querySelector('link[rel="icon"]');

        if (!media.matches || !(icon instanceof HTMLLinkElement)) {
          return;
        }

        const lit = faviconLit;
        const out = faviconOut;
        const schedule = () => {
          const delay = 20000 + Math.random() * 40000;
          window.setTimeout(() => {
            icon.href = out;
            window.requestAnimationFrame(() => {
              icon.href = lit;
              schedule();
            });
          }, delay);
        };

        schedule();
      })();
    </script>
  </body>
</html>
