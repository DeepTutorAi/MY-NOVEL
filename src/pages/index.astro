---
import NovelCard from "../components/_shared/NovelCard.astro";
import ResumeCard from "../components/_shared/ResumeCard.astro";
import { NOVELS } from "../data/_novels";
import HubLayout from "../layouts/HubLayout.astro";
---

<HubLayout
  title="Pii-chan Dechalert — Fiction Hub"
  description="พื้นที่รวมผลงานนิยายของ Pii-chan Dechalert"
>
  <main class="hub-shell" aria-labelledby="hub-title">
    <section class="hub-hero">
      <div class="hub-title-group">
        <h1 id="hub-title">Pii-chan Dechalert</h1>
        <p>สองเรื่อง สองอากาศ และพื้นที่อ่านเดียวกันสำหรับกลับไปยังโลกที่ยังค้างอยู่</p>
      </div>
      
      <div class="hub-side-col">
        <div class="hub-profile-widget" data-profile-widget style="display: none;">
          <div class="hub-profile-info">
            <span class="profile-icon">👤</span>
            <span class="profile-name" data-profile-name>...</span>
          </div>
          <button type="button" class="hub-profile-settings-btn" data-profile-settings-btn>
            สลับโปรไฟล์ / สำรองข้อมูล
          </button>
        </div>
        <p class="hub-side-note">ฮับกลางสำหรับนิยายที่เปิดให้อ่านแล้ว และเรื่องถัดไปที่กำลังรอเวลาเดินทางมาถึง</p>
      </div>
    </section>

    <ResumeCard />

    <section class="hub-library" aria-label="รายการนิยาย">
      {NOVELS.map((novel) => <NovelCard novel={novel} />)}
    </section>

    <footer class="hub-footer">
      <span>เพิ่มเรื่องใหม่: เร็วๆ นี้</span>
      <span>Pii-chan Dechalert · 2026</span>
    </footer>
  </main>

  <!-- WELCOME PROFILE OVERLAY -->
  <div class="hub-modal-overlay" data-welcome-modal style="display: none;">
    <div class="hub-modal-card">
      <div class="modal-header">
        <h2>ยินดีต้อนรับสู่คลังนิยาย</h2>
      </div>
      <div class="modal-body">
        <p class="modal-desc">
          เพื่อบันทึกประวัติการอ่านของแต่ละบุคคลอย่างถาวรและเป็นสัดส่วน (สามารถแชร์เครื่องอ่านกันได้โดยประวัติไม่ปนกัน) โปรดเลือกเข้าใช้งาน:
        </p>
        
        <div class="modal-form-group">
          <label for="new-profile-name">สร้างโปรไฟล์ใหม่ (พิมพ์ชื่อของคุณ)</label>
          <div class="modal-input-row">
            <input type="text" id="new-profile-name" placeholder="ระบุชื่อโปรไฟล์..." maxlength="15" />
            <button type="button" class="btn-primary" data-create-profile-btn>สร้าง</button>
          </div>
        </div>
        
        <div class="modal-divider"><span>หรือ</span></div>
        
        <button type="button" class="btn-secondary btn-full" data-guest-profile-btn>
          เข้าใช้งานในฐานะ Guest (ผู้เข้าชมชั่วคราว)
        </button>
      </div>
    </div>
  </div>

  <!-- SWITCH PROFILE & SETTINGS MODAL -->
  <div class="hub-modal-overlay" data-settings-modal style="display: none;">
    <div class="hub-modal-card">
      <div class="modal-header">
        <h2>สลับโปรไฟล์ / สำรองข้อมูล</h2>
        <button type="button" class="modal-close-btn" data-settings-close-btn>×</button>
      </div>
      <div class="modal-body">
        <!-- Profile list -->
        <section class="settings-section">
          <h3>👤 โปรไฟล์ทั้งหมดบนเครื่องนี้</h3>
          <div class="profiles-list" data-profiles-list>
            <!-- Profiles generated dynamically -->
          </div>
          
          <div class="add-profile-inline">
            <input type="text" id="inline-profile-name" placeholder="เพิ่มโปรไฟล์ใหม่..." maxlength="15" />
            <button type="button" data-inline-create-btn>เพิ่ม</button>
          </div>
        </section>
        
        <!-- Backup / Restore -->
        <section class="settings-section border-top">
          <h3>💾 ระบบสำรองและกู้คืนข้อมูล</h3>
          <p class="section-desc">
            คัดลอกรหัสสำรองข้อมูลเก็บไว้ เพื่อป้องกันความคืบหน้าการอ่านสูญหายหากเบราว์เซอร์ล้างข้อมูลแคช
          </p>
          
          <div class="backup-group">
            <label>รหัสสำรองข้อมูลของคุณ (Copy ไปเก็บไว้)</label>
            <textarea id="backup-code-text" readonly onclick="this.select()"></textarea>
            <button type="button" class="btn-copy" data-copy-backup-btn>คัดลอกรหัส</button>
          </div>
          
          <div class="restore-group">
            <label for="restore-code-input">วางรหัสเพื่อกู้คืนข้อมูลที่นี่</label>
            <div class="restore-input-row">
              <input type="text" id="restore-code-input" placeholder="วางรหัสกู้คืนที่นี่..." />
              <button type="button" class="btn-restore" data-restore-btn>กู้คืน</button>
            </div>
            <p class="restore-error" data-restore-error style="display: none; color: #ff6b6b; font-size: 0.85rem; margin-top: 0.4rem;"></p>
          </div>
        </section>
      </div>
    </div>
  </div>
</HubLayout>

<style>
  /* Profile Widget */
  .hub-side-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-end;
  }

  .hub-profile-widget {
    background: var(--hub-panel-strong);
    border: 1px solid var(--hub-line);
    border-radius: 6px;
    padding: 12px 16px;
    width: 100%;
    max-width: 260px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    box-sizing: border-box;
  }

  .hub-profile-info {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.95rem;
  }

  .profile-icon {
    font-size: 1.1rem;
  }

  .profile-name {
    font-weight: 500;
    color: var(--hub-ink);
  }

  .hub-profile-settings-btn {
    background: none;
    border: 1px solid var(--hub-line);
    color: var(--hub-muted);
    font-size: 0.8rem;
    padding: 6px 10px;
    border-radius: 4px;
    cursor: pointer;
    text-align: center;
    transition: background 0.2s, color 0.2s;
  }

  .hub-profile-settings-btn:hover {
    background: rgba(238, 232, 221, 0.05);
    color: var(--hub-ink);
  }

  /* Modal Overlay */
  .hub-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(10, 9, 8, 0.85);
    backdrop-filter: blur(12px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    animation: fadeIn 0.25s ease-out;
  }

  .hub-modal-card {
    background: var(--hub-panel-strong);
    border: 1px solid var(--hub-line);
    border-radius: 8px;
    width: 100%;
    max-width: 480px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
    overflow: hidden;
    animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .modal-header {
    padding: 20px 24px;
    border-bottom: 1px solid var(--hub-line);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .modal-header h2 {
    margin: 0;
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--hub-ink);
    font-family: var(--font-display);
  }

  .modal-close-btn {
    background: none;
    border: none;
    color: var(--hub-muted);
    font-size: 1.5rem;
    cursor: pointer;
    line-height: 1;
    padding: 4px;
  }

  .modal-close-btn:hover {
    color: var(--hub-ink);
  }

  .modal-body {
    padding: 24px;
  }

  .modal-desc {
    color: var(--hub-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0 0 20px;
  }

  .modal-form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .modal-form-group label {
    font-size: 0.85rem;
    color: var(--hub-muted);
  }

  .modal-input-row {
    display: flex;
    gap: 8px;
  }

  .modal-input-row input,
  .restore-input-row input,
  .add-profile-inline input {
    flex: 1;
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid var(--hub-line);
    color: var(--hub-ink);
    padding: 8px 12px;
    border-radius: 4px;
    font-size: 0.95rem;
  }

  .btn-primary {
    background: var(--hub-accent);
    color: var(--paper-deep);
    border: none;
    padding: 8px 16px;
    border-radius: 4px;
    font-weight: 500;
    cursor: pointer;
    font-size: 0.95rem;
    transition: opacity 0.2s;
  }

  .btn-primary:hover {
    opacity: 0.9;
  }

  .modal-divider {
    display: flex;
    align-items: center;
    text-align: center;
    color: var(--hub-faint);
    margin: 20px 0;
    font-size: 0.85rem;
  }

  .modal-divider::before,
  .modal-divider::after {
    content: '';
    flex: 1;
    border-bottom: 1px solid var(--hub-line);
  }

  .modal-divider span {
    padding: 0 10px;
  }

  .btn-secondary {
    background: none;
    border: 1px solid var(--hub-line);
    color: var(--hub-ink);
    padding: 10px 16px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.95rem;
    transition: background 0.2s;
  }

  .btn-secondary:hover {
    background: rgba(238, 232, 221, 0.05);
  }

  .btn-full {
    width: 100%;
  }

  /* Settings Card specific */
  .settings-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
  }

  .settings-section h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 500;
    color: var(--hub-ink);
  }

  .border-top {
    border-top: 1px solid var(--hub-line);
    padding-top: 20px;
  }

  .profiles-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-height: 160px;
    overflow-y: auto;
  }

  .profile-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(0, 0, 0, 0.15);
    border: 1px solid var(--hub-line);
    border-radius: 4px;
    padding: 8px 12px;
  }

  .profile-item-info {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.95rem;
  }

  .profile-item.is-active {
    border-color: var(--hub-accent);
    background: color-mix(in srgb, var(--hub-accent) 8%, transparent);
  }

  .profile-item.is-active::after {
    content: '✓';
    color: var(--hub-accent);
    font-weight: bold;
    font-size: 0.95rem;
  }

  .profile-item-actions {
    display: flex;
    gap: 8px;
  }

  .btn-switch, .btn-delete-profile {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.85rem;
    padding: 4px 8px;
    border-radius: 2px;
  }

  .btn-switch {
    color: var(--hub-accent);
  }

  .btn-delete-profile {
    color: #ff6b6b;
  }

  .add-profile-inline {
    display: flex;
    gap: 8px;
    margin-top: 4px;
  }

  .add-profile-inline button {
    background: none;
    border: 1px solid var(--hub-line);
    color: var(--hub-ink);
    padding: 6px 12px;
    border-radius: 4px;
    cursor: pointer;
  }

  .section-desc {
    font-size: 0.85rem;
    color: var(--hub-muted);
    margin: 0;
  }

  .backup-group, .restore-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 8px;
  }

  .backup-group label, .restore-group label {
    font-size: 0.8rem;
    color: var(--hub-muted);
  }

  .backup-group textarea {
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid var(--hub-line);
    color: var(--hub-muted);
    border-radius: 4px;
    padding: 8px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    height: 60px;
    resize: none;
    word-break: break-all;
  }

  .btn-copy, .btn-restore {
    background: none;
    border: 1px solid var(--hub-line);
    color: var(--hub-ink);
    padding: 6px 12px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.85rem;
    text-align: center;
  }

  .restore-input-row {
    display: flex;
    gap: 8px;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideUp {
    from { transform: translateY(16px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  @media (max-width: 780px) {
    .hub-side-col {
      align-items: stretch;
    }
    .hub-profile-widget {
      max-width: none;
    }
  }
</style>

<script is:inline>
  (() => {
    const activeProfileNameEl = document.querySelector('[data-profile-name]');
    const profileWidget = document.querySelector('[data-profile-widget]');
    const welcomeModal = document.querySelector('[data-welcome-modal]');
    const settingsModal = document.querySelector('[data-settings-modal]');
    const settingsBtn = document.querySelector('[data-profile-settings-btn]');
    const settingsCloseBtn = document.querySelector('[data-settings-close-btn]');
    
    const PROFILES_KEY = "piichan-novels:profiles";
    const ACTIVE_KEY = "piichan-novels:active-profile-id";

    function getProfiles() {
      try {
        const raw = localStorage.getItem(PROFILES_KEY);
        return raw ? JSON.parse(raw) : [];
      } catch (e) {
        return [];
      }
    }

    function saveProfiles(profiles) {
      localStorage.setItem(PROFILES_KEY, JSON.stringify(profiles));
    }

    function getActiveProfileId() {
      return localStorage.getItem(ACTIVE_KEY);
    }

    function setActiveProfileId(id) {
      localStorage.setItem(ACTIVE_KEY, id);
    }

    const init = () => {
      const activeId = getActiveProfileId();
      const profiles = getProfiles();

      if (!activeId) {
        // Show welcome overlay
        welcomeModal.style.display = 'flex';
      } else {
        // Show profile bar
        const activeProfile = profiles.find(p => p.id === activeId) || { name: 'Guest (ผู้เข้าชม)', type: 'guest' };
        if (activeProfileNameEl) {
          activeProfileNameEl.textContent = activeProfile.name;
        }
        if (profileWidget) {
          profileWidget.style.display = 'flex';
        }
      }
    };

    // Welcome actions
    const createProfileBtn = document.querySelector('[data-create-profile-btn]');
    const guestProfileBtn = document.querySelector('[data-guest-profile-btn]');
    const newProfileNameInput = document.getElementById('new-profile-name');

    const createProfile = (name) => {
      const trimmed = name.trim();
      if (!trimmed) return;
      const id = 'p_' + Date.now() + '_' + Math.random().toString(36).substring(2, 11);
      const profiles = getProfiles();
      profiles.push({ id, name: trimmed, type: 'user', createdAt: Date.now() });
      saveProfiles(profiles);
      setActiveProfileId(id);
      welcomeModal.style.display = 'none';
      window.location.reload();
    };

    if (createProfileBtn && newProfileNameInput instanceof HTMLInputElement) {
      createProfileBtn.addEventListener('click', () => {
        createProfile(newProfileNameInput.value);
      });
      newProfileNameInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          createProfile(newProfileNameInput.value);
        }
      });
    }

    if (guestProfileBtn) {
      guestProfileBtn.addEventListener('click', () => {
        const profiles = getProfiles();
        if (!profiles.some(p => p.id === 'guest')) {
          profiles.push({ id: 'guest', name: 'Guest (ผู้เข้าชม)', type: 'guest', createdAt: Date.now() });
          saveProfiles(profiles);
        }
        setActiveProfileId('guest');
        welcomeModal.style.display = 'none';
        window.location.reload();
      });
    }

    // Settings actions
    if (settingsBtn) {
      settingsBtn.addEventListener('click', () => {
        settingsModal.style.display = 'flex';
        renderSettingsProfiles();
        generateBackup();
      });
    }

    if (settingsCloseBtn) {
      settingsCloseBtn.addEventListener('click', () => {
        settingsModal.style.display = 'none';
      });
    }

    // Close on clicking overlay
    [welcomeModal, settingsModal].forEach(modal => {
      if (modal) {
        modal.addEventListener('click', (e) => {
          if (e.target === modal && modal !== welcomeModal) {
            modal.style.display = 'none';
          }
        });
      }
    });

    const renderSettingsProfiles = () => {
      const listContainer = document.querySelector('[data-profiles-list]');
      if (!listContainer) return;
      listContainer.innerHTML = '';

      const profiles = getProfiles();
      const activeId = getActiveProfileId();

      profiles.forEach(p => {
        const item = document.createElement('div');
        item.className = 'profile-item' + (p.id === activeId ? ' is-active' : '');
        
        const info = document.createElement('div');
        info.className = 'profile-item-info';
        info.innerHTML = `<span>${p.type === 'guest' ? '👤' : '📖'}</span><strong>${p.name}</strong>`;
        item.appendChild(info);

        const actions = document.createElement('div');
        actions.className = 'profile-item-actions';

        if (p.id !== activeId) {
          const switchBtn = document.createElement('button');
          switchBtn.type = 'button';
          switchBtn.className = 'btn-switch';
          switchBtn.textContent = 'ใช้งาน';
          switchBtn.addEventListener('click', () => {
            setActiveProfileId(p.id);
            window.location.reload();
          });
          actions.appendChild(switchBtn);

          if (p.id !== 'guest') {
            const deleteBtn = document.createElement('button');
            deleteBtn.type = 'button';
            deleteBtn.className = 'btn-delete-profile';
            deleteBtn.textContent = 'ลบ';
            deleteBtn.addEventListener('click', () => {
              if (confirm(`คุณแน่ใจหรือไม่ที่จะลบโปรไฟล์ "${p.name}"? ประวัติการอ่านของโปรไฟล์นี้ทั้งหมดจะหายไปถาวร`)) {
                const prefixes = [
                  "hvitveldt:reading:",
                  "tsukinomi:reading:",
                  "hvitveldt:secret:",
                  "tsukinomi:reading:secret:",
                  "hvitveldt:extra-bypassed",
                  "tsukinomi:extra-bypassed"
                ];
                prefixes.forEach(prefix => {
                  localStorage.removeItem(`${prefix}:${p.id}`);
                });
                
                const updated = getProfiles().filter(profile => profile.id !== p.id);
                saveProfiles(updated);
                renderSettingsProfiles();
              }
            });
            actions.appendChild(deleteBtn);
          }
        }

        item.appendChild(actions);
        listContainer.appendChild(item);
      });
    };

    const inlineCreateBtn = document.querySelector('[data-inline-create-btn]');
    const inlineInput = document.getElementById('inline-profile-name');
    if (inlineCreateBtn && inlineInput instanceof HTMLInputElement) {
      const addInline = () => {
        const val = inlineInput.value.trim();
        if (!val) return;
        const id = 'p_' + Date.now() + '_' + Math.random().toString(36).substring(2, 11);
        const profiles = getProfiles();
        profiles.push({ id, name: val, type: 'user', createdAt: Date.now() });
        saveProfiles(profiles);
        inlineInput.value = '';
        renderSettingsProfiles();
      };
      inlineCreateBtn.addEventListener('click', addInline);
      inlineInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') addInline();
      });
    }

    // Backup & Restore
    const generateBackup = () => {
      const text = document.getElementById('backup-code-text');
      if (!(text instanceof HTMLTextAreaElement)) return;

      try {
        const data = {};
        for (let i = 0; i < localStorage.length; i++) {
          const key = localStorage.key(i);
          if (
            key.startsWith("piichan-novels:") || 
            key.startsWith("hvitveldt:") || 
            key.startsWith("tsukinomi:")
          ) {
            data[key] = localStorage.getItem(key);
          }
        }
        const json = JSON.stringify(data);
        const base64 = btoa(encodeURIComponent(json).replace(/%([0-9A-F]{2})/g, (_, p1) => {
          return String.fromCharCode(parseInt(p1, 16));
        }));
        text.value = base64;
      } catch (e) {
        text.value = 'ไม่สามารถสร้างรหัสสำรองข้อมูลได้';
      }
    };

    const copyBackupBtn = document.querySelector('[data-copy-backup-btn]');
    if (copyBackupBtn) {
      copyBackupBtn.addEventListener('click', () => {
        const text = document.getElementById('backup-code-text');
        if (text instanceof HTMLTextAreaElement) {
          text.select();
          navigator.clipboard.writeText(text.value).then(() => {
            const old = copyBackupBtn.textContent;
            copyBackupBtn.textContent = 'คัดลอกสำเร็จแล้ว!';
            setTimeout(() => {
              copyBackupBtn.textContent = old;
            }, 2000);
          });
        }
      });
    }

    const restoreBtn = document.querySelector('[data-restore-btn]');
    const restoreInput = document.getElementById('restore-code-input');
    const restoreError = document.querySelector('[data-restore-error]');

    if (restoreBtn && restoreInput instanceof HTMLInputElement) {
      restoreBtn.addEventListener('click', () => {
        const code = restoreInput.value.trim();
        if (!code) return;
        
        try {
          const json = decodeURIComponent(Array.prototype.map.call(atob(code), (c) => {
            return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
          }).join(''));
          const data = JSON.parse(json);
          
          for (let i = localStorage.length - 1; i >= 0; i--) {
            const key = localStorage.key(i);
            if (
              key.startsWith("piichan-novels:") || 
              key.startsWith("hvitveldt:") || 
              key.startsWith("tsukinomi:")
            ) {
              localStorage.removeItem(key);
            }
          }

          for (const key in data) {
            localStorage.setItem(key, data[key]);
          }

          if (restoreError instanceof HTMLElement) {
            restoreError.style.display = 'none';
          }
          alert('กู้คืนข้อมูลสำเร็จ! หน้าเว็บจะเริ่มต้นใหม่');
          window.location.reload();
        } catch (e) {
          if (restoreError instanceof HTMLElement) {
            restoreError.textContent = 'รหัสกู้คืนไม่ถูกต้องหรือข้อมูลชำรุด';
            restoreError.style.display = 'block';
          }
        }
      });
    }

    init();
    document.addEventListener('astro:page-load', init);
  })();
</script>

