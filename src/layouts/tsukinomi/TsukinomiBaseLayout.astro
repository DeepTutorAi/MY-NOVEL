---
import { ClientRouter } from "astro:transitions";
import GrainOverlay from "../../components/_shared/GrainOverlay.astro";
import SakuraTwilightBackdrop from "../../components/tsukinomi/atmosphere/SakuraTwilightBackdrop.astro";
import WalkmanPlayer from "../../components/tsukinomi/audio/WalkmanPlayer.astro";
import TopBar from "../../components/tsukinomi/navigation/TopBar.astro";
import WalkmanCorner from "../../components/tsukinomi/reading/WalkmanCorner.astro";
import {
  HOME_BACKGROUND_SLOT,
  getTsukinomiBackgroundSlot,
  type TsukinomiBackgroundSlotId,
} from "../../data/tsukinomi/background-slots";
import "../../styles/tsukinomi/global.css";
import { withBase } from "../../utils/base-path";

interface Props {
  title: string;
  description: string;
  bodyClass?: string;
  sectionPalette?: string;
  musicCueId?: string;
  backgroundSlotId?: TsukinomiBackgroundSlotId;
  showTopBar?: boolean;
  ogImage?: string;
}

const {
  title,
  description,
  bodyClass,
  sectionPalette = "",
  musicCueId = "",
  backgroundSlotId = HOME_BACKGROUND_SLOT.id,
  showTopBar = true,
  ogImage = "/og.jpg",
} = Astro.props;
const canonical = Astro.url.href;
const resolvedOgImage = new URL(withBase(ogImage), Astro.site ?? Astro.url).href;
const faviconLit = withBase("/favicon.svg");
const faviconPng = withBase("/favicon.png");
const bodyClasses = ["tsukinomi-page", "tsukinomi-shell", showTopBar ? "has-tsukinomi-topbar" : "", bodyClass]
  .filter(Boolean)
  .join(" ");
const backgroundSlot = getTsukinomiBackgroundSlot(backgroundSlotId);
const backgroundStatus = backgroundSlot.status;
const imageBase = backgroundSlot.expectedImageBase;
const bgImage =
  backgroundSlot.status === "ready"
    ? `image-set(` +
      `url("${withBase(`${imageBase}.avif`)}") type("image/avif"), ` +
      `url("${withBase(`${imageBase}.webp`)}") type("image/webp"), ` +
      `url("${withBase(`${imageBase}.jpg`)}"))`
    : "none";
const backgroundStyle = bgImage === "none" ? undefined : `--bg-image: ${bgImage};`;
---

<!doctype html>
<html lang="th">
  <head>
    <script is:inline>
      (function() {
        if (window.__localStorageIntercepted) return;
        window.__localStorageIntercepted = true;

        const originalGet = localStorage.getItem;
        const originalSet = localStorage.setItem;
        const originalRemove = localStorage.removeItem;

        function getActiveProfileId() {
          try {
            return originalGet.call(localStorage, "piichan-novels:active-profile-id") || "guest";
          } catch(e) {
            return "guest";
          }
        }

        function getProfileKey(key) {
          if (typeof key !== 'string') return key;
          const prefixes = [
            "hvitveldt:reading:",
            "tsukinomi:reading:",
            "hvitveldt:secret:",
            "tsukinomi:reading:secret:",
            "hvitveldt:extra-bypassed",
            "tsukinomi:extra-bypassed"
          ];
          if (prefixes.some(p => key.startsWith(p))) {
            const activeProfile = getActiveProfileId();
            return `${key}:${activeProfile}`;
          }
          return key;
        }

        localStorage.getItem = function(key) {
          return originalGet.call(localStorage, getProfileKey(key));
        };
        localStorage.setItem = function(key, value) {
          originalSet.call(localStorage, getProfileKey(key), value);
        };
        localStorage.removeItem = function(key) {
          originalRemove.call(localStorage, getProfileKey(key));
        };
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0E0B1E" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={faviconLit} type="image/svg+xml" />
    <link rel="icon" href={faviconPng} type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href={faviconPng} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <ClientRouter />
  </head>
  <body
    class={bodyClasses}
    style={backgroundStyle}
    data-theme="sakura-twilight"
    data-section={sectionPalette}
    data-palette={sectionPalette}
    data-music-cue={musicCueId}
    data-background-slot={backgroundSlotId}
    data-background-status={backgroundStatus}
    data-background-expected={backgroundSlot.expectedImageBase}
  >
    <script is:inline>
      (function() {
        const parts = ["7a1c", "d5bf", "758e", "bf3d", "42bd", "bf81", "706a", "d55c", "2f7d", "c9a1", "da1e", "27ab", "bcae", "f433", "f167", "8968"];
        const h1 = parts.join("");
        const key = "tsukinomi:extra-bypassed";
        
        let isProgressMet = false;
        try {
          const raw = localStorage.getItem("tsukinomi:reading:secret:reads");
          const arr = raw ? JSON.parse(raw) : [];
          if (Array.isArray(arr)) {
            isProgressMet = arr.filter(id => id !== "00-introduction").length >= 4;
          }
        } catch(e) {}
        
        let isLodgeUnlocked = false;
        try {
          const lodgeBypassH1 = localStorage.getItem("hvitveldt:extra-bypassed");
          // Obfuscated Lodge H1 check to run synchronously
          // Lodge H1: c14cbee5949dbd6b00df5b3e7893764cba713534db902dac0fa66369a78890bf
          const lodgeH1Parts = ["c14c", "bee5", "949d", "bd6b", "00df", "5b3e", "7893", "764c", "ba71", "3534", "db90", "2dac", "0fa6", "6369", "a788", "90bf"];
          if (lodgeBypassH1 === lodgeH1Parts.join("")) {
            isLodgeUnlocked = true;
          }
          
          const rawLodge = localStorage.getItem("hvitveldt:secret:reads");
          const arrLodge = rawLodge ? JSON.parse(rawLodge) : [];
          if (Array.isArray(arrLodge)) {
            const lodgeReads = arrLodge.filter(id => id !== "00-introduction").length;
            if (lodgeReads >= 15) {
              isLodgeUnlocked = true;
            }
          }
        } catch(e) {}
        
        const isUnlocked = localStorage.getItem(key) === h1 || isProgressMet || isLodgeUnlocked;
        const rawPath = window.location.pathname.replace(/\/+$/, "/");
        const appPath = rawPath.startsWith("/MY-NOVEL/") ? rawPath.slice("/MY-NOVEL".length) : rawPath;
        const PUBLIC_TSUKINOMI_PATHS = ["/tsukinomi/", "/tsukinomi/sections/", "/tsukinomi/characters/", "/tsukinomi/extra/"];
        const isPublicTsukinomiPath = PUBLIC_TSUKINOMI_PATHS.includes(appPath);
        const pathParts = appPath.split("/").filter(Boolean);
        const requiresTsukinomiUnlock =
          appPath.startsWith("/tsukinomi/sections/") && !isPublicTsukinomiPath && pathParts.length >= 3;
        
        if (!isUnlocked && requiresTsukinomiUnlock) {
          let target = "/";
          if (window.location.pathname.startsWith("/MY-NOVEL/")) {
            target = "/MY-NOVEL/";
          }
          window.location.replace(target);
          return;
        }

        function setTimeOfDay(hour) {
          let tod = 'evening';
          if (hour >= 6 && hour < 13) {
            tod = 'morning';
          } else if (hour >= 13 && hour < 19) {
            tod = 'afternoon';
          } else if (hour >= 19 || hour < 1) {
            tod = 'evening';
          } else {
            tod = 'night';
          }
          document.body.setAttribute('data-time-of-day', tod);
          window.__currentTimeOfDay = tod;
        }

        const localHour = new Date().getHours();
        setTimeOfDay(localHour);

        fetch('https://worldtimeapi.org/api/ip')
          .then(res => res.json())
          .then(data => {
            if (data && typeof data.datetime === 'string') {
              const tIndex = data.datetime.indexOf('T');
              if (tIndex !== -1) {
                const hourStr = data.datetime.substring(tIndex + 1, tIndex + 3);
                const hour = parseInt(hourStr, 10);
                if (!isNaN(hour)) {
                  setTimeOfDay(hour);
                }
              }
            }
          })
          .catch(err => {
            console.warn('IP-based time fetch failed, using local device time.', err);
          });

        if (!window.__timeOfDayBound) {
          window.__timeOfDayBound = true;
          document.addEventListener('astro:after-swap', () => {
            const currentTod = window.__currentTimeOfDay || 'evening';
            document.body.setAttribute('data-time-of-day', currentTod);
          });
        }
      })();
    </script>
    <a class="skip-to-content" href="#tsukinomi-main">ข้ามไปยังเนื้อหา</a>
    <SakuraTwilightBackdrop />
    <GrainOverlay texture="/assets/tsukinomi/textures/film-grain.png" />
    <WalkmanCorner />
    <WalkmanPlayer />
    {showTopBar && <TopBar />}
    <slot />
  </body>
</html>
