---
import { withBase } from "../../utils/base-path";

interface Props {
  texture?: string;
}

const { texture = "/assets/_shared/grain.png" } = Astro.props;
const grainImage = withBase(texture);
---

<div class="grain-overlay" aria-hidden="true" style={`--grain-image: url("${grainImage}")`}></div>

<style>
  .grain-overlay {
    position: fixed;
    inset: 0;
    z-index: 4;
    background-image: var(--grain-image);
    background-repeat: repeat;
    opacity: 0.035;
    mix-blend-mode: overlay;
    pointer-events: none;
  }
</style>
