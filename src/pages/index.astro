---
import { withBase } from "../utils/base-path";

const lodgeHref = withBase("/lodge/");
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0; url=${lodgeHref}`} />
    <title>กำลังพาไปฮวิตเวลต์ ลอดจ์</title>
    <link rel="canonical" href={lodgeHref} />
  </head>
  <body>
    <p>กำลังพาไป <a href={lodgeHref}>ฮวิตเวลต์ ลอดจ์</a></p>
  </body>
</html>
