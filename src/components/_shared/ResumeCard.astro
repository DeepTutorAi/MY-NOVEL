---
import { getCollection } from "astro:content";
import { withBase } from "../../utils/base-path";

const lodgeChapterBase = withBase("/lodge/chapters/");
const tsukinomiSectionBase = withBase("/tsukinomi/sections/");

const lodgeUnits = (await getCollection("chapters"))
  .sort((a, b) => a.data.number - b.data.number)
  .map((chapter) => ({ id: chapter.id, number: chapter.data.number, title: chapter.data.title }));
const tsukinomiUnits = (await getCollection("tsukinomiSections"))
  .sort((a, b) => a.data.number - b.data.number)
  .map((section) => ({ id: section.id, number: section.data.number, title: section.data.title }));
---

<section class="resume-card" data-hub-resume hidden aria-live="polite">
  <div class="resume-card-copy">
    <span class="resume-card-kicker" data-resume-novel></span>
    <h2>อ่านต่อจากครั้งล่าสุด</h2>
    <p data-resume-title></p>
    <small data-resume-detail></small>
  </div>
  <div class="resume-card-actions">
    <a data-resume-link href={withBase("/")}>อ่านต่อ</a>
    <button type="button" data-resume-clear>ล้าง</button>
  </div>
</section>

<script
  is:inline
  define:vars={{ lodgeChapterBase, tsukinomiSectionBase, lodgeUnits, tsukinomiUnits }}
>
  (async () => {
    const card = document.querySelector("[data-hub-resume]");
    const novelLabel = document.querySelector("[data-resume-novel]");
    const title = document.querySelector("[data-resume-title]");
    const detail = document.querySelector("[data-resume-detail]");
    const link = document.querySelector("[data-resume-link]");
    const clear = document.querySelector("[data-resume-clear]");

    if (
      !(card instanceof HTMLElement) ||
      !(novelLabel instanceof HTMLElement) ||
      !(title instanceof HTMLElement) ||
      !(detail instanceof HTMLElement) ||
      !(link instanceof HTMLAnchorElement) ||
      !(clear instanceof HTMLButtonElement)
    ) {
      return;
    }

    const COMPLETED_PROGRESS = 0.995;
    const percentText = (progress) => `${Math.max(1, Math.min(99, Math.round(progress * 100)))}%`;

    const readJson = (key) => {
      try {
        const raw = localStorage.getItem(key);
        return raw ? JSON.parse(raw) : null;
      } catch {
        return null;
      }
    };

    const normalize = (config) => {
      const saved = readJson(config.storageKey);
      const progress = Number(saved?.progress);
      const id = config.getId(saved);
      const number = config.getNumber(saved);
      const chapterTitle = config.getTitle(saved);
      const updatedAt = Number(saved?.updatedAt);

      if (!id || !number || !chapterTitle || !Number.isFinite(progress) || progress < 0.005) {
        return null;
      }

      const index = config.units.findIndex((unit) => String(unit.id) === String(id));
      const next = index >= 0 ? config.units[index + 1] : null;

      return {
        storageKey: config.storageKey,
        detailKey: `${config.detailPrefix}${id}`,
        novelTitle: config.novelTitle,
        unitLabel: config.unitLabel,
        title: `${config.unitLabel} ${number}: ${chapterTitle}`,
        progress,
        completed: progress >= COMPLETED_PROGRESS,
        resumeHref: `${config.baseHref}${id}/?resume=1`,
        nextHref: next ? `${config.baseHref}${next.id}/` : "",
        nextLabel: next ? `${config.unitLabel} ${next.number}: ${next.title}` : "",
        tocHref: config.baseHref,
        updatedAt: Number.isFinite(updatedAt) ? updatedAt : 0,
      };
    };

    // SHA-256 helper
    async function sha256(message) {
      const msgBuffer = new TextEncoder().encode(message);
      const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);
      const hashArray = Array.from(new Uint8Array(hashBuffer));
      return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
    }

    const getSecretReadsCount = () => {
      try {
        const raw = localStorage.getItem("tsukinomi:reading:secret:reads");
        const arr = raw ? JSON.parse(raw) : [];
        if (Array.isArray(arr)) {
          return arr.filter(id => id !== "00-introduction").length;
        }
        return 0;
      } catch {
        return 0;
      }
    };

    const getLodgeReadsCount = () => {
      try {
        const raw = localStorage.getItem("hvitveldt:secret:reads");
        const arr = raw ? JSON.parse(raw) : [];
        if (Array.isArray(arr)) {
          return arr.filter(id => id !== "00-introduction").length;
        }
        return 0;
      } catch {
        return 0;
      }
    };

    const isTsukinomiUnlocked = async () => {
      const storedH1 = localStorage.getItem("tsukinomi:extra-bypassed");
      if (storedH1) {
        const calculatedH2 = await sha256(storedH1);
        if (calculatedH2 === "ef8fa25c0397c32aa53ef84fd328412eb170e33ad8b0a6c62cd0f67f4f604f18") {
          return true;
        }
      }
      if (getSecretReadsCount() >= 4) {
        return true;
      }
      // Lodge extra check
      const lodgeBypassH1 = localStorage.getItem("hvitveldt:extra-bypassed");
      if (lodgeBypassH1) {
        const calculatedLodgeH2 = await sha256(lodgeBypassH1);
        if (calculatedLodgeH2 === "6d4829eebb416434779797994fa3b4324fcf1b3eb2392c99b0c6599313b8dad7") {
          return true;
        }
      }
      return getLodgeReadsCount() >= 15;
    };

    const isUnlocked = await isTsukinomiUnlocked();

    const candidates = [
      normalize({
        storageKey: "hvitveldt:reading:last",
        detailPrefix: "hvitveldt:reading:chapter:",
        baseHref: lodgeChapterBase,
        novelTitle: "ฮวิตเวลต์ ลอดจ์",
        unitLabel: "บทที่",
        units: lodgeUnits,
        getId: (saved) => (typeof saved?.chapterId === "string" ? saved.chapterId : ""),
        getNumber: (saved) => `${saved?.chapterNumber ?? ""}`.trim(),
        getTitle: (saved) => (typeof saved?.chapterTitle === "string" ? saved.chapterTitle.trim() : ""),
      }),
      normalize({
        storageKey: "tsukinomi:reading:last",
        detailPrefix: "tsukinomi:reading:section:",
        baseHref: tsukinomiSectionBase,
        novelTitle: "สถานีทะเลพระจันทร์",
        unitLabel: "ภาคที่",
        units: tsukinomiUnits,
        getId: (saved) =>
          typeof saved?.sectionId === "string"
            ? saved.sectionId
            : typeof saved?.chapterId === "string"
              ? saved.chapterId
              : "",
        getNumber: (saved) => `${saved?.sectionNumber ?? saved?.chapterNumber ?? ""}`.trim(),
        getTitle: (saved) =>
          typeof saved?.sectionTitle === "string"
            ? saved.sectionTitle.trim()
            : typeof saved?.chapterTitle === "string"
              ? saved.chapterTitle.trim()
              : "",
      }),
    ].filter(Boolean).filter((candidate) => {
      if (candidate.novelTitle === "สถานีทะเลพระจันทร์") {
        return isUnlocked;
      }
      return true;
    });

    const saved = candidates.sort((a, b) => b.updatedAt - a.updatedAt)[0];

    if (!saved) {
      card.hidden = true;
      return;
    }

    novelLabel.textContent = saved.novelTitle;
    title.textContent = saved.title;

    if (saved.completed) {
      // A finished chapter/section keeps its place at 100% and points the
      // reader at the next unit instead of disappearing.
      if (saved.nextHref) {
        detail.textContent = `อ่านจบ 100% · ไปต่อ ${saved.nextLabel}`;
        link.href = saved.nextHref;
        link.textContent = "อ่านต่อบทถัดไป";
      } else {
        detail.textContent = "อ่านจบเรื่องแล้ว";
        link.href = saved.tocHref;
        link.textContent = "กลับสารบัญ";
      }
    } else {
      detail.textContent = `ค้างไว้ประมาณ ${percentText(saved.progress)}`;
      link.href = saved.resumeHref;
      link.textContent = "อ่านต่อ";
    }
    card.hidden = false;

    clear.addEventListener("click", () => {
      try {
        localStorage.removeItem(saved.detailKey);
        localStorage.removeItem(saved.storageKey);
      } finally {
        card.hidden = true;
      }
    });
  })();
</script>
