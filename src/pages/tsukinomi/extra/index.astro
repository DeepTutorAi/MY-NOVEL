---
import TsukinomiBaseLayout from "../../../layouts/tsukinomi/TsukinomiBaseLayout.astro";
---

<TsukinomiBaseLayout
  title="ส่วนเสริม — สถานีทะเลพระจันทร์"
  description="เบื้องหลัง ภาพประกอบ และของแถมของสถานีทะเลพระจันทร์"
  bodyClass="tsukinomi-extra-page section-home palette-autumn"
  sectionPalette="autumn"
  backgroundSlotId="hero-station"
>
  <main id="tsukinomi-main" class="tsuki-extra">
    <!-- LOCKED GATE -->
    <section class="tsuki-extra-gate" data-extra-gate>
      <div class="gate-card">
        <div class="lock-icon">🌸</div>
        <h2>ความทรงจำที่ยังไม่พร้อมเปิดเผย</h2>
        <p class="gate-desc">
          พื้นที่พิเศษนี้เปิดให้เฉพาะผู้อ่านที่ใช้เวลาซึมซับเนื้อเรื่องอย่างลึกซึ้ง (อย่างน้อย 80% หรือ 4 ภาคจากทั้งหมด 5 ภาค โดยใช้เวลารับฟังและอ่านอย่างน้อยภาคละ 18 นาที)
        </p>
        
        <div class="progress-bar-container">
          <div class="progress-label">ความคืบหน้าการซึมซับแบบลับของคุณ</div>
          <div class="progress-track">
            <div class="progress-fill" data-progress-fill style="width: 0%"></div>
          </div>
          <div class="progress-status" data-progress-status>0 / 5 ภาค (0%)</div>
        </div>

        <div class="bypass-form">
          <label for="bypass-password">สิทธิ์เข้าถึงของทีมงาน (Developer Bypass)</label>
          <div class="bypass-input-group">
            <input
              type="password"
              id="bypass-password"
              placeholder="กรอกรหัสผ่านเพื่อเรียกคืนความทรงจำ..."
              data-bypass-input
            />
            <button type="button" data-bypass-btn>ปลดล็อค</button>
          </div>
          <p class="bypass-error" data-bypass-error hidden>รหัสผ่านไม่ถูกต้อง</p>
        </div>
      </div>
    </section>

    <!-- UNLOCKED PREMIUM CONTENT -->
    <article class="tsuki-extra-content" data-extra-content hidden>
      <p class="tsukinomi-kicker">Premium Extra</p>
      <h1>เบื้องหลังสถานีทะเลพระจันทร์</h1>
      <p class="tsuki-extra-lead">
        ยินดีต้อนรับสู่ส่วนบันทึกข้อมูลพิเศษสำหรับผู้ติดตามที่ซึมซับเรื่องราวของ สถานีทะเลพระจันทร์
      </p>

      <div class="extra-grid">
        <section class="extra-card">
          <h2>🌸 แนวคิดและความเหงาของสองฝั่งเวลา</h2>
          <p>
            สถานีทะเลพระจันทร์ มุ่งเน้นการสร้างสภาวะอารมณ์สงบนิ่งแต่อ้างว้าง (Mono-no-aware) การผสมผสานของธีมย้อนยุคอย่างเครื่องเล่นเทป Walkman และจังหวะชีวิตที่ดำเนินไปอย่างช้า ๆ ในสถานีรถไฟชนบทของญี่ปุ่น ช่วยสะท้อนให้เห็นถึงเวลาที่ไหลผ่านตัวละครไปอย่างไม่มีวันกลับ
          </p>
        </section>

        <section class="extra-card">
          <h2>🎶 รายการเพลงในม้วนเทป Walkman</h2>
          <table class="audio-ledger-table">
            <thead>
              <tr>
                <th>ภาค</th>
                <th>ธีมดนตรี</th>
                <th>อารมณ์เพลง (Mood & Tone)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>ภาค 1: การค้นพบ (Discovery)</td>
                <td>Quiet Solitude</td>
                <td>เสียงเปียโนเดี่ยว เบาบาง อบอุ่นผสมผสานความเหงา</td>
              </tr>
              <tr>
                <td>ภาค 2: การเปิดเผย (Reveal)</td>
                <td>Distant Twilight</td>
                <td>แอมเบียนต์ล่องลอยสะท้อนภาพอาทิตย์ตกดิน</td>
              </tr>
              <tr>
                <td>ภาค 3: การตัดสินใจ (Decision)</td>
                <td>Rainy Nostalgia</td>
                <td>เสียงเปียโนคลอซาวด์เอฟเฟกต์เม็ดฝนตกกระทบหลังคา</td>
              </tr>
              <tr>
                <td>ภาค 4: ภูเขาแสนไกล (Mountain)</td>
                <td>Wind in Pines</td>
                <td>แอมเบียนต์หม่น ทุ้มต่ำ สะท้อนถึงการเดินทางยาวไกล</td>
              </tr>
              <tr>
                <td>ภาค 5: สิบปีถัดมา (Ten Years)</td>
                <td>Unresolved Ending</td>
                <td>ท่วงทำนองที่ไม่จบลงตัว ทิ้งความทรงจำที่ละมุนละไม</td>
              </tr>
            </tbody>
          </table>
        </section>

        <section class="extra-card">
          <h2>✉️ บันทึกจากผู้ประพันธ์</h2>
          <blockquote class="tsuki-quote">
            "บางครั้งการรอคอยที่ยาวนาน ไม่ใช่เพื่อรอให้ใครบางคนกลับมา แต่เพื่อรอให้ตัวเราเองเข้าใจความหมายของการจากลา... ขอบคุณที่ร่วมเดินทางมากับพวกเราที่สถานีรถไฟแห่งนี้"
          </blockquote>
        </section>
      </div>
    </article>
  </main>

  <script>
    const gate = document.querySelector("[data-extra-gate]");
    const content = document.querySelector("[data-extra-content]");
    const fill = document.querySelector("[data-progress-fill]");
    const status = document.querySelector("[data-progress-status]");
    const passwordInput = document.querySelector("[data-bypass-input]");
    const bypassBtn = document.querySelector("[data-bypass-btn]");
    const bypassError = document.querySelector("[data-bypass-error]");

    const SECRET_READS_KEY = "tsukinomi:reading:secret:reads";
    const BYPASS_KEY = "tsukinomi:extra-bypassed";
    const BYPASS_PASSWORD = "tsukinomi-bypass-gate-2026";
    const TOTAL_SECTIONS = 5;
    const UNLOCK_THRESHOLD = 4; // 80% of 5 is 4 sections

    const getSecretReadsCount = (): number => {
      try {
        const raw = localStorage.getItem(SECRET_READS_KEY);
        const arr = raw ? JSON.parse(raw) : [];
        if (Array.isArray(arr)) {
          return arr.filter(id => id !== "00-introduction").length;
        }
        return 0;
      } catch {
        return 0;
      }
    };

    const checkUnlocked = (): boolean => {
      if (localStorage.getItem(BYPASS_KEY) === "true") {
        return true;
      }
      return getSecretReadsCount() >= UNLOCK_THRESHOLD;
    };

    const updateUI = () => {
      const readCount = getSecretReadsCount();
      const percent = Math.round((readCount / TOTAL_SECTIONS) * 100);

      if (fill instanceof HTMLElement) {
        fill.style.width = `${percent}%`;
      }
      if (status) {
        status.textContent = `${readCount} / ${TOTAL_SECTIONS} ภาค (${percent}%)`;
      }

      if (checkUnlocked()) {
        gate?.setAttribute("hidden", "");
        content?.removeAttribute("hidden");
      } else {
        gate?.removeAttribute("hidden");
        content?.setAttribute("hidden", "");
      }
    };

    const attemptBypass = () => {
      if (passwordInput instanceof HTMLInputElement) {
        if (passwordInput.value.trim() === BYPASS_PASSWORD) {
          localStorage.setItem(BYPASS_KEY, "true");
          bypassError?.setAttribute("hidden", "");
          updateUI();
        } else {
          bypassError?.removeAttribute("hidden");
        }
      }
    };

    if (bypassBtn) {
      bypassBtn.addEventListener("click", attemptBypass);
    }

    if (passwordInput instanceof HTMLInputElement) {
      passwordInput.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          attemptBypass();
        }
      });
    }

    // Initialize UI on load
    updateUI();
    document.addEventListener("astro:page-load", updateUI);
  </script>

  <style>
    .tsuki-extra {
      max-width: 50rem;
      margin: 0 auto;
      padding: calc(var(--tsuki-topbar-height) + 3rem) 1.25rem 5rem;
    }

    /* LOCKED GATE STYLING */
    .tsuki-extra-gate {
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 3rem 1rem;
    }

    .gate-card {
      background: var(--tsuki-surface);
      border: 1px solid var(--tsuki-line);
      border-radius: 8px;
      padding: 3rem 2rem;
      text-align: center;
      max-width: 32rem;
      width: 100%;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    }

    .lock-icon {
      font-size: 3rem;
      margin-bottom: 1rem;
    }

    .gate-card h2 {
      font-family: var(--font-display-tsukinomi);
      font-weight: 500;
      font-size: 1.5rem;
      margin-bottom: 1rem;
      color: var(--tsuki-ink);
    }

    .gate-desc {
      color: var(--tsuki-ink-dim);
      font-size: 0.95rem;
      line-height: 1.6;
      margin-bottom: 2rem;
    }

    .progress-bar-container {
      margin-bottom: 2.5rem;
      text-align: left;
    }

    .progress-label {
      font-size: 0.85rem;
      color: var(--tsuki-ink-dim);
      margin-bottom: 0.5rem;
    }

    .progress-track {
      background: rgba(0, 0, 0, 0.15);
      border: 1px solid var(--tsuki-line);
      border-radius: 4px;
      height: 10px;
      overflow: hidden;
      margin-bottom: 0.5rem;
    }

    .progress-fill {
      background: var(--tsuki-ink);
      height: 100%;
      transition: width 0.4s ease;
    }

    .progress-status {
      font-size: 0.85rem;
      text-align: right;
      font-family: var(--font-mono);
      color: var(--tsuki-ink-dim);
    }

    .bypass-form {
      border-top: 1px solid var(--tsuki-line);
      padding-top: 1.5rem;
      text-align: left;
    }

    .bypass-form label {
      display: block;
      font-size: 0.8rem;
      color: var(--tsuki-ink-dim);
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .bypass-input-group {
      display: flex;
      gap: 0.5rem;
    }

    .bypass-input-group input {
      flex: 1;
      background: rgba(0, 0, 0, 0.1);
      border: 1px solid var(--tsuki-line);
      border-radius: 4px;
      color: var(--tsuki-ink);
      padding: 0.6rem 0.8rem;
      font-size: 0.9rem;
    }

    .bypass-input-group button {
      background: var(--tsuki-ink);
      color: var(--tsuki-bg);
      border: none;
      border-radius: 4px;
      padding: 0.6rem 1.2rem;
      font-size: 0.9rem;
      cursor: pointer;
      font-weight: 500;
      transition: opacity 0.2s;
    }

    .bypass-input-group button:hover {
      opacity: 0.9;
    }

    .bypass-error {
      color: #d32f2f;
      font-size: 0.85rem;
      margin-top: 0.5rem;
    }

    /* CONTENT STYLING */
    .tsuki-extra-content {
      animation: fadeIn 0.6s ease forwards;
    }

    .tsukinomi-kicker {
      font-family: var(--font-mono);
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--tsuki-ink-dim);
      font-size: 0.74rem;
      text-align: center;
    }

    .tsuki-extra h1 {
      margin: 0.45rem 0 1rem;
      font-family: var(--font-display-tsukinomi);
      font-weight: 500;
      font-size: clamp(1.8rem, 5vw, 2.6rem);
      color: var(--tsuki-ink);
      text-align: center;
    }

    .tsuki-extra-lead {
      color: var(--tsuki-ink-dim);
      line-height: 1.8;
      text-align: center;
      margin-bottom: 3rem;
    }

    .extra-grid {
      display: grid;
      gap: 2rem;
    }

    .extra-card {
      background: var(--tsuki-surface);
      border: 1px solid var(--tsuki-line);
      border-radius: 6px;
      padding: 2rem;
      text-align: left;
    }

    .extra-card h2 {
      font-family: var(--font-display-tsukinomi);
      font-weight: 500;
      font-size: 1.25rem;
      color: var(--tsuki-ink);
      margin-bottom: 1rem;
      border-bottom: 1px solid var(--tsuki-line);
      padding-bottom: 0.5rem;
    }

    .extra-card p {
      color: var(--tsuki-ink-dim);
      line-height: 1.7;
    }

    blockquote.tsuki-quote {
      font-style: italic;
      color: var(--tsuki-ink);
      border-left: 3px solid var(--tsuki-ink);
      padding-left: 1.2rem;
      margin: 1rem 0;
    }

    .audio-ledger-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
      font-size: 0.9rem;
    }

    .audio-ledger-table th, .audio-ledger-table td {
      border: 1px solid var(--tsuki-line);
      padding: 0.75rem;
      text-align: left;
    }

    .audio-ledger-table th {
      background: rgba(0, 0, 0, 0.05);
      color: var(--tsuki-ink);
    }

    .audio-ledger-table td {
      color: var(--tsuki-ink-dim);
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</TsukinomiBaseLayout>
