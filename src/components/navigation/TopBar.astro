---
import AmbientPlayer from "../audio/AmbientPlayer.astro";
import TableOfContents from "./TableOfContents.astro";
import { withBase } from "../../utils/base-path";
---

<header class="topbar" data-visible="true">
  <a class="topbar-mark" href={withBase("/")} aria-label="Hvitveldt home">Hvitveldt</a>
  <nav class="topbar-actions" aria-label="Site">
    <TableOfContents />
    <AmbientPlayer />
  </nav>
</header>

<script>
  const topbar = document.querySelector(".topbar");

  if (topbar instanceof HTMLElement) {
    let lastY = window.scrollY;
    const observed = [
      ...Array.from(document.querySelectorAll("main, section, footer, .chapter-nav")),
      ...Array.from(document.querySelectorAll("article.chapter > p")).filter((_, index) => index % 8 === 0),
    ].filter((node): node is Element => node instanceof Element);

    const applyVisibility = () => {
      const currentY = window.scrollY;

      if (currentY < 80 || currentY < lastY) {
        topbar.dataset.visible = "true";
      } else if (currentY > 200 && currentY > lastY) {
        topbar.dataset.visible = "false";
      }

      lastY = currentY;
    };

    const observer = new IntersectionObserver(applyVisibility, {
      threshold: [0, 0.35, 1],
      rootMargin: "-10% 0px -55% 0px",
    });

    for (const node of observed) {
      observer.observe(node);
    }
  }
</script>

<style>
  .topbar {
    position: sticky;
    inset-block-start: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    block-size: var(--topbar-height);
    padding-inline: clamp(1rem, 3vw, 2rem);
    border-block-end: 1px solid oklch(from var(--ink) l c h / 0.06);
    background-color: oklch(from var(--paper) l c h / 0.7);
    backdrop-filter: blur(12px);
    transition: transform 180ms ease-out;
  }

  .topbar[data-visible="false"] {
    transform: translateY(-100%);
  }

  .topbar-mark {
    color: var(--ink-dim);
    font-family: var(--font-display);
    font-size: 1.1rem;
    line-height: 1;
    text-decoration: none;
  }

  .topbar-mark:hover {
    color: var(--ink);
  }

  .topbar-mark:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .topbar-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  @media (max-width: 640px) {
    .topbar {
      padding-inline: 0.85rem;
    }
  }
</style>
