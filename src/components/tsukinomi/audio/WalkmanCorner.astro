---
import { withBase } from "../../../utils/base-path";

const walkmanIcon = withBase("/assets/tsukinomi/icons/walkman.svg");
---

<div class="walkman-corner" aria-hidden="true">
  <img src={walkmanIcon} alt="" loading="eager" decoding="async" />
</div>

<style>
  .walkman-corner {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 12;
    width: 74px;
    padding: 8px;
    border: 1px solid rgba(224, 163, 106, 0.22);
    background: rgba(20, 17, 12, 0.54);
    box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.28);
    opacity: 0.74;
    pointer-events: none;
  }

  .walkman-corner img {
    width: 100%;
    height: auto;
  }

  @media (prefers-reduced-motion: no-preference) {
    .walkman-corner {
      animation: walkman-corner-idle 8s ease-in-out infinite;
    }
  }

  @keyframes walkman-corner-idle {
    0%,
    100% {
      transform: translateY(0);
      opacity: 0.66;
    }

    45% {
      transform: translateY(-2px);
      opacity: 0.82;
    }
  }

  @media (max-width: 760px) {
    .walkman-corner {
      display: none;
    }
  }
</style>
