<script>
  type LodgeReadingProgressController = {
    destroy: () => void;
  };

  type LodgeReadingProgressWindow = Window & {
    __hvitveldtReadingProgress?: LodgeReadingProgressController;
    __hvitveldtReadingProgressBound?: boolean;
  };

  const progressWindow = window as LodgeReadingProgressWindow;
  const storageKey = "hvitveldt:reading:last";
  const visitKey = "hvitveldt:reading:visits";
  const jumpKey = "hvitveldt:reading:jumps";
  const MIN_TRACKED_PROGRESS = 0.005;
  const COMPLETED_PROGRESS = 0.995;

  const setupReadingProgress = () => {
    progressWindow.__hvitveldtReadingProgress?.destroy();

    const article = document.querySelector("article.chapter");
    const resumeRequested = new URLSearchParams(window.location.search).get("resume") === "1";

    if (resumeRequested && "scrollRestoration" in history) {
      try {
        history.scrollRestoration = "manual";
      } catch {
        // ignore: some browsers disallow setting this.
      }
    }

    if (!(article instanceof HTMLElement)) {
      progressWindow.__hvitveldtReadingProgress = undefined;
      return;
    }

    let ticking = false;
    let lastSavedAt = 0;
    const chapterId = article.dataset.chapterId ?? "";
    const chapterKey = chapterId ? `hvitveldt:reading:chapter:${chapterId}` : "";
    const chapterNumber = Number(article.dataset.chapter ?? 0);
    const enteredAt = Date.now();
    const timers = new Set<number>();
    let loadStart: (() => void) | null = null;

    const setTimer = (callback: () => void, ms: number) => {
      const timer = window.setTimeout(() => {
        timers.delete(timer);
        callback();
      }, ms);
      timers.add(timer);
      return timer;
    };

    // Collect "anchorable" direct children of the article. Skip rune dividers
    // and end-of-chapter marks because they have no readable text to resume.
    const ANCHOR_SELECTOR = "p, div.journal, blockquote, figure, h1, h2, h3, ul, ol";
    const blocks = Array.from(article.querySelectorAll<HTMLElement>(`:scope > ${ANCHOR_SELECTOR}`));

    const buildExcerpt = (el: HTMLElement): string => {
      const text = (el.textContent ?? "").replace(/\s+/g, " ").trim();
      if (!text) return "";
      const limit = 80;
      return text.length > limit ? `${text.slice(0, limit)}…` : text;
    };

    const findCurrentBlockIndex = (): number => {
      const threshold = window.innerHeight * 0.35;
      let currentIndex = -1;

      for (let index = 0; index < blocks.length; index += 1) {
        const rect = blocks[index].getBoundingClientRect();
        if (rect.top <= threshold) {
          currentIndex = index;
        } else {
          break;
        }
      }

      return currentIndex < 0 ? 0 : currentIndex;
    };

    const readStored = (key: string) => {
      try {
        const raw = localStorage.getItem(key);
        return raw ? JSON.parse(raw) : null;
      } catch {
        return null;
      }
    };

    const writeStored = (key: string, value: unknown) => {
      try {
        localStorage.setItem(key, JSON.stringify(value));
      } catch {
        // localStorage can fail in private or restricted browser modes.
      }
    };

    const boundedList = (key: string, item: Record<string, unknown>, limit: number) => {
      const current = readStored(key);
      const list = Array.isArray(current) ? current : [];
      list.push(item);
      writeStored(key, list.slice(-limit));
    };

    const previous = readStored(storageKey);
    const previousChapterNumber = Number(previous?.chapterNumber ?? 0);
    const previousMaxChapterNumber = Number(previous?.maxChapterNumber ?? 0);
    const enteringNewChapter = chapterId ? previous?.chapterId !== chapterId : false;
    const maxChapterNumber = Math.max(
      Number.isFinite(previousMaxChapterNumber) ? previousMaxChapterNumber : 0,
      Number.isFinite(chapterNumber) ? chapterNumber : 0,
    );

    let jumpType = "start";

    if (
      chapterId &&
      typeof previous?.chapterId === "string" &&
      previous.chapterId !== chapterId &&
      Number.isFinite(chapterNumber) &&
      Number.isFinite(previousChapterNumber)
    ) {
      const diff = chapterNumber - previousChapterNumber;
      jumpType = Math.abs(diff) <= 1 ? "adjacent" : diff > 1 ? "forward-skip" : "backtrack";

      const movement = {
        chapterId,
        chapterNumber,
        fromChapterId: previous.chapterId,
        fromChapterNumber: previousChapterNumber,
        jumpType,
        enteredAt,
      };

      boundedList(visitKey, movement, 80);

      if (Math.abs(diff) > 1) {
        boundedList(jumpKey, movement, 50);
      }
    }

    const getRatio = () => {
      const rect = article.getBoundingClientRect();
      const scrollable = Math.max(1, rect.height - window.innerHeight);
      const read = Math.min(Math.max(-rect.top, 0), scrollable);
      return read / scrollable;
    };

    const saveProgress = (ratio: number) => {
      if (!Number.isFinite(ratio) || !chapterId || (ratio < MIN_TRACKED_PROGRESS && !enteringNewChapter)) {
        return;
      }

      const normalizedProgress = ratio >= COMPLETED_PROGRESS ? 1 : Math.max(ratio, MIN_TRACKED_PROGRESS);
      const now = Date.now();
      if (now - lastSavedAt < 750 && ratio < COMPLETED_PROGRESS) {
        return;
      }

      lastSavedAt = now;

      const blockIndex = blocks.length > 0 ? findCurrentBlockIndex() : -1;
      const excerpt = blockIndex >= 0 ? buildExcerpt(blocks[blockIndex]) : "";

      const saved = {
        chapterId,
        chapterNumber: article.dataset.chapter ?? "",
        chapterTitle: article.dataset.chapterTitle ?? "",
        path: window.location.pathname,
        progress: Number(normalizedProgress.toFixed(4)),
        blockIndex,
        blockExcerpt: excerpt,
        blockCount: blocks.length,
        updatedAt: now,
        enteredAt,
        maxChapterNumber,
        fromChapterId: typeof previous?.chapterId === "string" ? previous.chapterId : "",
        fromChapterNumber: Number.isFinite(previousChapterNumber) ? previousChapterNumber : "",
        jumpType,
      };

      writeStored(storageKey, saved);
      writeStored(chapterKey, saved);
    };

    const update = () => {
      const ratio = getRatio();
      saveProgress(ratio);
      ticking = false;
    };

    const requestUpdate = () => {
      if (!ticking) {
        ticking = true;
        window.requestAnimationFrame(update);
      }
    };

    const pickHighlightTarget = (preferredIndex: number): HTMLElement | null => {
      if (blocks.length === 0) return null;
      const safe = (idx: number) => Math.max(0, Math.min(blocks.length - 1, idx));
      const start = safe(preferredIndex);
      const candidate = blocks[start];
      if (candidate && candidate.tagName !== "FIGURE") {
        return candidate;
      }

      for (let index = start - 1; index >= 0; index -= 1) {
        if (blocks[index].tagName !== "FIGURE") return blocks[index];
      }

      for (let index = start + 1; index < blocks.length; index += 1) {
        if (blocks[index].tagName !== "FIGURE") return blocks[index];
      }

      return null;
    };

    const flashHighlight = (el: HTMLElement) => {
      el.classList.add("resume-highlight");
      setTimer(() => {
        el.classList.remove("resume-highlight");
      }, 3000);
    };

    const startResume = () => {
      if (!resumeRequested || !chapterKey) {
        return;
      }

      const saved = readStored(chapterKey);
      const savedProgress = Number(saved?.progress);
      const savedBlockIndex = Number(saved?.blockIndex);
      const hasBlockAnchor =
        Number.isFinite(savedBlockIndex) &&
        savedBlockIndex >= 0 &&
        savedBlockIndex < blocks.length;

      let highlightBlock: HTMLElement | null = null;
      let ratioFallback: number | null = null;

      if (hasBlockAnchor) {
        highlightBlock = pickHighlightTarget(savedBlockIndex);
      } else if (
        Number.isFinite(savedProgress) &&
        savedProgress >= MIN_TRACKED_PROGRESS &&
        savedProgress < COMPLETED_PROGRESS
      ) {
        ratioFallback = savedProgress;
        highlightBlock = pickHighlightTarget(Math.floor(savedProgress * blocks.length));
      }

      if (!highlightBlock && ratioFallback === null) {
        return;
      }

      const computeTarget = (): number => {
        if (highlightBlock) {
          const absoluteTop = highlightBlock.getBoundingClientRect().top + window.scrollY;
          return Math.max(0, absoluteTop - window.innerHeight * 0.3);
        }

        const scrollable = Math.max(1, article.offsetHeight - window.innerHeight);
        return article.offsetTop + scrollable * (ratioFallback ?? 0);
      };

      let corrections = 0;
      const settleAndCorrect = () => {
        const desired = computeTarget();
        if (Math.abs(window.scrollY - desired) > 8 && corrections < 5) {
          corrections += 1;
          window.scrollTo({ top: desired, behavior: "auto" });
          setTimer(settleAndCorrect, 160);
          return;
        }

        if (highlightBlock) {
          flashHighlight(highlightBlock);
        }
      };

      let started = false;
      const start = () => {
        if (started) return;
        started = true;
        window.scrollTo({ top: computeTarget(), behavior: "auto" });
        history.replaceState(null, "", window.location.pathname + window.location.hash);
        setTimer(settleAndCorrect, 200);
      };

      if (document.readyState === "complete") {
        setTimer(start, 80);
      } else {
        loadStart = () => setTimer(start, 80);
        window.addEventListener("load", loadStart, { once: true });
        setTimer(start, 1400);
      }
    };

    // --- SECRET READING TRACKING SYSTEM ---
    const secretTimersKey = "hvitveldt:secret:timers";
    const secretReadsKey = "hvitveldt:secret:reads";
    const SECRET_THRESHOLD_SEC = 420; // 7 minutes

    let activeSeconds = 0;
    let lastInteraction = Date.now();

    const loadSecretTimers = (): Record<string, number> => {
      try {
        const raw = localStorage.getItem(secretTimersKey);
        return raw ? JSON.parse(raw) : {};
      } catch {
        return {};
      }
    };

    const saveSecretTimers = (timersObj: Record<string, number>) => {
      try {
        localStorage.setItem(secretTimersKey, JSON.stringify(timersObj));
      } catch {}
    };

    const getSecretReads = (): string[] => {
      try {
        const raw = localStorage.getItem(secretReadsKey);
        return Array.isArray(raw ? JSON.parse(raw) : null) ? JSON.parse(raw!) : [];
      } catch {
        return [];
      }
    };

    const saveSecretReads = (reads: string[]) => {
      try {
        localStorage.setItem(secretReadsKey, JSON.stringify(reads));
      } catch {}
    };

    if (chapterId) {
      const currentTimers = loadSecretTimers();
      activeSeconds = currentTimers[chapterId] || 0;
    }

    const recordInteraction = () => {
      lastInteraction = Date.now();
    };

    const updateSecretTimer = () => {
      if (!chapterId) return;
      const now = Date.now();
      // User is active if there was interaction in the last 60 seconds
      if (now - lastInteraction < 60000) {
        activeSeconds += 1;

        if (activeSeconds % 10 === 0 || activeSeconds >= SECRET_THRESHOLD_SEC) {
          const currentTimers = loadSecretTimers();
          currentTimers[chapterId] = activeSeconds;
          saveSecretTimers(currentTimers);
        }

        if (activeSeconds >= SECRET_THRESHOLD_SEC) {
          const currentReads = getSecretReads();
          if (!currentReads.includes(chapterId)) {
            currentReads.push(chapterId);
            saveSecretReads(currentReads);
          }
        }
      }
    };

    const secretInterval = window.setInterval(updateSecretTimer, 1000);

    const handlePageHide = () => {
      saveProgress(getRatio());
      if (chapterId) {
        const currentTimers = loadSecretTimers();
        currentTimers[chapterId] = activeSeconds;
        saveSecretTimers(currentTimers);
      }
    };

    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);
    window.addEventListener("pagehide", handlePageHide);

    // Interaction listeners for secret tracking
    window.addEventListener("mousemove", recordInteraction, { passive: true });
    window.addEventListener("keydown", recordInteraction, { passive: true });
    window.addEventListener("touchstart", recordInteraction, { passive: true });
    window.addEventListener("click", recordInteraction, { passive: true });

    startResume();
    update();

    progressWindow.__hvitveldtReadingProgress = {
      destroy() {
        window.removeEventListener("scroll", requestUpdate);
        window.removeEventListener("resize", requestUpdate);
        window.removeEventListener("pagehide", handlePageHide);
        window.removeEventListener("mousemove", recordInteraction);
        window.removeEventListener("keydown", recordInteraction);
        window.removeEventListener("touchstart", recordInteraction);
        window.removeEventListener("click", recordInteraction);
        window.clearInterval(secretInterval);
        
        if (loadStart) {
          window.removeEventListener("load", loadStart);
        }
        for (const timer of timers) {
          window.clearTimeout(timer);
        }
        timers.clear();
      },
    };
  };

  if (!progressWindow.__hvitveldtReadingProgressBound) {
    progressWindow.__hvitveldtReadingProgressBound = true;
    document.addEventListener("astro:page-load", setupReadingProgress);
  }

  setupReadingProgress();
</script>
