<script>
  const media = window.matchMedia("(prefers-reduced-motion: reduce)");
  const article = document.querySelector("article.chapter");
  const storageKey = "hvitveldt:reading:last";
  const visitKey = "hvitveldt:reading:visits";
  const jumpKey = "hvitveldt:reading:jumps";
  const resumeRequested = new URLSearchParams(window.location.search).get("resume") === "1";

  if (article instanceof HTMLElement) {
    let ticking = false;
    let lastSavedAt = 0;
    const chapterId = article.dataset.chapterId ?? "";
    const chapterKey = chapterId ? `hvitveldt:reading:chapter:${chapterId}` : "";
    const chapterNumber = Number(article.dataset.chapter ?? 0);
    const enteredAt = Date.now();

    // ----- Block-level anchor capture (D1) -----
    // Collect "anchorable" direct children of the article: paragraphs, journal divs,
    // blockquotes, figures, headings, lists. Skip rune dividers and end-of-chapter
    // marks (they have no readable content).
    const ANCHOR_SELECTOR = "p, div.journal, blockquote, figure, h1, h2, h3, ul, ol";
    const blocks = Array.from(article.querySelectorAll<HTMLElement>(`:scope > ${ANCHOR_SELECTOR}`));

    const buildExcerpt = (el: HTMLElement): string => {
      const text = (el.textContent ?? "").replace(/\s+/g, " ").trim();
      if (!text) return "";
      // Thai characters are wider than ASCII; 80 chars stays under ~one line on mobile.
      const limit = 80;
      return text.length > limit ? `${text.slice(0, limit)}…` : text;
    };

    const findCurrentBlockIndex = (): number => {
      // The "current" block is the last one whose top has crossed 35% of the viewport.
      // Falls back to 0 if nothing has crossed yet.
      const threshold = window.innerHeight * 0.35;
      let currentIndex = -1;
      for (let i = 0; i < blocks.length; i += 1) {
        const rect = blocks[i].getBoundingClientRect();
        if (rect.top <= threshold) {
          currentIndex = i;
        } else {
          break;
        }
      }
      return currentIndex < 0 ? 0 : currentIndex;
    };

    const readStored = (key: string) => {
      try {
        const raw = localStorage.getItem(key);
        return raw ? JSON.parse(raw) : null;
      } catch {
        return null;
      }
    };

    const writeStored = (key: string, value: unknown) => {
      try {
        localStorage.setItem(key, JSON.stringify(value));
      } catch {
        // localStorage can fail in private or restricted browser modes.
      }
    };

    const boundedList = (key: string, item: Record<string, unknown>, limit: number) => {
      const current = readStored(key);
      const list = Array.isArray(current) ? current : [];
      list.push(item);
      writeStored(key, list.slice(-limit));
    };

    const previous = readStored(storageKey);
    const previousChapterNumber = Number(previous?.chapterNumber ?? 0);
    const previousMaxChapterNumber = Number(previous?.maxChapterNumber ?? 0);
    const maxChapterNumber = Math.max(
      Number.isFinite(previousMaxChapterNumber) ? previousMaxChapterNumber : 0,
      Number.isFinite(chapterNumber) ? chapterNumber : 0,
    );

    let jumpType = "start";

    if (
      chapterId &&
      typeof previous?.chapterId === "string" &&
      previous.chapterId !== chapterId &&
      Number.isFinite(chapterNumber) &&
      Number.isFinite(previousChapterNumber)
    ) {
      const diff = chapterNumber - previousChapterNumber;
      jumpType = Math.abs(diff) <= 1 ? "adjacent" : diff > 1 ? "forward-skip" : "backtrack";

      const movement = {
        chapterId,
        chapterNumber,
        fromChapterId: previous.chapterId,
        fromChapterNumber: previousChapterNumber,
        jumpType,
        enteredAt,
      };

      boundedList(visitKey, movement, 80);

      if (Math.abs(diff) > 1) {
        boundedList(jumpKey, movement, 50);
      }
    }

    const getRatio = () => {
      const rect = article.getBoundingClientRect();
      const scrollable = Math.max(1, rect.height - window.innerHeight);
      const read = Math.min(Math.max(-rect.top, 0), scrollable);
      return read / scrollable;
    };

    const saveProgress = (ratio: number) => {
      if (!chapterId || ratio < 0.005) {
        return;
      }

      const now = Date.now();
      if (now - lastSavedAt < 750 && ratio < 0.99) {
        return;
      }

      lastSavedAt = now;

      const blockIndex = blocks.length > 0 ? findCurrentBlockIndex() : -1;
      const excerpt = blockIndex >= 0 ? buildExcerpt(blocks[blockIndex]) : "";

      const saved = {
        chapterId,
        chapterNumber: article.dataset.chapter ?? "",
        chapterTitle: article.dataset.chapterTitle ?? "",
        path: window.location.pathname,
        progress: Number(ratio.toFixed(4)),
        blockIndex,
        blockExcerpt: excerpt,
        blockCount: blocks.length,
        updatedAt: now,
        enteredAt,
        maxChapterNumber,
        fromChapterId: typeof previous?.chapterId === "string" ? previous.chapterId : "",
        fromChapterNumber: Number.isFinite(previousChapterNumber) ? previousChapterNumber : "",
        jumpType,
      };

      writeStored(storageKey, saved);
      writeStored(chapterKey, saved);
    };

    const update = () => {
      const ratio = getRatio();

      saveProgress(ratio);
      ticking = false;
    };

    const requestUpdate = () => {
      if (!ticking) {
        ticking = true;
        window.requestAnimationFrame(update);
      }
    };

    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);

    // ----- Resume highlight (D2) -----
    // Choose a target block that the reader can safely look at.
    // Figures are skipped so the glow never sits behind chapter art (01A/01B etc.).
    const pickHighlightTarget = (preferredIndex: number): HTMLElement | null => {
      if (blocks.length === 0) return null;
      const safe = (idx: number) => Math.max(0, Math.min(blocks.length - 1, idx));
      const start = safe(preferredIndex);
      const candidate = blocks[start];
      if (candidate && candidate.tagName !== "FIGURE") {
        return candidate;
      }
      // If we landed on a figure, prefer the paragraph just before it.
      for (let i = start - 1; i >= 0; i -= 1) {
        if (blocks[i].tagName !== "FIGURE") return blocks[i];
      }
      // Otherwise look forward.
      for (let i = start + 1; i < blocks.length; i += 1) {
        if (blocks[i].tagName !== "FIGURE") return blocks[i];
      }
      return null;
    };

    const flashHighlight = (el: HTMLElement) => {
      el.classList.add("resume-highlight");
      // Animation runs 1800ms; we clear the class slightly after so the next
      // resume can re-trigger cleanly.
      window.setTimeout(() => {
        el.classList.remove("resume-highlight");
      }, 2100);
    };

    if (resumeRequested && chapterKey) {
      window.setTimeout(() => {
        try {
          const saved = readStored(chapterKey);
          const savedProgress = Number(saved?.progress);
          const savedBlockIndex = Number(saved?.blockIndex);
          const hasBlockAnchor =
            Number.isFinite(savedBlockIndex) &&
            savedBlockIndex >= 0 &&
            savedBlockIndex < blocks.length;

          // Prefer block anchor if available; fall back to ratio for legacy saves.
          let targetTop: number | null = null;
          let highlightBlock: HTMLElement | null = null;

          if (hasBlockAnchor) {
            highlightBlock = pickHighlightTarget(savedBlockIndex);
            if (highlightBlock) {
              // Position the highlight block ~30% from the top of the viewport
              // so the reader's eye lands naturally on it.
              const blockRect = highlightBlock.getBoundingClientRect();
              const absoluteTop = blockRect.top + window.scrollY;
              targetTop = Math.max(0, absoluteTop - window.innerHeight * 0.3);
            }
          }

          if (targetTop === null) {
            if (!Number.isFinite(savedProgress) || savedProgress <= 0.01 || savedProgress >= 0.99) {
              return;
            }
            const scrollable = Math.max(1, article.offsetHeight - window.innerHeight);
            targetTop = article.offsetTop + scrollable * savedProgress;
            highlightBlock = pickHighlightTarget(Math.floor(savedProgress * blocks.length));
          }

          window.scrollTo({
            top: targetTop,
            behavior: media.matches ? "auto" : "smooth",
          });
          history.replaceState(null, "", window.location.pathname + window.location.hash);

          if (highlightBlock) {
            // Wait for smooth scroll to settle before flashing.
            const delay = media.matches ? 60 : 520;
            window.setTimeout(() => flashHighlight(highlightBlock!), delay);
          }
        } catch {
          return;
        }
      }, 120);
    }

    window.addEventListener("pagehide", () => saveProgress(getRatio()));
    update();
  }
</script>
