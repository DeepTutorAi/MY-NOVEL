---
import { getCollection } from "astro:content";
import LodgeBaseLayout from "../../../layouts/lodge/LodgeBaseLayout.astro";
import { ACTS } from "../../../data/lodge/acts";
import { withBase } from "../../../utils/base-path";
import { formatReadingTime } from "../../../utils/reading-time";
import "../../../styles/lodge/chapter.css";

const roman = ["I", "II", "III", "IV"];
const chapters = (await getCollection("chapters")).sort(
  (a, b) => a.data.number - b.data.number,
);
---

<LodgeBaseLayout
  title="สารบัญ — ฮวิตเวลต์ ลอดจ์"
  description="สารบัญฮวิตเวลต์ ลอดจ์ แบ่งตามช่วง"
  bodyClass="toc-page"
>
  <main class="toc">
    <h1>ฮวิตเวลต์ ลอดจ์</h1>
    <p class="toc-intro">เลือกอ่านตามบท บทอ่านจะเปิดในหน้าที่จัดสำหรับการอ่านยาวโดยเฉพาะ</p>

    {
      chapters.filter(c => c.data.number === 0).map(c => (
        <section class="toc-act">
          <ul class="toc-list">
            <li>
              <a class="toc-row" data-chapter-id={c.id} href={withBase(`/lodge/chapters/${c.id}/`)}>
                <span class="toc-row-number">บทนำ —</span>
                <span class="toc-row-copy">
                  <span class="toc-row-title">{c.data.title}</span>
                  {c.data.thaiTitle && (
                    <span class="toc-row-thai"> — {c.data.thaiTitle}</span>
                  )}
                  {c.data.summary && (
                    <span class="toc-row-summary">{c.data.summary}</span>
                  )}
                </span>
                <span class="toc-row-time">{formatReadingTime(c.data.readingMinutes)}</span>
              </a>
            </li>
          </ul>
        </section>
      ))
    }

    {
      ACTS.map((act, index) => {
        const actChapters = chapters.filter((chapter) => chapter.data.act === act.number && chapter.data.number !== 0);

        return (
          <section class="toc-act" aria-labelledby={`act-${act.number}`}>
            <h2 id={`act-${act.number}`}>
              ช่วง {roman[index]} · {act.title}
            </h2>
            <ul class="toc-list">
              {actChapters.map((chapter) => (
                <li>
                  <a class="toc-row" data-chapter-id={chapter.id} href={withBase(`/lodge/chapters/${chapter.id}/`)}>
                    <span class="toc-row-number">บทที่ {chapter.data.number} —</span>
                    <span class="toc-row-copy">
                      <span class="toc-row-title">{chapter.data.title}</span>
                      {chapter.data.thaiTitle && (
                        <span class="toc-row-thai"> — {chapter.data.thaiTitle}</span>
                      )}
                      {chapter.data.summary && (
                        <span class="toc-row-summary">{chapter.data.summary}</span>
                      )}
                    </span>
                    <span class="toc-row-time">{formatReadingTime(chapter.data.readingMinutes)}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        );
      })
    }
  </main>

  <script>
    const updateReads = () => {
      try {
        const raw = localStorage.getItem("hvitveldt:secret:reads");
        const reads = raw ? JSON.parse(raw) : [];
        if (Array.isArray(reads)) {
          const links = document.querySelectorAll(".toc-row[data-chapter-id]");
          links.forEach((link) => {
            if (link instanceof HTMLElement) {
              const id = link.dataset.chapterId;
              if (id && reads.includes(id)) {
                link.classList.add("is-read");
              }
            }
          });
        }
      } catch (e) {}
    };

    updateReads();
    document.addEventListener("astro:page-load", updateReads);
  </script>

  <style>
    .toc-row.is-read::after {
      content: " 📌";
      margin-left: 0.5rem;
      font-size: 0.9em;
      filter: drop-shadow(0 0 2px var(--accent));
    }
  </style>
</LodgeBaseLayout>
