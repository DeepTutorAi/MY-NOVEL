---
import { ClientRouter } from "astro:transitions";
import GrainOverlay from "../../components/_shared/GrainOverlay.astro";
import SakuraTwilightBackdrop from "../../components/tsukinomi/atmosphere/SakuraTwilightBackdrop.astro";
import WalkmanPlayer from "../../components/tsukinomi/audio/WalkmanPlayer.astro";
import TopBar from "../../components/tsukinomi/navigation/TopBar.astro";
import WalkmanCorner from "../../components/tsukinomi/reading/WalkmanCorner.astro";
import {
  HOME_BACKGROUND_SLOT,
  getTsukinomiBackgroundSlot,
  type TsukinomiBackgroundSlotId,
} from "../../data/tsukinomi/background-slots";
import "../../styles/tsukinomi/global.css";
import { withBase } from "../../utils/base-path";

interface Props {
  title: string;
  description: string;
  bodyClass?: string;
  sectionPalette?: string;
  musicCueId?: string;
  backgroundSlotId?: TsukinomiBackgroundSlotId;
  showTopBar?: boolean;
  ogImage?: string;
}

const {
  title,
  description,
  bodyClass,
  sectionPalette = "",
  musicCueId = "",
  backgroundSlotId = HOME_BACKGROUND_SLOT.id,
  showTopBar = true,
  ogImage = "/og.jpg",
} = Astro.props;
const canonical = Astro.url.href;
const resolvedOgImage = new URL(withBase(ogImage), Astro.site ?? Astro.url).href;
const faviconLit = withBase("/favicon.svg");
const faviconPng = withBase("/favicon.png");
const bodyClasses = ["tsukinomi-page", "tsukinomi-shell", showTopBar ? "has-tsukinomi-topbar" : "", bodyClass]
  .filter(Boolean)
  .join(" ");
const backgroundSlot = getTsukinomiBackgroundSlot(backgroundSlotId);
const backgroundStatus = backgroundSlot.status;
const backgroundStyle = backgroundSlot.cssImage === "none" ? undefined : `--bg-image: ${backgroundSlot.cssImage};`;
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0E0B1E" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={faviconLit} type="image/svg+xml" />
    <link rel="icon" href={faviconPng} type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href={faviconPng} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <ClientRouter />
  </head>
  <body
    class={bodyClasses}
    style={backgroundStyle}
    data-theme="sakura-twilight"
    data-section={sectionPalette}
    data-palette={sectionPalette}
    data-music-cue={musicCueId}
    data-background-slot={backgroundSlotId}
    data-background-status={backgroundStatus}
    data-background-expected={backgroundSlot.expectedImageBase}
  >
    <SakuraTwilightBackdrop />
    <GrainOverlay texture="/assets/tsukinomi/textures/film-grain.png" />
    <WalkmanCorner />
    <WalkmanPlayer />
    {showTopBar && <TopBar />}
    <slot />
  </body>
</html>
