---
import NovelCard from "../components/_shared/NovelCard.astro";
import ResumeCard from "../components/_shared/ResumeCard.astro";
import { NOVELS } from "../data/_novels";
import HubLayout from "../layouts/HubLayout.astro";
---

<HubLayout
  title="Pii-chan Dechalert — Fiction Hub"
  description="พื้นที่รวมผลงานนิยายของ Pii-chan Dechalert"
>
  <main class="hub-shell" aria-labelledby="hub-title">
    <section class="hub-hero">
      <div class="hub-title-group">
        <h1 id="hub-title">Pii-chan Dechalert</h1>
        <p>สองเรื่อง สองอากาศ และพื้นที่อ่านเดียวกันสำหรับกลับไปยังโลกที่ยังค้างอยู่</p>
      </div>
      
      <div class="hub-side-col">
        <div class="hub-profile-widget" data-profile-widget style="display: none;">
          <div class="hub-profile-info">
            <span class="profile-icon" data-profile-icon>👤</span>
            <span class="profile-name" data-profile-name>...</span>
          </div>
          <div class="hub-profile-actions">
            <button type="button" class="hub-profile-edit-btn" data-profile-edit-btn>
              แก้ไขโปรไฟล์
            </button>
            <button type="button" class="hub-profile-settings-btn" data-profile-settings-btn>
              สลับ Guest
            </button>
          </div>
        </div>
        <p class="hub-side-note">ฮับกลางสำหรับนิยายที่เปิดให้อ่านแล้ว และเรื่องถัดไปที่กำลังรอเวลาเดินทางมาถึง</p>
      </div>
    </section>

    <ResumeCard />

    <section class="hub-library" aria-label="รายการนิยาย">
      {NOVELS.map((novel) => <NovelCard novel={novel} />)}
    </section>

    <footer class="hub-footer">
      <span>เพิ่มเรื่องใหม่: เร็วๆ นี้</span>
      <span>Pii-chan Dechalert · 2026</span>
    </footer>
  </main>

  <!-- EDIT PROFILE MODAL -->
  <div class="hub-modal-overlay" data-edit-profile-modal style="display: none;">
    <div class="hub-modal-card">
      <div class="modal-header">
        <h2>แก้ไขโปรไฟล์ Guest</h2>
        <button type="button" class="modal-close-btn" data-edit-profile-close-btn>×</button>
      </div>
      <div class="modal-body">
        <div class="modal-form-group">
          <label for="edit-profile-name">ชื่อของคุณ (เปลี่ยนได้ตามใจชอบ)</label>
          <input type="text" id="edit-profile-name" placeholder="ระบุชื่อของคุณ..." maxlength="20" />
        </div>
        
        <div class="modal-form-group" style="margin-top: 16px;">
          <label>รูปโปรไฟล์ (เลือกอิโมจิ หรือวางลิงก์รูปภาพ)</label>
          <div class="avatar-selectors">
            <button type="button" class="avatar-preset-btn" data-preset="👤">👤</button>
            <button type="button" class="avatar-preset-btn" data-preset="🐱">🐱</button>
            <button type="button" class="avatar-preset-btn" data-preset="🐶">🐶</button>
            <button type="button" class="avatar-preset-btn" data-preset="🐸">🐸</button>
            <button type="button" class="avatar-preset-btn" data-preset="🦊">🦊</button>
            <button type="button" class="avatar-preset-btn" data-preset="👻">👻</button>
            <button type="button" class="avatar-preset-btn" data-preset="👽">👽</button>
            <button type="button" class="avatar-preset-btn" data-preset="🤖">🤖</button>
            <button type="button" class="avatar-preset-btn" data-preset="💩">💩</button>
            <button type="button" class="avatar-preset-btn" data-preset="🤡">🤡</button>
            <button type="button" class="avatar-preset-btn" data-preset="🍆">🍆</button>
            <button type="button" class="avatar-preset-btn" data-preset="🍑">🍑</button>
            <button type="button" class="avatar-preset-btn" data-preset="💦">💦</button>
            <button type="button" class="avatar-preset-btn" data-preset="🤪">🤪</button>
            <button type="button" class="avatar-preset-btn" data-preset="🖕">🖕</button>
          </div>
          
          <div style="display: flex; gap: 8px; margin-top: 8px;">
            <input type="text" id="edit-profile-avatar-input" placeholder="พิมพ์ข้อความ/วางลิงก์รูปภาพ..." style="flex: 1;" />
          </div>
        </div>
        
        <button type="button" class="btn-primary btn-full" style="margin-top: 24px;" data-save-profile-btn>
          บันทึกการเปลี่ยนแปลง
        </button>
      </div>
    </div>
  </div>

  <!-- SWITCH PROFILE MODAL -->
  <div class="hub-modal-overlay" data-settings-modal style="display: none;">
    <div class="hub-modal-card">
      <div class="modal-header">
        <h2>สลับโปรไฟล์ Guest</h2>
        <button type="button" class="modal-close-btn" data-settings-close-btn>×</button>
      </div>
      <div class="modal-body">
        <section class="settings-section">
          <h3>👥 โปรไฟล์ Guest ทั้งหมดบนเครื่องนี้</h3>
          <div class="profiles-list" data-profiles-list>
            <!-- Profiles generated dynamically -->
          </div>
          
          <button type="button" class="btn-primary btn-full" style="margin-top: 12px;" data-add-guest-btn>
            ➕ เพิ่ม Guest ใหม่ (สุ่มชื่อปั่นๆ)
          </button>
        </section>
      </div>
    </div>
  </div>
</HubLayout>

<style>
  /* Profile Widget */
  .hub-side-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-end;
  }

  .hub-profile-widget {
    background: var(--hub-panel-strong);
    border: 1px solid var(--hub-line);
    border-radius: 6px;
    padding: 12px 16px;
    width: 100%;
    max-width: 260px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    box-sizing: border-box;
  }

  .hub-profile-info {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.95rem;
  }

  .profile-icon {
    font-size: 1.25rem;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.2);
    border-radius: 50%;
    overflow: hidden;
  }

  .profile-icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .profile-name {
    font-weight: 500;
    color: var(--hub-ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 180px;
  }

  .hub-profile-actions {
    display: flex;
    gap: 6px;
    width: 100%;
  }

  .hub-profile-edit-btn,
  .hub-profile-settings-btn {
    flex: 1;
    background: none;
    border: 1px solid var(--hub-line);
    color: var(--hub-muted);
    font-size: 0.75rem;
    padding: 6px 4px;
    border-radius: 4px;
    cursor: pointer;
    text-align: center;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .hub-profile-edit-btn:hover,
  .hub-profile-settings-btn:hover {
    background: rgba(238, 232, 221, 0.05);
    color: var(--hub-ink);
  }

  /* Modal Overlay */
  .hub-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(10, 9, 8, 0.85);
    backdrop-filter: blur(12px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    animation: fadeIn 0.25s ease-out;
  }

  .hub-modal-card {
    background: var(--hub-panel-strong);
    border: 1px solid var(--hub-line);
    border-radius: 8px;
    width: 100%;
    max-width: 480px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
    overflow: hidden;
    animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .modal-header {
    padding: 20px 24px;
    border-bottom: 1px solid var(--hub-line);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .modal-header h2 {
    margin: 0;
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--hub-ink);
    font-family: var(--font-display);
  }

  .modal-close-btn {
    background: none;
    border: none;
    color: var(--hub-muted);
    font-size: 1.5rem;
    cursor: pointer;
    line-height: 1;
    padding: 4px;
  }

  .modal-close-btn:hover {
    color: var(--hub-ink);
  }

  .modal-body {
    padding: 24px;
  }

  .modal-form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .modal-form-group label {
    font-size: 0.85rem;
    color: var(--hub-muted);
  }

  .modal-form-group input {
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid var(--hub-line);
    color: var(--hub-ink);
    padding: 8px 12px;
    border-radius: 4px;
  }

  .btn-primary {
    background: var(--hub-accent);
    color: var(--paper-deep);
    border: none;
    padding: 8px 16px;
    border-radius: 4px;
    font-weight: 500;
    cursor: pointer;
    font-size: 0.95rem;
    transition: opacity 0.2s;
  }

  .btn-primary:hover {
    opacity: 0.9;
  }

  .btn-full {
    width: 100%;
  }

  /* Avatar Selectors */
  .avatar-selectors {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
  }

  .avatar-preset-btn {
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--hub-line);
    border-radius: 4px;
    cursor: pointer;
    background: rgba(0, 0, 0, 0.15);
    font-size: 1.15rem;
    transition: background 0.2s, border-color 0.2s;
  }

  .avatar-preset-btn:hover,
  .avatar-preset-btn.is-selected {
    background: rgba(238, 232, 221, 0.1);
    border-color: var(--hub-accent);
  }

  /* Settings Card specific */
  .settings-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .settings-section h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 500;
    color: var(--hub-ink);
  }

  .profiles-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-height: 180px;
    overflow-y: auto;
  }

  .profile-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(0, 0, 0, 0.15);
    border: 1px solid var(--hub-line);
    border-radius: 4px;
    padding: 8px 12px;
  }

  .profile-item-info {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.95rem;
  }

  .profile-item-info .profile-icon {
    width: 24px;
    height: 24px;
    font-size: 0.95rem;
  }

  .profile-item.is-active {
    border-color: var(--hub-accent);
    background: color-mix(in srgb, var(--hub-accent) 8%, transparent);
  }

  .profile-item.is-active::after {
    content: '✓';
    color: var(--hub-accent);
    font-weight: bold;
    font-size: 0.95rem;
  }

  .profile-item-actions {
    display: flex;
    gap: 8px;
  }

  .btn-switch, .btn-delete-profile {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.85rem;
    padding: 4px 8px;
    border-radius: 2px;
  }

  .btn-switch {
    color: var(--hub-accent);
  }

  .btn-delete-profile {
    color: #ff6b6b;
  }

  .add-profile-inline {
    display: flex;
    gap: 8px;
    margin-top: 4px;
  }

  .add-profile-inline button {
    background: none;
    border: 1px solid var(--hub-line);
    color: var(--hub-ink);
    padding: 6px 12px;
    border-radius: 4px;
    cursor: pointer;
  }

  .section-desc {
    font-size: 0.85rem;
    color: var(--hub-muted);
    margin: 0;
  }

  .backup-group, .restore-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 8px;
  }

  .backup-group label, .restore-group label {
    font-size: 0.8rem;
    color: var(--hub-muted);
  }

  .backup-group textarea {
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid var(--hub-line);
    color: var(--hub-muted);
    border-radius: 4px;
    padding: 8px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    height: 60px;
    resize: none;
    word-break: break-all;
  }

  .btn-copy, .btn-restore {
    background: none;
    border: 1px solid var(--hub-line);
    color: var(--hub-ink);
    padding: 6px 12px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.85rem;
    text-align: center;
  }

  .restore-input-row {
    display: flex;
    gap: 8px;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideUp {
    from { transform: translateY(16px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  @media (max-width: 780px) {
    .hub-side-col {
      align-items: stretch;
    }
    .hub-profile-widget {
      max-width: none;
    }
  }
</style>

<script is:inline>
  (() => {
    const activeProfileNameEl = document.querySelector('[data-profile-name]');
    const activeProfileIconEl = document.querySelector('[data-profile-icon]');
    const profileWidget = document.querySelector('[data-profile-widget]');
    
    // Modals
    const editProfileModal = document.querySelector('[data-edit-profile-modal]');
    const settingsModal = document.querySelector('[data-settings-modal]');
    
    // Buttons to open modals
    const editProfileBtn = document.querySelector('[data-profile-edit-btn]');
    const settingsBtn = document.querySelector('[data-profile-settings-btn]');
    
    // Buttons to close modals
    const editProfileCloseBtn = document.querySelector('[data-edit-profile-close-btn]');
    const settingsCloseBtn = document.querySelector('[data-settings-close-btn]');
    
    // Edit Modal inputs & buttons
    const editProfileNameInput = document.getElementById('edit-profile-name');
    const editProfileAvatarInput = document.getElementById('edit-profile-avatar-input');
    const saveProfileBtn = document.querySelector('[data-save-profile-btn]');
    const presetButtons = document.querySelectorAll('.avatar-preset-btn');
    
    // Settings Modal buttons
    const addGuestBtn = document.querySelector('[data-add-guest-btn]');
    
    const PROFILES_KEY = "piichan-novels:profiles";
    const ACTIVE_KEY = "piichan-novels:active-profile-id";

    const TROLL_NAMES = [
      "ดูดหีน้ำแตก", "ขี้ทะลวงดาก", "อมไข่สั่นสู้ชีวิต", "กูชื่อไรวะ?", "ตดเปียกในลิฟต์",
      "ขี้เล็ดกลางห้าง", "จิ๋มกระพือฮือฮา", "หีบินได้", "ควยเหล็กเจ็ดสี", "ดากดำช้ำรัก",
      "ตูดหมึกอมนิ้ว", "จิบเบียร์เลียตูด", "อมขี้มาพ่น", "ส้นตีนกระแทกปาก", "ไข่เหี่ยวเปรี้ยวเยี่ยว",
      "ตดไม่มีเสียงแต่ดมแล้วตาย", "หำหดตดหาย", "อมหำช้าง", "ตดอัดกระป๋อง", "เสี้ยนดากอยากโดน",
      "ควยเรืองแสง", "แรดบินตินถีบ", "หัวควยสี่ทิศ", "เยี่ยวราดรดกางเกง", "ดมตูดหมาแก่งแก้",
      "อ่างขี้ปลาทอง", "คนบ้าปัญญาอ่อน", "เลียกระป๋องกาว", "น้ำเงี่ยนไหลอาบแก้ม", "อมขี้หมาสู้ชีวิต",
      "ตดเปียกทะลุกางเกง", "มะเร็งควย", "กระโถนท้องพระโรง", "คูดารูสึกดี", "เลียแคมสะท้านโลกันตร์",
      "ควยระเบิด", "ดมกลิ่นดากตัวเอง", "ขี้คาตูด", "ดากฉีกถึงหู", "ล้างตูดไม่สะอาด",
      "ชักว่าวจนไข่แห้ง", "อมท่อไอเสีย", "หน้าควยธรรมชาติ", "เยี่ยวเหนียวเคี้ยวหนึบ", "ส้วมเต็มช้อนกิน",
      "นิ้วเขี่ยตูดดม", "ขี้เหนียวเคี้ยวเพลิน", "ควยเปียกแดด", "ดมผ้าอนามัยใช้แล้ว", "ดากทองคำฝังเพชร"
    ];

    function getProfiles() {
      try {
        const raw = localStorage.getItem(PROFILES_KEY);
        return raw ? JSON.parse(raw) : [];
      } catch (e) {
        return [];
      }
    }

    function saveProfiles(profiles) {
      localStorage.setItem(PROFILES_KEY, JSON.stringify(profiles));
    }

    function getActiveProfileId() {
      return localStorage.getItem(ACTIVE_KEY);
    }

    function setActiveProfileId(id) {
      localStorage.setItem(ACTIVE_KEY, id);
    }

    function getRandomTrollName(profiles) {
      const usedNames = new Set(profiles.map(p => p.name));
      const availableNames = TROLL_NAMES.filter(name => !usedNames.has(name));
      
      if (availableNames.length > 0) {
        const randomIndex = Math.floor(Math.random() * availableNames.length);
        return availableNames[randomIndex];
      }
      
      // Fallback: append random number
      const baseName = TROLL_NAMES[Math.floor(Math.random() * TROLL_NAMES.length)];
      return `${baseName} #${Math.floor(Math.random() * 1000)}`;
    }

    function renderAvatar(avatarValue, containerElement) {
      if (!containerElement) return;
      containerElement.innerHTML = '';
      
      const val = (avatarValue || '👤').trim();
      const isUrl = val.startsWith('http://') || val.startsWith('https://') || val.startsWith('/') || val.startsWith('./') || val.startsWith('../');
      
      if (isUrl) {
        const img = document.createElement('img');
        img.src = val;
        img.alt = 'Avatar';
        containerElement.appendChild(img);
      } else {
        containerElement.textContent = val;
      }
    }

    const init = () => {
      let activeId = getActiveProfileId();
      let profiles = getProfiles();

      // Check if we need to auto-initialize guest profile
      if (!activeId || !profiles.some(p => p.id === activeId)) {
        const newGuestId = 'p_' + Date.now() + '_' + Math.random().toString(36).substring(2, 11);
        const name = getRandomTrollName(profiles);
        profiles.push({
          id: newGuestId,
          name: name,
          avatar: "👤",
          type: 'guest',
          createdAt: Date.now()
        });
        saveProfiles(profiles);
        setActiveProfileId(newGuestId);
        activeId = newGuestId;
      }

      // Show profile bar
      const activeProfile = profiles.find(p => p.id === activeId);
      if (activeProfile) {
        if (activeProfileNameEl) {
          activeProfileNameEl.textContent = activeProfile.name;
        }
        if (activeProfileIconEl) {
          renderAvatar(activeProfile.avatar, activeProfileIconEl);
        }
        if (profileWidget) {
          profileWidget.style.display = 'flex';
        }
      }
    };

    // Edit Profile Modal logic
    if (editProfileBtn) {
      editProfileBtn.addEventListener('click', () => {
        const activeId = getActiveProfileId();
        const profiles = getProfiles();
        const activeProfile = profiles.find(p => p.id === activeId);
        
        if (activeProfile && editProfileNameInput instanceof HTMLInputElement && editProfileAvatarInput instanceof HTMLInputElement) {
          editProfileNameInput.value = activeProfile.name;
          editProfileAvatarInput.value = activeProfile.avatar || '👤';
          
          // Clear active presets
          presetButtons.forEach(btn => btn.classList.remove('is-selected'));
          
          // Highlight preset if matching
          presetButtons.forEach(btn => {
            if (btn.getAttribute('data-preset') === activeProfile.avatar) {
              btn.classList.add('is-selected');
            }
          });
          
          if (editProfileModal) {
            editProfileModal.style.display = 'flex';
          }
        }
      });
    }

    if (editProfileCloseBtn) {
      editProfileCloseBtn.addEventListener('click', () => {
        if (editProfileModal) editProfileModal.style.display = 'none';
      });
    }

    presetButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        presetButtons.forEach(b => b.classList.remove('is-selected'));
        btn.classList.add('is-selected');
        if (editProfileAvatarInput instanceof HTMLInputElement) {
          editProfileAvatarInput.value = btn.getAttribute('data-preset') || '👤';
        }
      });
    });

    if (saveProfileBtn) {
      saveProfileBtn.addEventListener('click', () => {
        if (editProfileNameInput instanceof HTMLInputElement && editProfileAvatarInput instanceof HTMLInputElement) {
          const newName = editProfileNameInput.value.trim();
          const newAvatar = editProfileAvatarInput.value.trim();
          
          if (!newName) {
            alert('โปรดระบุชื่อผู้ใช้!');
            return;
          }
          
          const activeId = getActiveProfileId();
          let profiles = getProfiles();
          const pIndex = profiles.findIndex(p => p.id === activeId);
          
          if (pIndex !== -1) {
            profiles[pIndex].name = newName;
            profiles[pIndex].avatar = newAvatar || '👤';
            saveProfiles(profiles);
            if (editProfileModal) editProfileModal.style.display = 'none';
            window.location.reload();
          }
        }
      });
    }

    // Switch profile modal logic
    if (settingsBtn) {
      settingsBtn.addEventListener('click', () => {
        if (settingsModal) {
          settingsModal.style.display = 'flex';
          renderSettingsProfiles();
        }
      });
    }

    if (settingsCloseBtn) {
      settingsCloseBtn.addEventListener('click', () => {
        if (settingsModal) settingsModal.style.display = 'none';
      });
    }

    // Close modal on background click
    [editProfileModal, settingsModal].forEach(modal => {
      if (modal) {
        modal.addEventListener('click', (e) => {
          if (e.target === modal) {
            modal.style.display = 'none';
          }
        });
      }
    });

    const renderSettingsProfiles = () => {
      const listContainer = document.querySelector('[data-profiles-list]');
      if (!listContainer) return;
      listContainer.innerHTML = '';

      const profiles = getProfiles();
      const activeId = getActiveProfileId();

      profiles.forEach(p => {
        const item = document.createElement('div');
        item.className = 'profile-item' + (p.id === activeId ? ' is-active' : '');
        
        const info = document.createElement('div');
        info.className = 'profile-item-info';
        
        const iconSpan = document.createElement('span');
        iconSpan.className = 'profile-icon';
        renderAvatar(p.avatar, iconSpan);
        
        const nameStrong = document.createElement('strong');
        nameStrong.textContent = p.name;
        
        info.appendChild(iconSpan);
        info.appendChild(nameStrong);
        item.appendChild(info);

        const actions = document.createElement('div');
        actions.className = 'profile-item-actions';

        if (p.id !== activeId) {
          const switchBtn = document.createElement('button');
          switchBtn.type = 'button';
          switchBtn.className = 'btn-switch';
          switchBtn.textContent = 'ใช้งาน';
          switchBtn.addEventListener('click', () => {
            setActiveProfileId(p.id);
            window.location.reload();
          });
          actions.appendChild(switchBtn);

          const deleteBtn = document.createElement('button');
          deleteBtn.type = 'button';
          deleteBtn.className = 'btn-delete-profile';
          deleteBtn.textContent = 'ลบ';
          deleteBtn.addEventListener('click', () => {
            if (confirm(`คุณแน่ใจหรือไม่ที่จะลบโปรไฟล์ "${p.name}"?`)) {
              // Remove reading state prefixes
              const prefixes = [
                "hvitveldt:reading:",
                "tsukinomi:reading:",
                "hvitveldt:secret:",
                "tsukinomi:reading:secret:",
                "hvitveldt:extra-bypassed",
                "tsukinomi:extra-bypassed"
              ];
              prefixes.forEach(prefix => {
                localStorage.removeItem(`${prefix}:${p.id}`);
              });
              
              const updated = getProfiles().filter(profile => profile.id !== p.id);
              saveProfiles(updated);
              renderSettingsProfiles();
            }
          });
          actions.appendChild(deleteBtn);
        }

        item.appendChild(actions);
        listContainer.appendChild(item);
      });
    };

    if (addGuestBtn) {
      addGuestBtn.addEventListener('click', () => {
        const profiles = getProfiles();
        const newGuestId = 'p_' + Date.now() + '_' + Math.random().toString(36).substring(2, 11);
        const name = getRandomTrollName(profiles);
        
        profiles.push({
          id: newGuestId,
          name: name,
          avatar: "👤",
          type: 'guest',
          createdAt: Date.now()
        });
        saveProfiles(profiles);
        setActiveProfileId(newGuestId);
        
        if (settingsModal) settingsModal.style.display = 'none';
        window.location.reload();
      });
    }

    init();
    document.addEventListener('astro:page-load', init);
  })();
</script>

