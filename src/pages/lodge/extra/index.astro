---
import LodgeBaseLayout from "../../../layouts/lodge/LodgeBaseLayout.astro";
---

<LodgeBaseLayout
  title="ส่วนเสริม — ฮวิตเวลต์ ลอดจ์"
  description="เบื้องหลัง เอกสาร และของแถมของฮวิตเวลต์ ลอดจ์"
  bodyClass="extra-page"
>
  <main class="lodge-extra">
    <p class="lodge-extra-kicker">Extra</p>
    <h1>ส่วนเสริม</h1>
    <p>พื้นที่สำหรับเบื้องหลัง เอกสารที่พบ และของแถมของฮวิตเวลต์ ลอดจ์</p>
    <div class="lodge-extra-soon">กำลังจัดเตรียม — เร็ว ๆ นี้</div>
  </main>

  <style>
    .lodge-extra {
      max-width: 44rem;
      margin: 0 auto;
      padding: 6rem 1.25rem 5rem;
      text-align: center;
      color: var(--ink);
    }

    .lodge-extra-kicker {
      font-family: var(--font-mono);
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--ink-dim);
      font-size: 0.74rem;
    }

    .lodge-extra h1 {
      margin: 0.45rem 0 1rem;
      font-size: clamp(1.8rem, 5vw, 2.6rem);
    }

    .lodge-extra p {
      color: var(--ink-dim);
      line-height: 1.8;
    }

    .lodge-extra-soon {
      margin-top: 2.4rem;
      padding: 1.4rem;
      border: 1px dashed color-mix(in oklab, var(--ink) 22%, transparent);
      color: var(--ink-dim);
      font-family: var(--font-mono);
      font-size: 0.9rem;
    }
  </style>
</LodgeBaseLayout>
