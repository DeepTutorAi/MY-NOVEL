---
import "../styles/global.css";
import "../styles/polish.css";
import { ClientRouter } from "astro:transitions";
import BackgroundFog from "../components/atmosphere/BackgroundFog.astro";
import GrainOverlay from "../components/atmosphere/GrainOverlay.astro";
import SnowCanvas from "../components/atmosphere/SnowCanvas.astro";
import TopBar from "../components/navigation/TopBar.astro";
import { withBase } from "../utils/base-path";

interface Props {
  title: string;
  description: string;
  bodyClass?: string;
  showTopBar?: boolean;
  ogImage?: string;
}

const { title, description, bodyClass, showTopBar = true, ogImage = "/og.jpg" } = Astro.props;
const canonical = Astro.url.href;
const resolvedOgImage = new URL(withBase(ogImage), Astro.site ?? Astro.url).href;
const faviconLit = withBase("/favicon.svg");
const faviconOut = withBase("/favicon-out.svg");
const faviconPng = withBase("/favicon.png");
const bodyClasses = [bodyClass, showTopBar ? "has-topbar" : "no-topbar"]
  .filter(Boolean)
  .join(" ");
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0E0D0C" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={faviconLit} type="image/svg+xml" />
    <link rel="icon" href={faviconPng} type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href={faviconPng} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <ClientRouter />
  </head>
  <body class={bodyClasses}>
    <BackgroundFog />
    <GrainOverlay />
    <SnowCanvas />
    {showTopBar && <TopBar />}
    <slot />
    <script is:inline define:vars={{ faviconLit, faviconOut }}>
      (() => {
        const media = window.matchMedia("(prefers-reduced-motion: no-preference)");
        const icon = document.querySelector('link[rel="icon"]');

        if (!media.matches || !(icon instanceof HTMLLinkElement)) {
          return;
        }

        const lit = faviconLit;
        const out = faviconOut;
        const schedule = () => {
          const delay = 20000 + Math.random() * 40000;
          window.setTimeout(() => {
            icon.href = out;
            window.requestAnimationFrame(() => {
              icon.href = lit;
              schedule();
            });
          }, delay);
        };

        schedule();
      })();
    </script>
  </body>
</html>
