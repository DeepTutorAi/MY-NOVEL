---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import BackgroundFog from "../components/atmosphere/BackgroundFog.astro";
import GrainOverlay from "../components/atmosphere/GrainOverlay.astro";
import SnowCanvas from "../components/atmosphere/SnowCanvas.astro";
import AmbientPlayer from "../components/audio/AmbientPlayer.astro";

interface Props {
  title: string;
  description: string;
  bodyClass?: string;
}

const { title, description, bodyClass } = Astro.props;
const canonical = Astro.url.href;
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0E0D0C" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <ClientRouter />
  </head>
  <body class={bodyClass}>
    <BackgroundFog />
    <GrainOverlay />
    <SnowCanvas />
    <AmbientPlayer />
    <slot />
    <script is:inline>
      (() => {
        const media = window.matchMedia("(prefers-reduced-motion: no-preference)");
        const icon = document.querySelector('link[rel="icon"]');

        if (!media.matches || !(icon instanceof HTMLLinkElement)) {
          return;
        }

        const lit = "/favicon.svg";
        const out = "/favicon-out.svg";
        const schedule = () => {
          const delay = 20000 + Math.random() * 40000;
          window.setTimeout(() => {
            icon.href = out;
            window.requestAnimationFrame(() => {
              icon.href = lit;
              schedule();
            });
          }, delay);
        };

        schedule();
      })();
    </script>
  </body>
</html>
