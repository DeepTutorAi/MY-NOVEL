---
import type { CollectionEntry } from "astro:content";

interface Props {
  section: CollectionEntry<"tsukinomiSections">;
}

const { section } = Astro.props;
const roman = ["I", "II", "III", "IV", "V"][section.data.number - 1] ?? String(section.data.number);
---

<header class="section-header">
  <div class="section-number">Section {roman}</div>
  <div class="section-english">{section.data.englishTitle}</div>
  <h1>{section.data.title}</h1>
  <div class="section-range">{section.data.chapterRange} · {section.data.readingMinutes} นาที</div>
</header>
