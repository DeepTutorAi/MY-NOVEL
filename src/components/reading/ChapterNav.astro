---
import type { CollectionEntry } from "astro:content";
import { withBase } from "../../utils/base-path";

interface Props {
  previous?: CollectionEntry<"chapters">;
  next?: CollectionEntry<"chapters">;
  isFinalChapter?: boolean;
}

const { previous, next, isFinalChapter = false } = Astro.props;
---

<nav class="chapter-nav" aria-label="Chapter navigation">
  <div>
    {
      previous ? (
        <a href={withBase(`/chapters/${previous.id}/`)}>← Ch {previous.data.number}: {previous.data.title}</a>
      ) : (
        <span aria-hidden="true"></span>
      )
    }
  </div>
  <div>
    {
      isFinalChapter ? (
        <a class="chapter-nav-warning" href={withBase("/puzzle/")}>
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 4 21 20H3L12 4Z" />
            <path d="M12 9v5M12 17h.01" />
          </svg>
          Puzzle Map →
        </a>
      ) : next ? (
        <a href={withBase(`/chapters/${next.id}/`)}>Ch {next.data.number}: {next.data.title} →</a>
      ) : null
    }
  </div>
</nav>
