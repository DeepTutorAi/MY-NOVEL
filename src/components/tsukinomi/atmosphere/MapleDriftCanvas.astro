<canvas class="maple-drift-canvas" aria-hidden="true"></canvas>

<script>
  const canvas = document.querySelector(".maple-drift-canvas");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  if (canvas instanceof HTMLCanvasElement) {
    const context = canvas.getContext("2d");
    const mobile = window.matchMedia("(max-width: 640px)");
    let width = 0;
    let height = 0;
    let frame = 0;
    let resizeTimer = 0;

    type DriftProfile = {
      density: number;
      mobileDensity: number;
      kind: "leaf" | "rain-leaf" | "none" | "ash" | "snow-light";
      colors: string[];
      opacity: [number, number];
      speed: [number, number];
      size: [number, number];
    };

    type DriftParticle = {
      x: number;
      y: number;
      size: number;
      speed: number;
      driftX: number;
      rotation: number;
      rotationSpeed: number;
      opacity: number;
      color: string;
      kind: DriftProfile["kind"];
    };

    type ProtectedRect = {
      rect: DOMRect;
      pad: number;
    };

    const profiles: Record<string, DriftProfile> = {
      autumn: {
        density: 40,
        mobileDensity: 18,
        kind: "leaf",
        colors: ["#c98648", "#b66e3f", "#d6a35c", "#8f5a3b"],
        opacity: [0.28, 0.62],
        speed: [0.18, 0.58],
        size: [5, 13],
      },
      twilight: {
        density: 30,
        mobileDensity: 12,
        kind: "rain-leaf",
        colors: ["#c98648", "#8d6f55", "#4a6b7e", "#b98a58"],
        opacity: [0.18, 0.46],
        speed: [0.34, 0.88],
        size: [4, 10],
      },
      "warm-room": {
        density: 0,
        mobileDensity: 0,
        kind: "none",
        colors: ["#c98648"],
        opacity: [0, 0],
        speed: [0, 0],
        size: [0, 0],
      },
      "snow-pact": {
        density: 12,
        mobileDensity: 6,
        kind: "ash",
        colors: ["#a7b7bd", "#8a8f90", "#6e2730", "#d8c7ad"],
        opacity: [0.12, 0.34],
        speed: [0.16, 0.42],
        size: [2, 6],
      },
      "winter-light": {
        density: 24,
        mobileDensity: 10,
        kind: "snow-light",
        colors: ["#d8e1df", "#aebfc6", "#e8dcc4"],
        opacity: [0.16, 0.42],
        speed: [0.16, 0.5],
        size: [2, 7],
      },
    };

    let particles: DriftParticle[] = [];

    const activeProfile = () => {
      const section = document.body.dataset.section || "autumn";
      return profiles[section] ?? profiles.autumn;
    };

    const particleCap = () => {
      const profile = activeProfile();
      return mobile.matches ? profile.mobileDensity : profile.density;
    };

    const randomBetween = ([min, max]: [number, number]) => min + Math.random() * (max - min);

    const createParticle = (initial = false): DriftParticle => {
      const profile = activeProfile();
      const size = randomBetween(profile.size);
      const diagonal = profile.kind === "rain-leaf";

      return {
        x: Math.random() * width,
        y: initial ? Math.random() * height : -size - 12,
        size,
        speed: randomBetween(profile.speed),
        driftX: diagonal ? -0.38 - Math.random() * 0.5 : -0.16 + Math.random() * 0.42,
        rotation: Math.random() * Math.PI * 2,
        rotationSpeed: -0.012 + Math.random() * 0.024,
        opacity: randomBetween(profile.opacity),
        color: profile.colors[Math.floor(Math.random() * profile.colors.length)] ?? profile.colors[0],
        kind: profile.kind,
      };
    };

    const particleInPaddedRect = (particle: DriftParticle, rect: DOMRect, pad: number) => {
      if (rect.width <= 0 || rect.height <= 0) {
        return false;
      }

      const left = rect.left - pad;
      const right = rect.right + pad;
      const top = Math.max(0, rect.top - pad);
      const bottom = Math.min(height, rect.bottom + pad);

      return (
        particle.x + particle.size >= left &&
        particle.x - particle.size <= right &&
        particle.y + particle.size >= top &&
        particle.y - particle.size <= bottom
      );
    };

    const getReaderProtectedRects = () => {
      const article = document.querySelector("article.tsukinomi-section");

      if (!(article instanceof HTMLElement)) {
        return [];
      }

      const pad = mobile.matches ? 12 : 24;
      return [{ rect: article.getBoundingClientRect(), pad }] satisfies ProtectedRect[];
    };

    const particleOverReaderProtectedArea = (
      particle: DriftParticle,
      protectedRects: ProtectedRect[],
    ) => protectedRects.some(({ rect, pad }) => particleInPaddedRect(particle, rect, pad));

    const resize = () => {
      const ratio = window.devicePixelRatio || 1;
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = Math.floor(width * ratio);
      canvas.height = Math.floor(height * ratio);
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
      context?.setTransform(ratio, 0, 0, ratio, 0, 0);
      particles = Array.from({ length: particleCap() }, () => createParticle(true));
      canvas.hidden = reduceMotion.matches || particleCap() === 0;
    };

    const drawLeaf = (particle: DriftParticle) => {
      if (!context) {
        return;
      }

      context.save();
      context.translate(particle.x, particle.y);
      context.rotate(particle.rotation);
      context.globalAlpha = particle.opacity;
      context.fillStyle = particle.color;
      context.beginPath();
      context.ellipse(0, 0, particle.size * 0.42, particle.size, 0.7, 0, Math.PI * 2);
      context.fill();
      context.strokeStyle = "rgba(232, 220, 196, 0.22)";
      context.lineWidth = 0.55;
      context.beginPath();
      context.moveTo(0, -particle.size * 0.72);
      context.lineTo(0, particle.size * 0.72);
      context.stroke();
      context.restore();
    };

    const drawRain = (particle: DriftParticle) => {
      if (!context) {
        return;
      }

      context.save();
      context.globalAlpha = particle.opacity * 0.82;
      context.strokeStyle = particle.color;
      context.lineWidth = 1;
      context.beginPath();
      context.moveTo(particle.x, particle.y);
      context.lineTo(particle.x - particle.size * 0.48, particle.y + particle.size * 1.9);
      context.stroke();
      context.restore();
    };

    const drawSpeck = (particle: DriftParticle) => {
      if (!context) {
        return;
      }

      context.save();
      context.globalAlpha = particle.opacity;
      context.fillStyle = particle.color;
      context.beginPath();
      context.arc(particle.x, particle.y, particle.size * 0.42, 0, Math.PI * 2);
      context.fill();
      context.restore();
    };

    const drawParticle = (particle: DriftParticle) => {
      if (particle.kind === "rain-leaf" && Math.random() < 0.58) {
        drawRain(particle);
        return;
      }

      if (particle.kind === "ash" || particle.kind === "snow-light") {
        drawSpeck(particle);
        return;
      }

      drawLeaf(particle);
    };

    const draw = () => {
      if (!context || reduceMotion.matches || particleCap() === 0) {
        context?.clearRect(0, 0, width, height);
        canvas.hidden = true;
        frame = 0;
        return;
      }

      canvas.hidden = false;
      context.clearRect(0, 0, width, height);
      const protectedRects = getReaderProtectedRects();

      for (const particle of particles) {
        particle.y += particle.speed;
        particle.x += particle.driftX;
        particle.rotation += particle.rotationSpeed;

        if (particle.y > height + particle.size + 12) {
          Object.assign(particle, createParticle(false));
        }

        if (particle.x < -24) {
          particle.x = width + 24;
        } else if (particle.x > width + 24) {
          particle.x = -24;
        }

        if (particleOverReaderProtectedArea(particle, protectedRects)) {
          continue;
        }

        drawParticle(particle);
      }

      frame = window.requestAnimationFrame(draw);
    };

    const pause = () => {
      if (frame) {
        window.cancelAnimationFrame(frame);
        frame = 0;
      }
    };

    const resume = () => {
      pause();
      if (!reduceMotion.matches && particleCap() > 0 && document.visibilityState === "visible") {
        frame = window.requestAnimationFrame(draw);
      } else {
        context?.clearRect(0, 0, width, height);
        canvas.hidden = true;
      }
    };

    const refresh = () => {
      pause();
      resize();
      resume();
    };

    resize();
    resume();

    window.addEventListener("resize", () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(refresh, 150);
    });

    reduceMotion.addEventListener("change", refresh);

    document.addEventListener("astro:after-swap", refresh);

    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "hidden") {
        pause();
      } else {
        resume();
      }
    });
  }
</script>

<style>
  .maple-drift-canvas {
    position: fixed;
    inset: 0;
    z-index: 6;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .maple-drift-canvas {
      display: none;
    }
  }
</style>
