---
import "../styles/lodge/global.css";
import "../styles/_shared/hub.css";
import { withBase } from "../utils/base-path";

interface Props {
  title: string;
  description: string;
  bodyClass?: string;
  ogImage?: string;
}

const {
  title,
  description,
  bodyClass = "hub-page",
  ogImage = "/assets/_shared/images/fictionhub.jpg",
} = Astro.props;
const canonical = Astro.url.href;
const resolvedOgImage = new URL(withBase(ogImage), Astro.site ?? Astro.url).href;
const faviconLit = withBase("/favicon.svg");
const faviconPng = withBase("/favicon.png");
---

<!doctype html>
<html lang="th">
  <head>
    <script is:inline>
      (function() {
        if (window.__localStorageIntercepted) return;
        window.__localStorageIntercepted = true;

        const originalGet = localStorage.getItem;
        const originalSet = localStorage.setItem;
        const originalRemove = localStorage.removeItem;

        function getActiveProfileId() {
          try {
            return originalGet.call(localStorage, "piichan-novels:active-profile-id") || "guest";
          } catch(e) {
            return "guest";
          }
        }

        function getProfileKey(key) {
          const prefixes = [
            "hvitveldt:reading:",
            "tsukinomi:reading:",
            "hvitveldt:secret:",
            "tsukinomi:reading:secret:",
            "hvitveldt:extra-bypassed",
            "tsukinomi:extra-bypassed"
          ];
          if (prefixes.some(p => key.startsWith(p))) {
            const activeProfile = getActiveProfileId();
            return `${key}:${activeProfile}`;
          }
          return key;
        }

        localStorage.getItem = function(key) {
          return originalGet.call(localStorage, getProfileKey(key));
        };
        localStorage.setItem = function(key, value) {
          originalSet.call(localStorage, getProfileKey(key), value);
        };
        localStorage.removeItem = function(key) {
          originalRemove.call(localStorage, getProfileKey(key));
        };
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0A0908" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={faviconLit} type="image/svg+xml" />
    <link rel="icon" href={faviconPng} type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href={faviconPng} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>
