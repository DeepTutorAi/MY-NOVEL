---
import type { CollectionEntry } from "astro:content";
import SectionDropcap from "../../components/tsukinomi/reading/SectionDropcap.astro";
import "../../styles/tsukinomi/section.css";
import TsukinomiBaseLayout from "./TsukinomiBaseLayout.astro";

interface Props {
  section: CollectionEntry<"tsukinomiSections">;
}

const { section } = Astro.props;
const siteTitle = "สถานีทะเลพระจันทร์";
const pageTitle = `ภาค ${section.data.number}: ${section.data.title} — ${siteTitle}`;
---

<TsukinomiBaseLayout
  title={pageTitle}
  description={section.data.summary}
  bodyClass={`tsukinomi-section-page section-${section.data.number} palette-${section.data.palette}`}
  sectionPalette={section.data.palette}
  musicCueId={section.data.musicCueId}
>
  <main class="tsukinomi-section-shell">
    <article
      class="tsukinomi-section"
      data-section-id={section.id}
      data-section-number={section.data.number}
      data-section-title={section.data.title}
      data-section-palette={section.data.palette}
      data-music-cue={section.data.musicCueId}
    >
      <SectionDropcap />
      <slot />
    </article>
  </main>
</TsukinomiBaseLayout>
