<div class="sakura-backdrop" aria-hidden="true" data-train="off">
  <div class="sakura-backdrop__base"></div>
  <div class="sakura-backdrop__tint"></div>
  <div class="sakura-backdrop__moon"></div>
  <div class="sakura-backdrop__rays"></div>
  <div class="sakura-backdrop__mist sakura-backdrop__mist--far"></div>
  <div class="sakura-backdrop__mist sakura-backdrop__mist--middle"></div>
  <div class="sakura-backdrop__mist sakura-backdrop__mist--near"></div>
  <div class="sakura-backdrop__train"></div>
  <canvas class="sakura-backdrop__petals" data-sakura-petals></canvas>
  <div class="sakura-backdrop__clock">7:14</div>
  <div class="sakura-backdrop__frame"></div>
</div>

<script>
  type ParticleKind = "petal" | "rain" | "ash" | "snow";

  type Petal = {
    kind: ParticleKind;
    x: number;
    y: number;
    size: number;
    speed: number;
    drift: number;
    sway: number;
    phase: number;
    rotation: number;
    rotationSpeed: number;
    opacity: number;
  };

  type Profile = {
    kinds: ParticleKind[];
    density: number;
    train: "off" | "wait" | "far" | "slow" | "return";
  };

  type BackdropController = {
    destroy: () => void;
  };

  // Story-woven profiles, keyed by section palette. The petal -> snow morph and
  // the distant-train-that-never-comes motif are encoded here, one per arc beat.
  const PROFILES: Record<string, Profile> = {
    "autumn": { kinds: ["petal", "rain"], density: 1, train: "wait" },
    "twilight": { kinds: ["petal", "snow"], density: 0.72, train: "far" },
    "warm-room": { kinds: [], density: 0, train: "off" },
    "snow-pact": { kinds: ["ash", "snow"], density: 0.5, train: "off" },
    "winter-light": { kinds: ["snow"], density: 0.72, train: "return" },
  };
  const HOME_PROFILE: Profile = { kinds: ["petal"], density: 1, train: "slow" };
  const MOTION_STORAGE_KEY = "tsukinomi:motion:backdrop";
  const MOTION_EVENT = "tsukinomi:motion-change";

  const KIND_SPECS: Record<ParticleKind, { size: [number, number]; speed: [number, number]; opacity: [number, number] }> = {
    petal: { size: [5, 12], speed: [0.16, 0.48], opacity: [0.24, 0.58] },
    rain: { size: [7, 13], speed: [1.4, 2.4], opacity: [0.1, 0.22] },
    ash: { size: [1.4, 3], speed: [0.1, 0.26], opacity: [0.14, 0.34] },
    snow: { size: [2, 4.6], speed: [0.18, 0.5], opacity: [0.3, 0.7] },
  };

  const controllerWindow = window as Window & {
    __tsukinomiSakuraBackdrop?: BackdropController;
  };

  controllerWindow.__tsukinomiSakuraBackdrop?.destroy();

  let canvas: HTMLCanvasElement | null = null;
  let context: CanvasRenderingContext2D | null = null;
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  const mobile = window.matchMedia("(max-width: 640px)");
  const desktopPetalCount = 36;
  const mobilePetalCount = 22;
  let petals: Petal[] = [];
  let currentProfile: Profile = HOME_PROFILE;
  let colorSakura = "#E6A6BD";
  let colorMist = "#CDD3E0";
  let colorMoon = "#E8EDF5";
  let width = 0;
  let height = 0;
  let frame = 0;
  let resizeTimer = 0;
  let parallaxFrame = 0;
  let freezeUntil = 0;
  let nextFreezeAt = 0;
  let motionEnabled = true;

  const randomBetween = (min: number, max: number) => min + Math.random() * (max - min);
  const baseCount = () => (mobile.matches ? mobilePetalCount : desktopPetalCount);
  const profileCount = () => (currentProfile.kinds.length ? Math.round(baseCount() * currentProfile.density) : 0);

  const root = () => document.querySelector(".sakura-backdrop");

  const readMotionEnabled = () => {
    try {
      return localStorage.getItem(MOTION_STORAGE_KEY) !== "false";
    } catch {
      return true;
    }
  };

  const resolveProfile = (): Profile => {
    const cls = document.body.className;
    if (/\bsection-home\b/.test(cls) || /\btsukinomi-home-page\b/.test(cls)) {
      return HOME_PROFILE;
    }
    const match = cls.match(/palette-([a-z-]+)/);
    const key = match ? match[1] : "autumn";
    return PROFILES[key] ?? PROFILES.autumn;
  };

  const readColors = () => {
    const cs = getComputedStyle(document.documentElement);
    colorSakura = cs.getPropertyValue("--sakura").trim() || "#E6A6BD";
    colorMist = cs.getPropertyValue("--mist").trim() || "#CDD3E0";
    colorMoon = cs.getPropertyValue("--moon").trim() || "#E8EDF5";
  };

  const scheduleFreeze = (now = performance.now()) => {
    nextFreezeAt = now + randomBetween(8_000, 15_000);
  };

  const bindCanvas = () => {
    canvas = document.querySelector("[data-sakura-petals]");
    context = canvas instanceof HTMLCanvasElement ? canvas.getContext("2d") : null;
  };

  const pickKind = (): ParticleKind => {
    const kinds = currentProfile.kinds;
    return kinds.length ? kinds[Math.floor(Math.random() * kinds.length)] : "petal";
  };

  const createPetal = (initial = false, kind: ParticleKind = pickKind()): Petal => {
    const spec = KIND_SPECS[kind];
    return {
      kind,
      x: randomBetween(-40, width + 40),
      y: initial ? randomBetween(-20, height) : randomBetween(-80, -16),
      size: randomBetween(spec.size[0], spec.size[1]),
      speed: randomBetween(spec.speed[0], spec.speed[1]),
      drift: randomBetween(-0.18, 0.24),
      sway: randomBetween(0.18, 0.62),
      phase: randomBetween(0, Math.PI * 2),
      rotation: randomBetween(0, Math.PI * 2),
      rotationSpeed: randomBetween(-0.012, 0.012),
      opacity: randomBetween(spec.opacity[0], spec.opacity[1]),
    };
  };

  const resetPetals = () => {
    petals = Array.from({ length: profileCount() }, () => createPetal(true));
  };

  const resize = () => {
    bindCanvas();

    if (!canvas || !context) {
      return;
    }

    const ratio = Math.min(window.devicePixelRatio || 1, 2);
    width = window.innerWidth;
    height = window.innerHeight;
    canvas.width = Math.floor(width * ratio);
    canvas.height = Math.floor(height * ratio);
    canvas.style.width = `${width}px`;
    canvas.style.height = `${height}px`;
    context.setTransform(ratio, 0, 0, ratio, 0, 0);
    canvas.hidden = reduceMotion.matches || !motionEnabled;
    resetPetals();
  };

  const updateFreezeState = (now: number) => {
    if (!nextFreezeAt) {
      scheduleFreeze(now);
    }

    if (now >= nextFreezeAt) {
      freezeUntil = now + 1_500;
      scheduleFreeze(freezeUntil);
    }

    return now < freezeUntil;
  };

  const petalOverReader = (petal: Petal) => {
    const article = document.querySelector("article.tsukinomi-section");

    if (!(article instanceof HTMLElement)) {
      return false;
    }

    const rect = article.getBoundingClientRect();
    const pad = mobile.matches ? 10 : 20;

    return (
      petal.x + petal.size >= rect.left - pad &&
      petal.x - petal.size <= rect.right + pad &&
      petal.y + petal.size >= rect.top - pad &&
      petal.y - petal.size <= rect.bottom + pad
    );
  };

  const drawPetal = (petal: Petal, now: number) => {
    if (!context || petalOverReader(petal)) {
      return;
    }

    const x = petal.x + Math.sin(now / 1250 + petal.phase) * petal.sway * 8;

    context.save();
    context.globalAlpha = petal.opacity;

    if (petal.kind === "rain") {
      context.strokeStyle = colorMist;
      context.lineWidth = 1;
      context.beginPath();
      context.moveTo(x, petal.y);
      context.lineTo(x + petal.drift * 6, petal.y + petal.size * 2.4);
      context.stroke();
    } else if (petal.kind === "snow") {
      context.fillStyle = colorMoon;
      context.beginPath();
      context.arc(x, petal.y, petal.size * 0.4, 0, Math.PI * 2);
      context.fill();
    } else if (petal.kind === "ash") {
      context.fillStyle = colorMist;
      context.beginPath();
      context.arc(x, petal.y, petal.size * 0.35, 0, Math.PI * 2);
      context.fill();
    } else {
      // petal: bezier sakura shape with a falling flutter (scaleX tumble)
      const flutter = Math.cos(now / 620 + petal.phase);
      context.translate(x, petal.y);
      context.rotate(petal.rotation);
      context.scale(flutter, 1);
      context.fillStyle = colorSakura;
      context.beginPath();
      context.moveTo(0, -petal.size);
      context.bezierCurveTo(petal.size * 0.78, -petal.size * 0.42, petal.size * 0.64, petal.size * 0.64, 0, petal.size);
      context.bezierCurveTo(-petal.size * 0.64, petal.size * 0.64, -petal.size * 0.78, -petal.size * 0.42, 0, -petal.size);
      context.fill();
    }

    context.restore();
  };

  const draw = (now: number) => {
    if (!canvas || !context || reduceMotion.matches || !motionEnabled || document.hidden || petals.length === 0) {
      context?.clearRect(0, 0, width, height);
      if (canvas) {
        canvas.hidden = reduceMotion.matches || !motionEnabled;
      }
      frame = 0;
      return;
    }

    canvas.hidden = false;
    context.clearRect(0, 0, width, height);
    const frozen = updateFreezeState(now);

    for (const petal of petals) {
      if (!frozen) {
        petal.y += petal.speed;
        petal.x += petal.drift;
        petal.rotation += petal.rotationSpeed;
      }

      if (petal.y > height + 28 || petal.x < -80 || petal.x > width + 80) {
        Object.assign(petal, createPetal(false, petal.kind));
      }

      drawPetal(petal, now);
    }

    frame = window.requestAnimationFrame(draw);
  };

  const pause = () => {
    if (frame) {
      window.cancelAnimationFrame(frame);
      frame = 0;
    }
  };

  const resume = () => {
    pause();
    bindCanvas();

    if (!canvas || !context || reduceMotion.matches || !motionEnabled || document.hidden || petals.length === 0) {
      context?.clearRect(0, 0, width, height);
      if (canvas) {
        canvas.hidden = reduceMotion.matches || !motionEnabled;
      }
      return;
    }

    frame = window.requestAnimationFrame(draw);
  };

  const applyTrainState = () => {
    const node = root();
    if (node instanceof HTMLElement) {
      node.dataset.train = reduceMotion.matches || !motionEnabled ? "off" : currentProfile.train;
    }
  };

  const applyMotionState = () => {
    const node = root();
    if (node instanceof HTMLElement) {
      node.dataset.motion = motionEnabled ? "on" : "off";
    }
  };

  const refresh = () => {
    pause();
    motionEnabled = readMotionEnabled();
    currentProfile = resolveProfile();
    readColors();
    applyMotionState();
    applyTrainState();
    resize();
    scheduleFreeze();
    resume();
  };

  const handleResize = () => {
    window.clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(refresh, 150);
  };

  const handleVisibility = () => {
    if (document.hidden) {
      pause();
    } else {
      resume();
    }
  };

  // Depth: a gentle scroll parallax nudges the moon + light rays (compositor-only).
  const handleScroll = () => {
    if (parallaxFrame) {
      return;
    }

    parallaxFrame = window.requestAnimationFrame(() => {
      const node = root();
      if (node instanceof HTMLElement) {
        node.style.setProperty("--py", String(window.scrollY * 0.02));
      }
      parallaxFrame = 0;
    });
  };

  refresh();

  window.addEventListener("resize", handleResize);
  window.addEventListener("scroll", handleScroll, { passive: true });
  reduceMotion.addEventListener("change", refresh);
  window.addEventListener(MOTION_EVENT, refresh);
  document.addEventListener("visibilitychange", handleVisibility);
  document.addEventListener("astro:after-swap", refresh);

  controllerWindow.__tsukinomiSakuraBackdrop = {
    destroy() {
      pause();
      window.clearTimeout(resizeTimer);
      if (parallaxFrame) {
        window.cancelAnimationFrame(parallaxFrame);
        parallaxFrame = 0;
      }
      window.removeEventListener("resize", handleResize);
      window.removeEventListener("scroll", handleScroll);
      reduceMotion.removeEventListener("change", refresh);
      window.removeEventListener(MOTION_EVENT, refresh);
      document.removeEventListener("visibilitychange", handleVisibility);
      document.removeEventListener("astro:after-swap", refresh);
    },
  };
</script>

<style>
  .sakura-backdrop,
  .sakura-backdrop__base,
  .sakura-backdrop__tint,
  .sakura-backdrop__moon,
  .sakura-backdrop__rays,
  .sakura-backdrop__mist,
  .sakura-backdrop__train,
  .sakura-backdrop__petals,
  .sakura-backdrop__clock,
  .sakura-backdrop__frame {
    position: fixed;
    pointer-events: none;
  }

  .sakura-backdrop {
    inset: 0;
    z-index: 0;
    overflow: hidden;
    background: var(--bg-night);
  }

  .sakura-backdrop__base,
  .sakura-backdrop__tint,
  .sakura-backdrop__moon,
  .sakura-backdrop__rays,
  .sakura-backdrop__petals,
  .sakura-backdrop__frame {
    inset: 0;
  }

  .sakura-backdrop__base {
    background-image: var(--bg-image), var(--bg-fallback-image);
    background-position: center;
    background-position: var(--bg-image-position, center), var(--bg-fallback-position);
    background-size: cover;
    background-size: var(--bg-image-size, cover), var(--bg-fallback-size);
    background-repeat: no-repeat;
    opacity: 0.72;
    transform: scale(1.01);
  }

  .sakura-backdrop__tint {
    background:
      linear-gradient(180deg, rgba(14, 11, 30, 0.84) 0%, rgba(23, 20, 48, 0.74) 44%, rgba(181, 86, 47, 0.32) 100%),
      radial-gradient(circle at 18% 92%, rgba(224, 138, 76, 0.18), transparent 34rem);
    mix-blend-mode: multiply;
  }

  .sakura-backdrop__moon {
    background: radial-gradient(circle at 76% 14%, color-mix(in srgb, var(--moon) 48%, transparent), transparent 14rem);
    opacity: 0.34;
    transform: translateY(calc(var(--py, 0) * 1px));
    animation: sakura-moon-flicker 9s ease-in-out infinite;
  }

  /* Light breath: a faint lamp glow that slowly inhales over the page. */
  .sakura-backdrop__rays {
    background:
      radial-gradient(ellipse at 50% 0%, color-mix(in srgb, var(--lamp, #e0a36a) 12%, transparent), transparent 58%),
      radial-gradient(ellipse at 50% 116%, color-mix(in srgb, var(--lamp, #e0a36a) 9%, transparent), transparent 52%);
    opacity: 0.4;
    transform: translateY(calc(var(--py, 0) * -0.6px));
    animation: sakura-breath 14s ease-in-out infinite;
  }

  .sakura-backdrop__mist {
    inset: -22%;
    background:
      radial-gradient(ellipse at 20% 64%, color-mix(in srgb, var(--mist) 13%, transparent), transparent 28rem),
      radial-gradient(ellipse at 74% 38%, color-mix(in srgb, var(--mist) 9%, transparent), transparent 24rem),
      linear-gradient(90deg, transparent, color-mix(in srgb, var(--mist) 8%, transparent), transparent);
    filter: blur(20px);
  }

  .sakura-backdrop__mist--far {
    opacity: 0.32;
    transform: translate3d(-6%, 2%, 0) scale(1.2);
    animation: sakura-mist-far 96s ease-in-out infinite alternate;
  }

  .sakura-backdrop__mist--middle {
    opacity: 0.42;
    transform: translate3d(4%, -1%, 0) scale(1.1);
    animation: sakura-mist-middle 72s ease-in-out infinite alternate;
  }

  .sakura-backdrop__mist--near {
    opacity: 0.5;
    transform: translate3d(-2%, 0, 0);
    animation: sakura-mist-near 54s ease-in-out infinite alternate;
  }

  /* The train that never comes: a low glow that nears, swells, then fades before arriving. */
  .sakura-backdrop__train {
    inset: auto 0 33% 0;
    height: 2px;
    opacity: 0;
    background: radial-gradient(
      ellipse 13rem 2.2rem at 50% 50%,
      color-mix(in srgb, var(--lamp, #e0a36a) 85%, white 8%),
      transparent 72%
    );
    filter: blur(2px);
    will-change: opacity, transform;
  }

  .sakura-backdrop[data-train="wait"] .sakura-backdrop__train {
    animation: sakura-train-near 32s ease-in-out infinite;
  }

  .sakura-backdrop[data-train="slow"] .sakura-backdrop__train {
    animation: sakura-train-near 44s ease-in-out infinite;
  }

  .sakura-backdrop[data-train="far"] .sakura-backdrop__train {
    animation: sakura-train-far 52s ease-in-out infinite;
  }

  .sakura-backdrop[data-train="return"] .sakura-backdrop__train {
    animation: sakura-train-near 30s ease-in-out 1 both;
  }

  .sakura-backdrop[data-motion="off"] .sakura-backdrop__moon,
  .sakura-backdrop[data-motion="off"] .sakura-backdrop__rays,
  .sakura-backdrop[data-motion="off"] .sakura-backdrop__mist,
  .sakura-backdrop[data-motion="off"] .sakura-backdrop__train {
    animation: none;
  }

  .sakura-backdrop[data-motion="off"] .sakura-backdrop__train {
    opacity: 0;
  }

  .sakura-backdrop[data-motion="off"] .sakura-backdrop__petals {
    display: none;
  }

  .sakura-backdrop__petals {
    width: 100vw;
    height: 100vh;
  }

  .sakura-backdrop__clock {
    right: clamp(1rem, 3vw, 2.75rem);
    bottom: clamp(1.1rem, 3vw, 2.6rem);
    z-index: 5;
    color: var(--moon);
    font-family: var(--font-mono);
    font-size: clamp(2.6rem, 8vw, 7rem);
    letter-spacing: 0;
    line-height: 1;
    opacity: 0.05;
  }

  .sakura-backdrop__frame {
    z-index: 6;
    box-shadow:
      inset 0 0 8rem rgba(4, 3, 10, 0.82),
      inset 0 -28vh 24vh rgba(14, 11, 30, 0.52);
  }

  @keyframes sakura-moon-flicker {
    0%,
    100% {
      opacity: 0.3;
    }

    48% {
      opacity: 0.36;
    }

    54% {
      opacity: 0.25;
    }

    62% {
      opacity: 0.34;
    }
  }

  @keyframes sakura-breath {
    0%,
    100% {
      opacity: 0.28;
    }

    50% {
      opacity: 0.5;
    }
  }

  /* Nears (brightens + widens) then fades out before it ever reaches the platform. */
  @keyframes sakura-train-near {
    0%,
    100% {
      opacity: 0;
      transform: scaleX(0.28);
    }

    42% {
      opacity: 0.5;
      transform: scaleX(0.72);
    }

    68% {
      opacity: 0.16;
      transform: scaleX(1.06);
    }

    82% {
      opacity: 0;
      transform: scaleX(1.2);
    }
  }

  @keyframes sakura-train-far {
    0%,
    100% {
      opacity: 0;
      transform: scaleX(0.2);
    }

    46% {
      opacity: 0.26;
      transform: scaleX(0.48);
    }

    74% {
      opacity: 0.08;
      transform: scaleX(0.64);
    }

    86% {
      opacity: 0;
      transform: scaleX(0.72);
    }
  }

  @keyframes sakura-mist-near {
    from {
      transform: translate3d(-3%, 0, 0) scale(1.04);
    }

    to {
      transform: translate3d(4%, -1.5%, 0) scale(1.08);
    }
  }

  @keyframes sakura-mist-middle {
    from {
      transform: translate3d(3%, -1%, 0) scale(1.1);
    }

    to {
      transform: translate3d(-4%, 2%, 0) scale(1.16);
    }
  }

  @keyframes sakura-mist-far {
    from {
      transform: translate3d(-6%, 2%, 0) scale(1.2);
    }

    to {
      transform: translate3d(5%, -2%, 0) scale(1.24);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sakura-backdrop__moon,
    .sakura-backdrop__rays,
    .sakura-backdrop__mist,
    .sakura-backdrop__train {
      animation: none;
    }

    .sakura-backdrop__rays {
      opacity: 0.32;
    }

    .sakura-backdrop__train {
      opacity: 0;
    }

    .sakura-backdrop__petals,
    .sakura-backdrop__clock {
      display: none;
    }
  }
</style>
