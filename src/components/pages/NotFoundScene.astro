---
import ChapterLayout from "../../layouts/ChapterLayout.astro";
import Rune from "../marks/Rune.astro";
import { withBase } from "../../utils/base-path";

const notFoundChapter = {
  data: {
    number: "404",
    title: "หน้านี้ —",
    act: 4,
    summary: "หน้านี้ไม่ควรมีใครเจอ",
  },
};
---

<ChapterLayout chapter={notFoundChapter} bodyClass="chapter-page not-found-page act-4">
  <header class="chapter-header">
    <div class="chapter-kicker">ชิ้นส่วนที่กู้คืน</div>
    <div class="chapter-number">404</div>
    <h1>หน้านี้ —</h1>
    <Rune seed={404} />
  </header>

  <div class="journal">
    <p>
      ผม — ไม่ — รู้ — ทำไม — คุณ — มาที่ — หน้านี้ — แต่ คุณ — ไม่ — ควร — อยู่ — ที่นี่ — กลับ — ก่อน — มัน — เห็น — คุณ
    </p>
  </div>

  <p class="not-found-audio" data-audio-status>เสียง: ปิด</p>
  <p><a href={withBase("/")}>กลับหน้าหลัก</a></p>

  <script>
    const status = document.querySelector("[data-audio-status]");
    const updateStatus = () => {
      if (status instanceof HTMLElement) {
        status.textContent = `เสียง: ${localStorage.getItem("hvitveldt:audio:enabled") === "true" ? "เปิด" : "ปิด"}`;
      }
    };

    updateStatus();
    document.addEventListener("click", (event) => {
      if (event.target instanceof Element && event.target.closest("[data-ambient-play]")) {
        window.setTimeout(updateStatus, 0);
      }
    });
    window.addEventListener("hvitveldt:audio-error", updateStatus);
  </script>
</ChapterLayout>
