---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import "../styles/chapter.css";

type ChapterLayoutData = CollectionEntry<"chapters"> | {
  data: {
    number: number | string;
    title: string;
    act: number;
    summary?: string;
  };
};

interface Props {
  chapter: ChapterLayoutData;
  bodyClass?: string;
}

const { chapter, bodyClass } = Astro.props;
const chapterNumber = chapter.data.number;
const chapterPrefix = typeof chapterNumber === "number" ? `Ch ${chapterNumber} · ` : "";
const titleSeparator = chapter.data.title.trim().endsWith("—") ? " " : " — ";
const pageTitle = `${chapterPrefix}${chapter.data.title}${titleSeparator}Hvitveldt Lodge`;
const description =
  chapter.data.summary ||
  (typeof chapterNumber === "number" ? `บทที่ ${chapterNumber} ของ Hvitveldt Lodge` : "Hvitveldt Lodge");
---

<BaseLayout
  title={pageTitle}
  description={description}
  bodyClass={bodyClass ?? `chapter-page act-${chapter.data.act}`}
>
  <main class="chapter-shell">
    <article class="chapter" data-chapter={String(chapterNumber)} data-act={chapter.data.act}>
      <slot />
    </article>
  </main>
</BaseLayout>
