---
import type { CollectionEntry } from "astro:content";
import Rune from "../marks/Rune.astro";
import { formatReadingTime } from "../../../utils/reading-time";

interface Props {
  chapter: CollectionEntry<"chapters">;
}

const { chapter } = Astro.props;
const isIntro = chapter.data.number === 0;
---

<header class="chapter-header">
  <div class="chapter-kicker">{isIntro ? "เกริ่นนำ" : `ช่วงที่ ${chapter.data.act} · ${chapter.data.actTitle}`}</div>
  <div class="chapter-number">{isIntro ? "Introduction" : `บทที่ ${chapter.data.number}`}</div>
  <h1>{chapter.data.title}</h1>
  {chapter.data.thaiTitle && <div class="chapter-thai-title">{chapter.data.thaiTitle}</div>}
  {
    chapter.data.readingMinutes && (
      <div class="chapter-reading-time">{formatReadingTime(chapter.data.readingMinutes)}</div>
    )
  }
  <Rune seed={isIntro ? 13 : chapter.data.number} />
</header>
