---
import { getCollection } from "astro:content";
import { ACTS } from "../../utils/act-for-chapter";
import { withBase } from "../../utils/base-path";

const roman = ["I", "II", "III", "IV"];
const chapters = (await getCollection("chapters")).sort(
  (a, b) => a.data.number - b.data.number,
);
---

<details class="toc-menu" data-toc-menu>
  <summary class="toc-trigger" aria-label="เปิดสารบัญ">
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 7v14" />
      <path d="M3 5.5A2.5 2.5 0 0 1 5.5 3H12v18H5.5A2.5 2.5 0 0 0 3 18.5Z" />
      <path d="M21 5.5A2.5 2.5 0 0 0 18.5 3H12v18h6.5A2.5 2.5 0 0 1 21 18.5Z" />
    </svg>
    <span>สารบัญ</span>
  </summary>
  <div class="toc-panel" aria-label="สารบัญ">
    <div class="toc-panel-head">
      <strong>สารบัญ</strong>
      <a href={withBase("/chapters/")}>หน้าสารบัญเต็ม</a>
    </div>
    <div class="toc-panel-body">
      {
        ACTS.map((act, index) => {
          const actChapters = chapters.filter((chapter) => chapter.data.act === act.number);

          return (
            <section class="toc-panel-act" aria-labelledby={`toc-menu-act-${act.number}`}>
              <h2 id={`toc-menu-act-${act.number}`}>
                ช่วง {roman[index]} · {act.title}
              </h2>
              <ul>
                {actChapters.map((chapter) => (
                  <li>
                    <a href={withBase(`/chapters/${chapter.id}/`)}>
                      <span>บทที่ {chapter.data.number} —</span>
                      <strong>{chapter.data.title}</strong>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          );
        })
      }
    </div>
  </div>
</details>

<script>
  const menus = Array.from(document.querySelectorAll("[data-toc-menu]"));

  for (const menu of menus) {
    if (!(menu instanceof HTMLDetailsElement) || menu.dataset.bound === "true") {
      continue;
    }

    menu.dataset.bound = "true";

    menu.addEventListener("toggle", () => {
      if (!menu.open) {
        return;
      }

      for (const other of menus) {
        if (other !== menu && other instanceof HTMLDetailsElement) {
          other.open = false;
        }
      }
    });

    menu.addEventListener("click", (event) => {
      const target = event.target;
      if (target instanceof HTMLAnchorElement) {
        menu.open = false;
      }
    });
  }

  document.addEventListener("click", (event) => {
    const target = event.target;
    for (const menu of menus) {
      if (menu instanceof HTMLDetailsElement && menu.open && target instanceof Node && !menu.contains(target)) {
        menu.open = false;
      }
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape") {
      return;
    }

    for (const menu of menus) {
      if (menu instanceof HTMLDetailsElement) {
        menu.open = false;
      }
    }
  });
</script>

<style>
  .toc-menu {
    position: relative;
    z-index: 2;
  }

  .toc-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-inline-size: 2.25rem;
    block-size: 2.25rem;
    padding-inline: 0.45rem;
    color: var(--ink-dim);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    list-style: none;
    text-decoration: none;
    transition: color 150ms ease-out;
  }

  .toc-trigger::-webkit-details-marker {
    display: none;
  }

  .toc-trigger:hover {
    color: var(--ink);
  }

  .toc-trigger:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .toc-trigger svg {
    inline-size: 1.25rem;
    block-size: 1.25rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.75;
  }

  .toc-panel {
    position: absolute;
    inset-block-start: calc(100% + 0.55rem);
    inset-inline-end: 0;
    width: min(25rem, calc(100vw - 1rem));
    max-height: calc(100vh - var(--topbar-height) - 1rem);
    overflow: auto;
    padding: 1rem;
    border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);
    background: color-mix(in oklab, var(--paper) 92%, black);
    box-shadow: 0 1.5rem 4rem rgb(0 0 0 / 0.42);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-0.35rem);
    transition: opacity 150ms ease-out, transform 150ms ease-out;
  }

  .toc-menu[open] .toc-panel {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .toc-panel-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-block-end: 0.8rem;
    border-block-end: 1px solid color-mix(in oklab, var(--ink) 10%, transparent);
  }

  .toc-panel-head strong {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 400;
  }

  .toc-panel-head a {
    flex: 0 0 auto;
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .toc-panel-body {
    display: grid;
    gap: 1rem;
    padding-block-start: 1rem;
  }

  .toc-panel-act h2 {
    margin: 0 0 0.45rem;
    color: var(--rune);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.08em;
  }

  .toc-panel-act ul {
    display: grid;
    gap: 0.1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .toc-panel-act a {
    display: grid;
    grid-template-columns: 4.7rem 1fr;
    gap: 0.65rem;
    align-items: baseline;
    padding: 0.45rem 0.35rem;
    color: inherit;
    text-decoration: none;
  }

  .toc-panel-act a:hover,
  .toc-panel-act a:focus-visible {
    background: var(--paper-2);
    color: var(--ink);
  }

  .toc-panel-act span {
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: 0.7rem;
  }

  .toc-panel-act strong {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.25;
  }

  @media (max-width: 700px) {
    .toc-trigger span {
      display: none;
    }

    .toc-panel {
      position: fixed;
      inset-block-start: calc(var(--topbar-height) + 0.45rem);
      inset-inline: 0.5rem;
      width: auto;
      max-height: calc(100vh - var(--topbar-height) - 1rem);
    }
  }
</style>
